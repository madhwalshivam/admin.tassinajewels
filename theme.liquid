  // Robust body-level filter sheet (works regardless of ancestor stacking/overflow)
  window.toggleFilterDrawer = function() {
    const existing = document.getElementById('tj-filter-modal');
    if (existing) {
      existing.classList.add('closing');
      document.body.style.overflow = '';
      setTimeout(() => { if (existing.parentNode) existing.remove(); }, 240);
      return;
    }
    window.tjEnsureFilterModalStyles();
    if (typeof renderSidebarFilters === 'function') {
      try { renderSidebarFilters(); } catch (e) { console.error('renderSidebarFilters failed', e); }
    }
    const sidebar = document.getElementById('tj-catalog-sidebar');
    const inner = (sidebar && sidebar.innerHTML.trim())
      ? sidebar.innerHTML
      : '<div style="padding:24px 8px;text-align:center;color:#999;font-size:12px;">No filters available for this view.</div>';
    const modal = document.createElement('div');
    modal.id = 'tj-filter-modal';
    modal.innerHTML = `
      <div class="tj-fm-overlay" onclick="toggleFilterDrawer()"></div>
      <div class="tj-fm-sheet" role="dialog" aria-label="Filters">
        <div class="tj-fm-grabber"></div>
        <div class="tj-fm-head">
          <span class="tj-fm-title">Filters</span>
          <button class="tj-fm-x" onclick="toggleFilterDrawer()" aria-label="Close">✕</button>
        </div>
        <div class="tj-fm-body" id="tj-fm-body">${inner}</div>
        <div class="tj-fm-foot">
          <button class="tj-fm-clear" onclick="clearAllFilters()">Clear All</button>
          <button class="tj-fm-apply" onclick="toggleFilterDrawer()">Show Results</button>
        </div>
      </div>`;
    document.body.appendChild(modal);
    document.body.style.overflow = 'hidden';
  };

  // Keep the open filter sheet in sync after any filter change
  window.tjRefreshFilterModal = function() {
    const body = document.getElementById('tj-fm-body');
    const sidebar = document.getElementById('tj-catalog-sidebar');
    if (body && sidebar) body.innerHTML = sidebar.innerHTML;
  };

  window.handleFilterChange = function(key, val, checked) {
    if (checked) {
      if (!activeFilters[key].includes(val)) {
        activeFilters[key].push(val);
      }
    } else {
      activeFilters[key] = activeFilters[key].filter(v => v !== val);
    }
    applyFiltersToUrl();
    loadProducts();
  };

  window.handleAvailabilityChange = function(val) {
    activeFilters.availability = val;
    applyFiltersToUrl();
    loadProducts();
  };

  window.handlePriceFilterChange = function(key, val) {
    const numVal = val ? parseFloat(val) : null;
    activeFilters[key] = isNaN(numVal) ? null : numVal;
    applyFiltersToUrl();
    loadProducts();
  };

  window.clearAllFilters = function() {
    activeFilters = {
      subcategories: [],
      gender: [],
      plating: [],
      material: [],
      color: [],
      'stone-type': [],
      priceMin: null,
      priceMax: null,
      availability: 'all'
    };
    applyFiltersToUrl();
    loadProducts();
    renderSidebarFilters();
    if (typeof tjRefreshFilterModal === 'function') tjRefreshFilterModal();
  };

  window.applyFiltersToUrl = function() {
    const url = new URL(window.location);
    url.searchParams.delete('p'); // Reset pagination on filter change
    
    const keys = ['subcategories', 'gender', 'plating', 'material', 'color', 'stone-type'];
    keys.forEach(k => {
      if (activeFilters[k] && activeFilters[k].length > 0) {
        url.searchParams.set(k, activeFilters[k].join(','));
      } else {
        url.searchParams.delete(k);
      }
    });

    if (activeFilters.priceMin !== null) {
      url.searchParams.set('priceMin', activeFilters.priceMin);
    } else {
      url.searchParams.delete('priceMin');
    }
    
    if (activeFilters.priceMax !== null) {
      url.searchParams.set('priceMax', activeFilters.priceMax);
    } else {
      url.searchParams.delete('priceMax');
    }

    if (activeFilters.availability !== 'all') {
      url.searchParams.set('availability', activeFilters.availability);
    } else {
      url.searchParams.delete('availability');
    }

    window.history.pushState({}, '', url);
  };

  window.parseFiltersFromUrl = function() {
    const params = new URLSearchParams(window.location.search);
    const keys = ['subcategories', 'gender', 'plating', 'material', 'color', 'stone-type'];
    keys.forEach(k => {
      const val = params.get(k);
      activeFilters[k] = val ? val.split(',') : [];
    });

    const pMin = params.get('priceMin');
    activeFilters.priceMin = pMin ? parseFloat(pMin) : null;
    const pMax = params.get('priceMax');
    activeFilters.priceMax = pMax ? parseFloat(pMax) : null;
    activeFilters.availability = params.get('availability') || 'all';
  };

  // ─── POLICY MODALS ────────────────────────────────────────
  window.openPolicyModal = async function(policyKey) {
    const overlay = document.getElementById('tj-policy-modal-overlay');
    const titleEl = document.getElementById('tj-policy-title');
    const contentEl = document.getElementById('tj-policy-content');
    if (!overlay || !contentEl || !titleEl) return;

    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';

    const titles = {
      privacy_policy: "Privacy Policy",
      terms_of_service: "Terms of Service",
      refund_policy: "Refund & Return Policy",
      shipping_policy: "Shipping & Delivery Policy",
      contact_us: "Contact Us"
    };
    titleEl.textContent = titles[policyKey] || "Store Policy";
    contentEl.textContent = "Loading policies...";

    try {
      let settings = _cachedSettings;
      if (!settings) {
        const cachedRaw = sessionStorage.getItem('tj_c_settings');
        if (cachedRaw) {
          settings = JSON.parse(cachedRaw);
        } else {
          const { data, error } = await db.from('settings').select('*');
          if (!error && data) {
            settings = data;
            try { sessionStorage.setItem('tj_c_settings', JSON.stringify(settings)); } catch(_e) {}
          }
        }
      }

      if (settings) {
        const keyMap = {
          privacy_policy: 'privacy_policy',
          terms_of_service: 'terms_of_service',
          refund_policy: 'refund_policy',
          shipping_policy: 'shipping_policy',
          contact_us: 'contact_us'
        };
        const settingObj = settings.find(s => s.key === keyMap[policyKey]);
        if (settingObj && settingObj.value) {
          contentEl.textContent = settingObj.value;
          return;
        }
      }
      
      const defaultPolicies = {
        privacy_policy: "Privacy Policy\n\nAt Tassina Jewels, we prioritize the protection of your personal and business data. Information gathered during the inquiry and ordering process is handled securely and in accordance with standard confidentiality guidelines.\n\nWe do not sell, trade, or share your contact details or procurement lists with outside parties. If you have any inquiries regarding data usage, please contact support.",
        terms_of_service: "Terms & Conditions\n\nWelcome to Tassina Jewels B2B Portal. By accessing this platform and placing wholesale inquiries, you agree to our standard terms of trade.\n\nAll jewelry products displayed are subject to minimum order quantity (MOQ) limits and wholesale packaging specifications. Pricing, shipping duties, and bulk discounts are finalized during direct invoicing.",
        refund_policy: "Refund & Return Policy\n\nAs a dedicated B2B manufacturer, we maintain strict quality control checks before bulk shipment dispatch. All wholesale transactions are final.\n\nIn the rare event of transit damage or manufacturing defects, claims must be raised with proof (photos/videos) within 7 days of shipment arrival to qualify for store credit or replacement pieces.",
        shipping_policy: "Shipping & Delivery Policy\n\nWe offer secure worldwide delivery for our B2B partners. Delivery is offered free globally for orders exceeding $500.\n\nDispatch times range from 3-7 business days for stock pieces and 15-20 days for custom catalog designs. Estimated shipping timelines and tracking credentials are provided upon invoice settlement.",
        contact_us: "Contact Us\n\nWe would love to hear from you. Our wholesale team is available to assist with product enquiries, bulk pricing, and custom catalog requests.\n\nWhatsApp / Business: +86 15986738500\nWeChat: 15986738500\nEmail: Reach us through the email link in the footer.\n\nBusiness Hours: Monday to Saturday, 9:00 AM – 7:00 PM (GMT+8).\nWe typically respond to all wholesale enquiries within 24 hours."
      };
      contentEl.textContent = defaultPolicies[policyKey] || "Details not found. Please contact wholesale support.";
    } catch(e) {
      console.error(e);
      contentEl.textContent = "Unable to load policy content. Please try again later.";
    }
  };

  window.closePolicyModal = function() {
    const overlay = document.getElementById('tj-policy-modal-overlay');
    if (overlay) overlay.classList.remove('open');
    document.body.style.overflow = '';
  };

  // ─── WECHAT MODAL ─────────────────────────────────────────
  window.openWeChatModal = function() {
    const overlay = document.getElementById('tj-wechat-modal-overlay');
    if (overlay) {
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
  };

  window.closeWeChatModal = function() {
    const overlay = document.getElementById('tj-wechat-modal-overlay');
    if (overlay) {
      overlay.classList.remove('open');
      document.body.style.overflow = '';
    }
  };

  // ─── CLEAN URL HELPERS ────────────────────────────────────
  // Strip platform tracking params. Routing uses query params on the home path
  // (e.g. /?category=slug) so a hard refresh always loads (HTTP 200) — no 404s.
  window.tjCleanUrl = function() {
    const url = new URL(window.location.href);
    let changed = false;

    // Remove tracking/analytics params that clutter the address bar
    ['spm', 'spm_prev', 'scm', 'pvid'].forEach(p => {
      if (url.searchParams.has(p)) { url.searchParams.delete(p); changed = true; }
    });

    if (changed) {
      const clean = url.pathname + (url.search ? url.search : '') + url.hash;
      window.history.replaceState(window.history.state, '', clean);
    }
  };

  // We can route on the client whenever we're on the home template. Old path-style
  // links (/categories/x, /product/x) are still recognised for backward compatibility.
  window.tjIsClientRoutable = function() {
    const p = window.location.pathname;
    return p === '/' || p === '/index' || p.endsWith('theme.liquid') ||
           p.startsWith('/categories') || p.startsWith('/product/');
  };

  // Navigate to a category — query-param URL on the home path (refresh-safe, 200 OK)
  window.navigateToCategory = function(slug) {
    const target = (slug === 'all' || !slug) ? '/' : '/?category=' + encodeURIComponent(slug);
    if (window.tjIsClientRoutable()) {
      window.history.pushState({}, '', target);
      window.renderPageViews();
    } else {
      window.location.href = target;
    }
  };

  // Categories Directory is an overlay — open it directly, without changing the URL,
  // so refreshing the page never re-pops the modal or lands on a blank/404 page.
  window.navigateToCategoryPage = function() {
    if (typeof window.openCategoriesModal === 'function') {
      window.openCategoriesModal();
    }
  };

  // Get premium jewelry vector icons for categories
  window.getCategoryIconSvg = function(cat) {
    if (!cat) return '';
    const slug = (cat.slug || '').toLowerCase();
    const name = (cat.name || '').toLowerCase();
    
    // Rings
    if (slug.includes('ring') || name.includes('ring')) {
      return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="14" r="5"/><path d="M12 9l-2-3.5h4L12 9zM9 3.5h6"/></svg>`;
    }
    // Necklaces / Pendants
    if (slug.includes('neck') || name.includes('neck') || slug.includes('pend') || name.includes('pend')) {
      return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5c4 7 12 7 16 0"/><path d="M12 9v4M12 13l-2 2 2 2 2-2z"/></svg>`;
    }
    // Bracelets
    if (slug.includes('bracelet') || name.includes('bracelet')) {
      return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12a7 7 0 0 0 14 0"/><circle cx="5" cy="12" r="0.8"/><circle cx="7.5" cy="8.5" r="0.8"/><circle cx="12" cy="7" r="0.8"/><circle cx="16.5" cy="8.5" r="0.8"/><circle cx="19" cy="12" r="0.8"/></svg>`;
    }
    // Earrings / Studs
    if (slug.includes('ear') || name.includes('ear') || slug.includes('stud') || name.includes('stud')) {
      return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h2.5v4.5M6 8.5c0 1.5 0.8 2.5 1.5 3.5M18 4h-2.5v4.5M18 8.5c0 1.5-0.8 2.5-1.5 3.5"/><circle cx="7.5" cy="14" r="1.5"/><circle cx="16.5" cy="14" r="1.5"/></svg>`;
    }
    // Bangles
    if (slug.includes('bangle') || name.includes('bangle')) {
      return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="10" rx="9" ry="3"/><ellipse cx="12" cy="14" rx="9" ry="3"/></svg>`;
    }
    // Default fallback
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>`;
  };

  // Open Categories Popup Modal
  window.openCategoriesModal = function() {
    const modal = document.getElementById('tj-cat-modal');
    if (!modal) return;
    modal.classList.add('active');
    document.body.style.overflow = 'hidden';
    window.renderCategoriesModalGrid();
    window.addEventListener('keydown', handleEscapeKey);
  };

  // Close Categories Popup Modal
  window.closeCategoriesModal = function(event) {
    const modal = document.getElementById('tj-cat-modal');
    if (!modal) return;
    modal.classList.remove('active');
    document.body.style.overflow = '';
    
    // Restore bottom navigation highlight state
    const urlParams = new URLSearchParams(window.location.search);
    const pageParam = urlParams.get('page');
    if (pageParam === 'wishlist') {
      selectBottomNav('nav-wishlist');
    } else if (pageParam === 'account') {
      selectBottomNav('nav-account');
    } else {
      selectBottomNav('nav-home');
    }
    
    window.removeEventListener('keydown', handleEscapeKey);
  };

  function handleEscapeKey(e) {
    if (e.key === 'Escape') {
      window.closeCategoriesModal();
    }
  }

  // Render modal content
  window.renderCategoriesModalGrid = function(hasError = false) {
    const grid = document.getElementById('tj-cat-modal-grid');
    if (!grid) return;

    if (hasError) {
      grid.innerHTML = `
        <div style="grid-column:1/-1; text-align:center; padding:40px 20px; color:#1B4332; font-family:var(--font-serif);">
          <svg viewBox="0 0 24 24" fill="none" stroke="#e63946" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 48px; height: 48px; margin: 0 auto 16px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p style="font-size:16px; font-weight:600; margin-bottom:8px;">Failed to Load Collections</p>
          <p style="font-size:12px; color:#666; margin-bottom:16px;">We encountered an error loading the collections. Please try again.</p>
          <button onclick="window.retryLoadFilters()" style="background:#1B4332; color:#E3BA45; border:none; padding:8px 20px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1px; border-radius:20px; cursor:pointer; font-family:var(--font-sans);">Retry</button>
        </div>
      `;

    font-size: 20px;
  }
  .tj-deal-main-title {
    font-family: 'Cinzel', serif;
    font-size: 16px;
    font-weight: 700;
    color: #ffffff !important;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 0;

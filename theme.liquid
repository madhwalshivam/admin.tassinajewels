    if (allCategories.length === 0) {
      grid.innerHTML = `
        <div style="grid-column:1/-1; text-align:center; padding:40px 0; color:#1B4332; font-family:var(--font-serif);">
          <p style="font-size:16px; font-weight:600; margin-bottom:8px;">No Collections Found</p>
          <p style="font-size:12px; color:#666;">Please check back later or refresh the page.</p>
        </div>
      `;
      return;
    }

    grid.innerHTML = allCategories.map(cat => {
      const img = cat.image_url ? formatImageUrl(cat.image_url) : getCategoryFallbackImage(cat);
      const displayName = cat.name.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
      return `
        <div class="tj-cat-modal-card" onclick="selectCategoryFromModal('${cat.slug}')">
          <div class="tj-cat-modal-card-img-wrap">
            <img class="tj-cat-modal-card-img" src="${img}" alt="${cat.name}" loading="lazy" onerror="this.src='${getCategoryFallbackImage(cat)}'">
          </div>
          <div class="tj-cat-modal-card-info">
            <h4 class="tj-cat-modal-card-name">${displayName}</h4>
            <div class="tj-cat-modal-card-arrow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width: 14px; height: 14px;"><path d="M9 5l7 7-7 7"/></svg>
            </div>
          </div>
        </div>
      `;
    }).join('');
  };

  window.selectCategoryFromModal = function(slug) {
    window.closeCategoriesModal();
    window.navigateToCategory(slug);
  };

  window.retryLoadFilters = function() {
    isCategoriesLoading = true;
    window.renderCategoriesModalGrid();
    loadFilters().catch(err => {
      console.error("Retry loading filters error:", err);
      window.renderCategoriesModalGrid(true);
    });
  };

  window.showCategoriesDrawer = function() {
    window.openCategoriesModal();
  };

  window.showCategoriesDirectoryPage = function() {
    window.openCategoriesModal();
  };

  window.renderPageViews = function() {
    // Strip tracking params (spm etc.) and normalize legacy links to clean paths
    if (typeof tjCleanUrl === 'function') { try { tjCleanUrl(); } catch(_e){} }

    // If the server delivered a 404 for a client-routed URL, hide that platform
    // content so our own view renders in its place (keeps the clean URL intact).
    try {
      const _p = window.location.pathname || '';
      const _cfl = document.getElementById('tj-content-for-layout');
      if (_cfl && (_p.startsWith('/categories') || _p.startsWith('/product/'))) {
        _cfl.style.setProperty('display', 'none', 'important');
      }
    } catch (_e) {}

    if (typeof parseFiltersFromUrl === 'function') parseFiltersFromUrl();
    const urlParams = new URLSearchParams(window.location.search);
    const pageParam = urlParams.get('page');
    const pathname = window.location.pathname;
    let catParam = urlParams.get('category');
    let productParam = urlParams.get('product');
    let openCatDirectory = (pageParam === 'categories');

    if (pathname.startsWith('/product/')) {
      productParam = pathname.replace('/product/', '').replace(/\/$/, '');
    }
    if (pathname.startsWith('/categories/')) {
      const seg = pathname.replace('/categories/', '').replace(/\/$/, '');
      if (seg) { catParam = decodeURIComponent(seg); }
      else { openCatDirectory = true; }
    } else if (pathname === '/categories') {
      openCatDirectory = true;
    }
    
    const heroSec = document.getElementById('tj-hero-banner');
    const goatSec = document.getElementById('tj-goat-deal-outer');
    const topOuterSec = document.getElementById('tj-top-deal-outer');
    const shopStyleSec = document.getElementById('tj-shop-by-category-outer');
    const trendingSec = document.getElementById('tj-trending-outer');
    const arrivalsSec = document.getElementById('tj-new-arrivals-section');
    const bestsellersSec = document.getElementById('tj-bestsellers-section');
    
    const campaignSec = document.querySelector('.tj-campaign-section');
    const promisesSec = document.querySelector('.tj-promises-bar');
    const productsSection = document.getElementById('tj-products-section');
    const categoriesDirSection = document.getElementById('tj-categories-directory-section');
    
    const reelsSec = document.getElementById('tj-reels-section');
    const trustBar = document.getElementById('tj-trust-bar');
    const reviewsSec = document.getElementById('tj-reviews-section');
    const bestQualitySec = document.getElementById('tj-best-quality-outer');
    const quickCatsSec = document.getElementById('tj-quick-categories-section');
    const productDetailPage = document.getElementById('tj-product-detail-page');
    
    function highlightNav(id) {
      document.querySelectorAll('.tj-bottom-nav-item').forEach(item => {
        item.classList.toggle('active', item.id === id);
      });
    }

    // The categories directory is an overlay opened by the user, not a page.
    // If someone lands on/refreshes a directory URL, normalise to home and render
    // the home page (do NOT auto-open the modal — that caused the pop-on-refresh bug).
    if (openCatDirectory) {
      try {
        const u = new URL(window.location);
        u.searchParams.delete('page');
        u.pathname = '/';
        window.history.replaceState({}, '', u.pathname + (u.search || ''));
      } catch (_e) {}
      catParam = null;
      productParam = null;
      openCatDirectory = false;
    }

    if (productParam) {
      if (heroSec) heroSec.style.display = 'none';
      if (goatSec) goatSec.style.display = 'none';
      if (topOuterSec) topOuterSec.style.display = 'none';
      if (shopStyleSec) shopStyleSec.style.display = 'none';
      if (trendingSec) trendingSec.style.display = 'none';
      if (arrivalsSec) arrivalsSec.style.display = 'none';
      if (bestsellersSec) bestsellersSec.style.display = 'none';
      if (campaignSec) campaignSec.style.display = 'none';
      if (promisesSec) promisesSec.style.display = 'none';
      if (reelsSec) reelsSec.style.display = 'none';
      if (trustBar) trustBar.style.display = 'none';
      if (reviewsSec) reviewsSec.style.display = 'none';
      if (bestQualitySec) bestQualitySec.style.display = 'none';
      if (quickCatsSec) quickCatsSec.style.display = 'none';
      
      if (categoriesDirSection) categoriesDirSection.style.display = 'none';
      if (productsSection) productsSection.style.display = 'none';
      if (productDetailPage) productDetailPage.style.display = 'block';

      renderProductDetailsPage(productParam);
      highlightNav('nav-home');
      window.scrollTo({ top: 0, behavior: 'auto' });
    }
    else if (catParam) {
      currentCategory = catParam;
      
      if (heroSec) heroSec.style.display = 'none';
      if (goatSec) goatSec.style.display = 'none';
      if (topOuterSec) topOuterSec.style.display = 'none';
      if (shopStyleSec) shopStyleSec.style.display = 'none';
      if (trendingSec) trendingSec.style.display = 'none';
      if (arrivalsSec) arrivalsSec.style.display = 'none';
      if (bestsellersSec) bestsellersSec.style.display = 'none';
      if (campaignSec) campaignSec.style.display = 'none';
      if (promisesSec) promisesSec.style.display = 'none';
      if (reelsSec) reelsSec.style.display = 'none';
      if (trustBar) trustBar.style.display = 'none';
      if (reviewsSec) reviewsSec.style.display = 'none';
      if (bestQualitySec) bestQualitySec.style.display = 'none';
      if (quickCatsSec) quickCatsSec.style.display = 'none';
      
      if (categoriesDirSection) categoriesDirSection.style.display = 'none';
      if (productDetailPage) productDetailPage.style.display = 'none';
      if (productsSection) productsSection.style.display = 'block';
      
      const dropdown = document.querySelector('.tj-filters-dropdown-container');
      if (dropdown) dropdown.style.display = 'none';
      
      const selectEl = document.getElementById('tj-category-select');
      if (selectEl) selectEl.value = catParam;
      
      document.querySelectorAll('.tj-filter-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.category === catParam);
      });

      const heading = document.getElementById('tj-catalog-heading');
      const subtitle = document.getElementById('tj-catalog-subtitle');
      const activeCat = allCategories.find(c => c.slug === catParam);
      if (activeCat) {
        if (heading) heading.textContent = activeCat.name;
        if (subtitle) subtitle.textContent = 'Explore our ' + activeCat.name.toLowerCase() + ' designs — handcrafted with premium quality';
      } else {
        const formatName = catParam.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
        if (heading) heading.textContent = formatName;
        if (subtitle) subtitle.textContent = 'Explore our ' + formatName.toLowerCase() + ' designs — handcrafted with premium quality';
      }
      
      // Render the filter sidebar immediately so it's visible on desktop
      // even before the product fetch resolves (loadProducts refreshes it after).
      if (typeof renderSidebarFilters === 'function') {
        try { renderSidebarFilters(); } catch (e) { console.error('renderSidebarFilters failed', e); }
      }

      loadProducts();
      highlightNav('nav-home');
      
      window.scrollTo({ top: 0, behavior: 'auto' });
    }
    else {
      currentCategory = 'all';
      if (heroSec) heroSec.style.display = 'block';
      
      const sMap = window.tjStorefrontSettings || {};
      if (goatSec) goatSec.style.display = sMap.goat_deal_active !== 'false' ? 'block' : 'none';
      if (topOuterSec) topOuterSec.style.display = sMap.top_deals_active !== 'false' ? 'block' : 'none';
      if (shopStyleSec) shopStyleSec.style.display = sMap.shop_by_cat_active !== 'false' ? 'block' : 'none';
      if (trendingSec) trendingSec.style.display = sMap.trending_active !== 'false' ? 'block' : 'none';
      
      if (arrivalsSec) arrivalsSec.style.display = 'block';
      if (bestsellersSec) bestsellersSec.style.display = sMap.bestsellers_active !== 'false' ? 'block' : 'none';
      if (campaignSec) campaignSec.style.display = 'block';
      if (promisesSec) promisesSec.style.display = 'flex';
      if (reelsSec) reelsSec.style.display = 'block';
      if (trustBar) trustBar.style.display = 'block';
      if (reviewsSec) reviewsSec.style.display = 'block';
      if (bestQualitySec) bestQualitySec.style.display = sMap.best_quality_active !== 'false' ? 'block' : 'none';
      if (quickCatsSec) quickCatsSec.style.display = 'block';
      
      if (categoriesDirSection) categoriesDirSection.style.display = 'none';
      if (productDetailPage) productDetailPage.style.display = 'none';
      if (productsSection) productsSection.style.display = 'none';
      
      const selectEl = document.getElementById('tj-category-select');
      if (selectEl) selectEl.value = 'all';
      
      document.querySelectorAll('.tj-filter-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.category === 'all');
      });

      const heading = document.getElementById('tj-catalog-heading');
      const subtitle = document.getElementById('tj-catalog-subtitle');
      if (heading) heading.textContent = 'Our Collections';
      if (subtitle) subtitle.textContent = 'Handcrafted luxury jewellery — explore our complete range';
      
      loadProducts();
      highlightNav('nav-home');
    }
  };

  // ─── RENDER PRODUCT DETAILS PAGE ─────────────────────────
  // ─── BACK ARROW: go to previous page, fallback Home ─────
  window.tjGoBack = function() {
    if (window.history.length > 1) {
      window.history.back();
    } else {
      window.history.pushState({}, "", "/");
      window.renderPageViews();
    }
    window.scrollTo({ top: 0, behavior: "auto" });
  };

  window.renderProductDetailsPage = async function(slugOrId) {
    if (!allProducts || allProducts.length === 0) {
      if (typeof loadProducts === 'function') {
        await loadProducts();
      } else {
        return;
      }
    }
    
    const p = allProducts.find(x => String(x.id) === String(slugOrId) || x.slug === slugOrId);
    if (!p) {
      const pdp = document.getElementById('tj-product-detail-page');
      if (pdp) {
        pdp.innerHTML = `<div style="text-align:center; padding: 100px 20px;">
          <h2 style="font-family: var(--font-serif); color: #1B4332;">Product Not Found</h2>
          <p style="color: #666; margin-bottom: 24px;">The masterpiece you're looking for could not be located.</p>
          <a href="/" style="display:inline-block; padding: 12px 24px; background: #1B4332; color: #E3BA45; border-radius: 8px; text-decoration: none; text-transform: uppercase; font-size: 11px; font-weight: 700; letter-spacing: 1px;">Return to Collections</a>
        </div>`;
      }
      return;
    }

    const catName = p.category || 'Fine Jewelry';
    const bCrumb = document.getElementById('tj-pdp-breadcrumb');
    if (bCrumb) bCrumb.innerHTML = `<a href="/">Home</a> &nbsp;/&nbsp; <a href="/?category=${p.category_slug || 'all'}">${catName}</a> &nbsp;/&nbsp; <span style="color: #1B4332; font-weight: 500;">${p.title}</span>`;

    const mainImg = document.getElementById('tj-pdp-main-image');
    if (mainImg) {
      mainImg.src = p.image_url ? formatImageUrl(p.image_url) : getProductFallbackImage(p);
      mainImg.alt = p.title;
      
      const imgWrap = document.getElementById('tj-pdp-main-image-wrap');
      if (imgWrap) {
        imgWrap.onmousemove = function(e) {
          const rect = imgWrap.getBoundingClientRect();
          const x = ((e.clientX - rect.left) / rect.width) * 100;
          const y = ((e.clientY - rect.top) / rect.height) * 100;
          mainImg.style.transformOrigin = `${x}% ${y}%`;
          mainImg.style.transform = 'scale(1.8)';
        };
        imgWrap.onmouseleave = function() {
          mainImg.style.transform = 'scale(1)';
          mainImg.style.transformOrigin = 'center center';
        };
      }
    }

    const thumbWrap = document.getElementById('tj-pdp-thumbnails');
    if (thumbWrap) {
      let images = p.image_url ? [p.image_url] : [];
      try {
        if (p.gallery_images) {
          const parsed = JSON.parse(p.gallery_images);
          if (Array.isArray(parsed)) images = images.concat(parsed);
        }
      } catch(e) {}
      
      if (images.length === 0) images = [getProductFallbackImage(p)];
      
      thumbWrap.innerHTML = images.map((img, idx) => `
        <img src="${formatImageUrl(img)}" class="tj-pdp-thumb ${idx === 0 ? 'active' : ''}" onclick="document.getElementById('tj-pdp-main-image').src=this.src; document.querySelectorAll('.tj-pdp-thumb').forEach(t=>t.classList.remove('active')); this.classList.add('active');" alt="Thumbnail">
      `).join('');
    }

    const catBadge = document.getElementById('tj-pdp-category-badge');
    if (catBadge) catBadge.textContent = catName;
    const titleEl = document.getElementById('tj-pdp-title');
    if (titleEl) titleEl.textContent = p.title;
    const priceEl = document.getElementById('tj-pdp-price');
    if (priceEl) priceEl.textContent = '$' + parseFloat(p.price || 0).toFixed(2);

    const compEl = document.getElementById('tj-pdp-compare-price');
    const badgeEl = document.getElementById('tj-pdp-discount-badge');
    if (compEl && badgeEl) {
      if (p.compare_price && parseFloat(p.compare_price) > parseFloat(p.price)) {
        compEl.textContent = '$' + parseFloat(p.compare_price).toFixed(2);
        compEl.style.display = 'inline-block';
        const off = Math.round((1 - parseFloat(p.price) / parseFloat(p.compare_price)) * 100);
        badgeEl.textContent = off + '% OFF';
        badgeEl.style.display = 'inline-block';
      } else {
        compEl.style.display = 'none';
        badgeEl.style.display = 'none';
      }
    }

    const moqEl = document.getElementById('tj-pdp-moq');
    if (moqEl) moqEl.textContent = (p.moq || 2) + ' pieces';
    const matEl = document.getElementById('tj-pdp-material');
    if (matEl) matEl.textContent = p.material || 'Premium Alloy & Plating';
    const wEl = document.getElementById('tj-pdp-weight');
    if (wEl) wEl.textContent = p.weight || 'Standard';

    const shortEl = document.getElementById('tj-pdp-short-desc');
    if (shortEl) shortEl.textContent = p.short_description || 'A timeless, meticulously crafted masterpiece designed for elegance and durability. Available exclusively for our wholesale partners.';
    
    const fullEl = document.getElementById('tj-pdp-full-desc');
    if (fullEl) fullEl.textContent = p.description || 'Elevate your jewelry collection with this exquisite piece. Designed with absolute precision by master craftsmen, it offers unparalleled shine and longevity. Our rigorous quality control ensures that each item meets international premium standards, making it perfect for your retail storefront.\n\nAll our pieces undergo rigorous hypoallergenic testing and are guaranteed skin-friendly, giving your customers the ultimate comfort and confidence.';

    const tblMat = document.getElementById('tj-pdp-table-material');
    if (tblMat) tblMat.textContent = p.material || 'Premium Gold Plated Alloy';
    const tblMoq = document.getElementById('tj-pdp-table-moq');
    if (tblMoq) tblMoq.textContent = (p.moq || 2) + ' Units Minimum';

    const featWrap = document.getElementById('tj-pdp-features');
    if (featWrap) {
      featWrap.innerHTML = `
        <li><strong>Handcrafted Precision:</strong> Each stone is set meticulously by experienced artisans.</li>
        <li><strong>Durability:</strong> Anti-tarnish coating to ensure a long-lasting brilliant finish.</li>
        <li><strong>Comfort Fit:</strong> Designed with smooth edges for all-day comfortable wear.</li>
        <li><strong>Versatile Elegance:</strong> Perfect for both high-end events and daily chic styles.</li>
      `;
    }
    
    const varWrap = document.getElementById('tj-pdp-variants-wrap');
    const varBox = document.getElementById('tj-pdp-variants');
    if (varWrap && varBox) {
      let variants = [];
      try {
        if (p.variants) {
          variants = typeof p.variants === 'string' ? JSON.parse(p.variants) : p.variants;
        }
      } catch(e) {}
      
      if (Array.isArray(variants) && variants.length > 0) {
        varWrap.style.display = 'block';
        varBox.innerHTML = variants.map((v, i) => `<div class="tj-pdp-variant-badge ${i===0?'active':''}" onclick="document.querySelectorAll('.tj-pdp-variant-badge').forEach(b=>b.classList.remove('active')); this.classList.add('active');">${v.name || v}</div>`).join('');
      } else {
        varWrap.style.display = 'none';
      }
    }

    // Action buttons
    const wlBtn = document.getElementById('tj-pdp-wishlist-btn');
    if (wlBtn) {
      const wlKey = 'tj_wl_' + p.id;
      const isNow = localStorage.getItem(wlKey) === '1';
      wlBtn.style.borderColor = isNow ? '#E3BA45' : '#eae6e0';
      wlBtn.style.background = isNow ? '#fff8e0' : '#ffffff';
      wlBtn.style.color = isNow ? '#E3BA45' : '#ccc';
      
      const pIdx = allProducts.findIndex(x => x.id === p.id);
      wlBtn.onclick = function() {
        if (typeof toggleWishlistDetail === 'function') toggleWishlistDetail(p.id, pIdx);
        const isSet = localStorage.getItem(wlKey) === '1';
        wlBtn.style.borderColor = isSet ? '#E3BA45' : '#eae6e0';
        wlBtn.style.background = isSet ? '#fff8e0' : '#ffffff';
        wlBtn.style.color = isSet ? '#E3BA45' : '#ccc';
      };
    }

    const bookBtn = document.getElementById('tj-pdp-book-btn');
    if (bookBtn) {
      bookBtn.onclick = function() {
        if (typeof openModal === 'function') openModal(p);
      };
    }

    // Render Related Products (Same category, excluding current)
    const relGrid = document.getElementById('tj-pdp-related-grid');
    if (relGrid) {
      let related = allProducts.filter(x => x.category_slug === p.category_slug && x.id !== p.id);
      if (related.length === 0) related = allProducts.filter(x => x.id !== p.id).slice(0, 4);
      else related = related.slice(0, 8);
      
      if (related.length > 0) {
        relGrid.innerHTML = related.map((rp, idx) => {
          const imgUrl = rp.image_url ? formatImageUrl(rp.image_url) : getProductFallbackImage(rp);
          const wlKey = 'tj_wl_' + rp.id;
          const isWishlisted = localStorage.getItem(wlKey) === '1';
          const globalIdx = allProducts.findIndex(ap => ap.id === rp.id);
          const detailAction = globalIdx !== -1 ? `openProductDetail(${globalIdx})` : '';
          const bookAction = globalIdx !== -1 ? `openModalByIndex(${globalIdx})` : `openModal(${JSON.stringify(rp)})`;
          const moq = rp.moq || 2;
          
          return `
          <div class="tj-bestseller-card">
            <div class="tj-star-badge">★</div>
            <div class="tj-bestseller-img-wrap" onclick="${detailAction}" style="cursor:pointer;">
              <img class="tj-bestseller-img" src="${imgUrl}" alt="${rp.title}" loading="lazy">
            </div>
            <div class="tj-bestseller-info">
              <div class="tj-stars">★★★★★</div>
              <h3 class="tj-bestseller-title" onclick="${detailAction}" style="cursor:pointer;">${rp.title}</h3>
              <div class="tj-bestseller-desc">${rp.category || 'Fine Jewelry'} &bull; MOQ: ${moq} pcs</div>
              <div class="tj-bestseller-price">$${parseFloat(rp.price || 0).toFixed(2)}${rp.compare_price ? ` - $${parseFloat(rp.compare_price).toFixed(2)}` : ''}</div>
              <div style="display: flex; gap: 8px; width: 100%; margin-top: 10px;">
                <button class="tj-product-btn" style="flex: 1; margin-top: 0; padding: 8px;" onclick="${bookAction}">Book Now</button>
                <button class="tj-card-wishlist-btn ${isWishlisted ? 'wishlisted' : ''}" id="wl-btn-${rp.id}" onclick="event.stopPropagation(); toggleWishlist('${rp.id}', this)" title="Wishlist" style="width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--green); background: ${isWishlisted ? 'var(--green)' : 'transparent'}; color: ${isWishlisted ? 'var(--gold)' : 'var(--green)'}; cursor: pointer; transition: all 0.3s;">
                  <svg width="16" height="16" fill="${isWishlisted ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                  </svg>
                </button>
              </div>
            </div>
          </div>`;
        }).join('');
      } else {
        relGrid.innerHTML = '<div style="text-align:center;width:100%;padding:20px;color:#999;font-size:12px;">No related pieces currently available.</div>';
      }
    }
  };

  window.addEventListener('popstate', () => {
    window.renderPageViews();
  });

  // Get premium fallback category lifestyle image based on keywords
  function getCategoryFallbackImage(cat) {
    if (!cat) return 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?q=80&w=600&auto=format&fit=cover';
    const slug = (cat.slug || '').toLowerCase();
    const name = (cat.name || '').toLowerCase();
    if (slug.includes('ring') || name.includes('ring')) {
      return 'https://images.unsplash.com/photo-1605100804763-247f67b3557e?q=80&w=600&auto=format&fit=cover';
    }
    if (slug.includes('neck') || name.includes('neck') || slug.includes('pend') || name.includes('pend')) {
      return 'https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?q=80&w=600&auto=format&fit=cover';
    }
    if (slug.includes('bracelet') || name.includes('bracelet') || slug.includes('bangle') || name.includes('bangle')) {
      return 'https://images.unsplash.com/photo-1611591437281-460bfbe1220a?q=80&w=600&auto=format&fit=cover';
    }
    if (slug.includes('ear') || name.includes('ear') || slug.includes('stud') || name.includes('stud')) {
      return 'https://images.unsplash.com/photo-1635767798638-3e25273a8236?q=80&w=600&auto=format&fit=cover';
    }
    return 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?q=80&w=600&auto=format&fit=cover';
  }

  // ─── HELPER FUNCTIONS FOR NAVIGATION AND CONTACTS ─────────
  window.scrollSection = function(elementId, direction) {
    const container = document.getElementById(elementId);
    if (!container) return;
    // Clear auto-slide if user manually interacts via navigation arrows
    if (elementId === 'tj-qcat-row-1' && container._autoSlide) {
      clearInterval(container._autoSlide);
      container._autoSlide = null;
    }
    const scrollAmount = container.clientWidth * 0.75;
    if (direction === 'left') {
      container.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    } else {
      container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    }
  };


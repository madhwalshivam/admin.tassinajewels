<!doctype html>
<html
  class='no-js'
  lang='{{ shop.locale }}'
  {% if shop.locale == 'ar-SA' %}dir='rtl'{% endif %}
  id='hero-html' 
>
<head>
  <meta charset='utf-8'>
  <meta http-equiv='X-UA-Compatible' content='IE=edge,chrome=1'>
  <meta name='viewport' content='width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=5,viewport-fit=cover'>
  <title>{{ page_title | default: shop.name }}</title>
  <meta name='description' content='{{ page_description | default: shop.name | escape }}'>
  <link rel='canonical' href='{{ canonical_url }}'>

  <!-- Favicon: use store favicon when configured, otherwise fall back to the brand logo -->
  {% if shop.favicon %}
    <link rel='shortcut icon' href='{{ shop.favicon }}'>
    <link rel='icon' href='{{ shop.favicon }}'>
    <link rel='apple-touch-icon' href='{{ shop.favicon }}'>
  {% else %}
    <link rel='icon' type='image/png' sizes='32x32' href='https://res.cloudinary.com/dxiasatlk/image/upload/w_32,h_32,c_fit/v1783413279/29aa78f0974ba0eff61ad18086e37001_mrvtl3.png'>
    <link rel='icon' type='image/png' sizes='16x16' href='https://res.cloudinary.com/dxiasatlk/image/upload/w_16,h_16,c_fit/v1783413279/29aa78f0974ba0eff61ad18086e37001_mrvtl3.png'>
    <link rel='shortcut icon' type='image/png' href='https://res.cloudinary.com/dxiasatlk/image/upload/w_32,h_32,c_fit/v1783413279/29aa78f0974ba0eff61ad18086e37001_mrvtl3.png'>
    <link rel='apple-touch-icon' sizes='180x180' href='https://res.cloudinary.com/dxiasatlk/image/upload/w_180,h_180,c_fit/v1783413279/29aa78f0974ba0eff61ad18086e37001_mrvtl3.png'>
  {% endif %}
  <meta name='theme-color' content='#1B4332'>
  <meta name='format-detection' content='telephone=no, email=no'>

  <!-- Google Fonts for Luxury Editorial Feel -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  {{ settings.type_title_font_family | font_url | preload_tag: as: 'font', type: 'font/woff2', crossorigin: 'anonymous' }}
  {% render 'social_meta_tags' %}
  {% render 'settings_css' %}
  {{ content_for_header }}


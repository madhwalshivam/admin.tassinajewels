      // Save profile to users table
      if (data.user) {
        try {
          await db.from('users').upsert({
            id: data.user.id,
            email,
            first_name: firstName,
            last_name: lastName,
            phone,
            company,
            created_at: new Date().toISOString()
          }, { onConflict: 'id' });
        } catch (dbErr) {
          console.error("Profile db save error:", dbErr);
        }
      }


  .tj-deal-badge {
    background: var(--gold);
    color: var(--green);
    font-family: var(--font-sans);
    font-size: 8px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 10px;
    border-radius: 20px;
    box-shadow: 0 2px 8px rgba(227,186,69,0.4);
  }
  .tj-deal-slider-row { position: relative; width: 100%; }
  /* Swiper wrapper — FLEXBOX: [←] [scroll] [→] */
  .tj-deal-swiper-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    position: relative;
  }
  .tj-deal-products-scroll {

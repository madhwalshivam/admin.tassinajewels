  window.validateReviewWordCount = function() {
    const commentInput = document.getElementById('review-comment');
    if (!commentInput) return;
    const text = commentInput.value.trim();
    const words = text ? text.split(/\s+/).filter(Boolean) : [];
    const count = words.length;
    
    const counter = document.getElementById('review-word-counter');
    const submitBtn = document.getElementById('tj-review-submit-btn');
    
    if (counter) {
      counter.textContent = `${count} / 50 words`;
      if (count >= 50) {
        counter.style.color = '#0f9d58';
      } else {
        counter.style.color = '#e63946';
      }
    }
    
    if (submitBtn) {
      if (count >= 50) {
        submitBtn.removeAttribute('disabled');
        submitBtn.style.background = 'var(--green)';
        submitBtn.style.color = 'var(--gold)';
        submitBtn.style.cursor = 'pointer';
      } else {
        submitBtn.setAttribute('disabled', 'true');
        submitBtn.style.background = '#8b9b90';
        submitBtn.style.color = '#ffffff';
        submitBtn.style.cursor = 'not-allowed';

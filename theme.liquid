      #tj-filter-modal .tj-fm-apply{flex:2;padding:13px;border:none;background:var(--green);color:var(--gold);border-radius:12px;font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:1px;cursor:pointer;font-family:var(--font-sans);}
      @keyframes tjFmFade{from{opacity:0}to{opacity:1}}
      @keyframes tjFmUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
      @keyframes tjFmPop{from{opacity:0;transform:translate(-50%,-46%)}to{opacity:1;transform:translate(-50%,-50%)}}
      @media(min-width:769px){
        #tj-filter-modal .tj-fm-sheet{left:50%;top:50%;right:auto;bottom:auto;transform:translate(-50%,-50%);width:400px;max-height:82vh;border-radius:16px;animation:tjFmPop .25s ease both;}
        #tj-filter-modal.closing .tj-fm-sheet{transform:translate(-50%,-46%);opacity:0;transition:all .2s ease;animation:none;}

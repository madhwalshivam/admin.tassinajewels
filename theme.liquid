        return `
          <div class="tj-qcat-tile" onclick="closeCategoriesDrawer(); navigateToCategory('${slug}');" style="flex:none; width:85px; margin: 0 auto;">
            <div class="tj-qcat-img-wrapper" style="border: 2px solid ${GREEN}; width:80px; height:80px; border-radius:16px;">
              <img src="${img}" alt="${name}" loading="lazy" onerror="this.src='${getCategoryFallbackImage(cat)}'" style="border-radius:12px;">
            </div>
            <div class="tj-qcat-label"><span style="color:#C9A82C; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:0.3px; display:block; text-align:center; max-width:90px; margin-top:2px;">${name}</span></div>
          </div>`;

    `;
    document.head.appendChild(style);
  })();

  window.handleSortChange = function(val) {
    currentSort = val;
    loadProducts();
  };

  // In-memory cache
  let _cachedProducts = null;
  let _cachedCategories = null;
  let _cachedSubcategories = null;
  let _cachedSettings = null;

  // Persistent product cache (versioned so schema/format changes bust old copies).
  const TJ_PRODUCTS_KEY = 'tj_c_products_v2';
  const TJ_PRODUCTS_MAX_AGE = 12 * 60 * 60 * 1000; // 12h instant-paint window

  // One-time cleanup: remove old/stale cache keys from previous versions so
  // clients never get stuck showing outdated content.
  try {
    ['tj_c_products', 'tj_c_products_v1'].forEach(k => {
      sessionStorage.removeItem(k);
      localStorage.removeItem(k);
    });
  } catch(_e) {}

  // On page reload, drop cached settings/categories so admin changes appear immediately.
  // Products still paint instantly from cache but are always revalidated (see loadProducts).
  try {
    const navEntry = performance.getEntriesByType('navigation')[0];
    if (navEntry && navEntry.type === 'reload') {
      ['tj_c_categories','tj_c_subcats','tj_c_settings'].forEach(k => sessionStorage.removeItem(k));
    }
  } catch(_e) {}

  // Resolve a stored image reference into something the live page can actually load.
  // New uploads store full R2 public URLs (https://pub-xxx.r2.dev/tape/dfix/...).
  // Old uploads stored localhost proxy URLs (http://localhost:3000/api/image/dfix/...).
  // Both are handled here — no admin_domain is needed for dfix/ assets.
  const TJ_R2_PUBLIC = 'https://pub-17a03ed838cff7b48ee24c1876e145fc.r2.dev';
  const TJ_R2_BUCKET = 'tape';

  function formatImageUrl(url) {
    if (!url || typeof url !== 'string') return '';
    url = url.trim();
    if (!url) return '';

    // dfix/ assets live in the R2 bucket — resolve through the admin proxy.
    // Three storage formats are handled:
    //   (a) "dfix/filename.jpg"                         — bare relative path
    //   (b) "/dfix/filename.jpg"                        — root-relative path
    //   (c) "http://localhost:3000/api/image/dfix/..."  — old admin proxy URL
    //   (d) "https://pub-.../tape/dfix/..."              — direct public R2 URL format
    if (url.includes('dfix/')) {
      const parts = url.split('dfix/');
      const rawFilename = (parts[parts.length - 1] || '').split('?')[0];
      const filename = rawFilename.startsWith('/') ? rawFilename.substring(1) : rawFilename;
      if (!filename) return '';
      const rawAdmin = (window.ADMIN_DOMAIN || '').trim().replace(/\/+$/, '') || 'https://admin-tassinajewels.vercel.app';
      return rawAdmin + '/api/image/dfix/' + filename;
    }

    // Already a full HTTPS URL (handles new R2 CDN uploads, Cloudinary, etc.)
    if (url.startsWith('https://')) return url;
    if (url.startsWith('data:') || url.startsWith('blob:')) return url;
    // Protocol-relative → inherit the page protocol.
    if (url.startsWith('//')) return window.location.protocol + url;

    const isPageSecure = window.location.protocol === 'https:';
    const rawAdmin = (window.ADMIN_DOMAIN || '').trim().replace(/\/+$/, '');
    const adminIsUsable = !!rawAdmin && !/^https?:\/\/localhost/i.test(rawAdmin) && !/^https?:\/\/127\./.test(rawAdmin);

    // Localhost URLs that don't involve dfix: rewrite to the real admin domain.
    if (/^https?:\/\/(localhost|127\.0\.0\.1)(:\d+)?/i.test(url)) {
      if (!adminIsUsable) return '';
      return url.replace(/^https?:\/\/(localhost|127\.0\.0\.1)(:\d+)?/i, rawAdmin);
    }

    // Plain http:// on an https:// page is blocked as mixed content. Try https.
    if (url.startsWith('http://')) {
      return isPageSecure ? url.replace(/^http:\/\//i, 'https://') : url;
    }

    // Root-relative or bare path against the admin domain.
    if (url.startsWith('/')) return adminIsUsable ? rawAdmin + url : url;

    return url;
  }


  // Single place that decides what a product image element should show, and what it
  // should fall back to when the network or the URL lets us down.
  window._tjBadImages = [];
  window.tjImgSrc = function(rawUrl, productForFallback) {
    const resolved = formatImageUrl(rawUrl);
    if (resolved) return resolved;

    // A cover quietly turning into a stock photo is invisible to the shop owner.
    // Record what was actually stored so the cause is nameable.
    try {
      const stored = (rawUrl === undefined || rawUrl === null || rawUrl === '') ? '(empty)' : String(rawUrl);
      const label = (productForFallback && (productForFallback.title || productForFallback.id)) || '?';
      if (window._tjBadImages.length < 20 &&
          !window._tjBadImages.some(b => b.stored === stored && b.product === label)) {
        window._tjBadImages.push({ product: label, stored: stored });
        console.warn('[TJ] Image could not be resolved for "' + label + '". Stored value: ' + stored +
          '  → showing a stock fallback. Run tjImageReport() for a summary.');
      }
    } catch (e) {}

    return (typeof getProductFallbackImage === 'function' && productForFallback)
      ? getProductFallbackImage(productForFallback)
      : 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?q=80&w=600&auto=format&fit=cover';
  };

  // Type tjImageReport() in the browser console to see every image the storefront
  // could not load, and why.
  window.tjImageReport = function() {
    const admin = (window.ADMIN_DOMAIN || '').trim();
    console.log('%c[TJ] Image diagnostics', 'font-weight:bold');
    console.log('  storefront_settings.admin_domain = ' + (admin ? admin : 'NOT SET'));
    console.log('  page protocol                    = ' + window.location.protocol);
    if (!window._tjBadImages.length) {
      console.log('  No unresolved images. Every product image loaded from its stored URL.');
      return;
    }
    console.log('  ' + window._tjBadImages.length + ' unresolved image(s):');
    console.table(window._tjBadImages);
    if (!admin) {
      console.log('  Most likely cause: images are stored as admin-hosted (dfix/ or localhost) URLs, ' +
                  'but admin_domain is not set in storefront_settings — so no working URL can be built.');
    }
    return window._tjBadImages;
  };

  // ══════════════════════════════════════════════════════════
  //  VARIANT MODEL
  //  One source of truth for: which variations get their own page/card,
  //  how they are addressed in the URL, and what data they carry.
  // ══════════════════════════════════════════════════════════

  // Do variations also appear as their own cards in the catalog listing?
  //   'off'          — NO. One card per product. Variations live only on that
  //                    product's page, where they are still shown and linkable.
  //                    (Current setting.)
  //   'image-groups' — groups whose options carry their own photo also get a
  //                    listing card each (marketplace style: one card per colour).
  //   'all-groups'   — every variation gets its own listing card.
  window.TJ_VARIANT_PAGE_MODE = window.TJ_VARIANT_PAGE_MODE || 'off';

  window.tjSlugify = function(str) {
    return String(str == null ? '' : str)
      .toLowerCase().trim()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');
  };

  // Whichever column the admin panel actually filled with the option's value.
  // Admin builds differ: option_value, value, name…
  const TJ_OPT_LABEL_KEYS = ['option_value', 'value', 'option', 'option_name', 'label', 'title', 'name'];
  function tjRawOptionLabel(v) {
    if (!v) return '';
    for (let i = 0; i < TJ_OPT_LABEL_KEYS.length; i++) {
      const raw = v[TJ_OPT_LABEL_KEYS[i]];
      if (raw !== undefined && raw !== null && String(raw).trim() !== '') return String(raw).trim();
    }
    return '';
  }

  // Resolved label. tjUsableVariations stamps _tjLabel after looking at the whole
  // group; fall back to the raw read for rows that never went through it.
  window.tjOptionLabel = function(v) {
    if (!v) return '';
    if (v._tjLabel) return v._tjLabel;
    return tjRawOptionLabel(v);
  };

  // Resolved group. Hidden on the page — it exists for screen readers.
  window.tjOptionGroup = function(v) {
    if (!v) return 'Options';
    if (v._tjGroup) return v._tjGroup;
    const g = String(v.variation_name || '').trim();
    return g && g !== window.tjOptionLabel(v) ? g : 'Options';
  };

  window.tjIsUsableVariation = function(v) {
    return window.tjOptionLabel(v) !== '';
  };

  // Normalise a product's variation rows: resolve each option's label and group,
  // and drop rows that cannot be named.
  //
  // The recovery rule is group-aware on purpose. If EVERY row in a group lacks an
  // option value, the admin evidently typed the option into variation_name (a
  // lone {variation_name:"test", option_value:""} row) — so use that as the label
  // rather than showing the shopper nothing. But if a sibling in the same group
  // IS labelled, an unlabelled row is simply a broken record: borrowing the group
  // name would render a bogus option like "test" beside real ones.
  window.tjUsableVariations = function(list) {
    const all = list || [];
    const byGroup = {};
    all.forEach(v => {
      const g = String((v && v.variation_name) || '').trim() || 'Options';
      (byGroup[g] = byGroup[g] || []).push(v);
    });

    const good = [];
    const bad = [];
    Object.keys(byGroup).forEach(g => {
      const rows = byGroup[g];
      const anyLabelled = rows.some(v => tjRawOptionLabel(v) !== '');
      rows.forEach(v => {
        const raw = tjRawOptionLabel(v);
        if (raw) {
          v._tjLabel = raw;
          v._tjGroup = (g && g !== raw) ? g : 'Options';
          good.push(v);
        } else if (!anyLabelled && g !== 'Options') {
          // Whole group unlabelled → variation_name is the option.
          v._tjLabel = g;
          v._tjGroup = 'Options';
          good.push(v);
        } else {
          bad.push(v);
        }
      });
    });

    if (bad.length && !window._tjWarnedBadVariations) {
      window._tjWarnedBadVariations = true;
      console.warn('[TJ] ' + bad.length + ' variation row(s) have a blank option_value while others in the same ' +
        'group are filled, so they are ignored. Fix in Supabase → product_variations. Ids: ' +
        bad.map(v => v.id).join(', '));
    }

    // Two options in one group must not share a label, or their URLs collide.
    const seen = {};
    good.forEach(v => {
      const k = window.tjOptionGroup(v) + '||' + window.tjSlugify(window.tjOptionLabel(v));
      seen[k] = (seen[k] || 0) + 1;
    });
    const dupes = Object.keys(seen).filter(k => seen[k] > 1);
    if (dupes.length && !window._tjWarnedDupeVariations) {
      window._tjWarnedDupeVariations = true;
      console.warn('[TJ] Duplicate option labels within a group — their links collide: ' + dupes.join(', '));
    }
    return good;
  };

  // Columns the admin panel might have used for an option's photo.
  const TJ_VAR_IMG_KEYS = ['image_url', 'image', 'variation_image', 'variant_image',
                           'img_url', 'img', 'photo', 'photo_url', 'thumbnail', 'thumb_url'];
  const TJ_VAR_GALLERY_KEYS = ['images', 'image_urls', 'gallery', 'gallery_images', 'variation_images'];

  function tjParseMaybeJson(val) {
    if (typeof val === 'string') {
      const t = val.trim();
      if (t.startsWith('[') || t.startsWith('{')) {
        try { return JSON.parse(t); } catch (e) { return null; }
      }
      return t ? [t] : null;
    }
    return val;
  }

  // Every image belonging to a variation, in order, de-duplicated.
  window.tjVariationImages = function(v) {
    if (!v) return [];
    const out = [];
    const push = (u) => {
      if (typeof u !== 'string') return;
      const t = u.trim();
      if (t && out.indexOf(t) === -1) out.push(t);
    };
    for (const k of TJ_VAR_IMG_KEYS) push(v[k]);
    for (const k of TJ_VAR_GALLERY_KEYS) {
      const arr = tjParseMaybeJson(v[k]);
      if (Array.isArray(arr)) {
        arr.forEach(item => {
          if (typeof item === 'string') push(item);
          else if (item && typeof item === 'object') TJ_VAR_IMG_KEYS.forEach(kk => push(item[kk]));
        });
      }
    }
    return out;
  };

  // Primary photo for a variation, or null.
  window.tjVariationImage = function(v) {
    const imgs = window.tjVariationImages(v);
    return imgs.length ? imgs[0] : null;
  };

  window.tjVariationOutOfStock = function(v) {
    if (!v) return false;
    return v.stock_status === 'out_of_stock' ||
      (v.stock_quantity !== undefined && v.stock_quantity !== null && Number(v.stock_quantity) <= 0);
  };

  // Effective price of a variation against its parent.
  window.tjVariationPrice = function(v, parent) {
    const pPrice = parseFloat((parent && parent.price) || 0);
    const pCompare = (parent && parent.compare_price) ? parseFloat(parent.compare_price) : null;
    if (!v) return { price: pPrice, compare: pCompare };
    const hasOwn = v.price !== undefined && v.price !== null && v.price !== '';
    const base = hasOwn ? parseFloat(v.price) : pPrice;
    const hasSale = v.sale_price !== undefined && v.sale_price !== null && parseFloat(v.sale_price) > 0;
    if (hasSale) return { price: parseFloat(v.sale_price), compare: base };
    const cmp = (v.compare_price !== undefined && v.compare_price !== null && v.compare_price !== '')
      ? parseFloat(v.compare_price)
      : (hasOwn ? null : pCompare);
    return { price: base, compare: cmp };
  };

  // Group the flat variation rows by variation_name, preserving display_order.
  window.tjGroupVariations = function(variations) {
    const groups = {};
    // Group via tjOptionGroup, not the raw column. When the label itself came from
    // variation_name, grouping on variation_name would file every option into its
    // own single-option group.
    (variations || []).forEach(v => {
      const g = window.tjOptionGroup(v);
      (groups[g] = groups[g] || []).push(v);
    });
    Object.keys(groups).forEach(g => {
      groups[g].sort((a, b) => (a.display_order || 0) - (b.display_order || 0));
    });
    return groups;
  };

  // Is this group page-worthy under the current mode?
  window.tjGroupIsPageWorthy = function(opts) {
    const mode = window.TJ_VARIANT_PAGE_MODE;
    if (mode === 'off') return false;
    if (mode === 'all-groups') return true;
    return (opts || []).some(v => !!window.tjVariationImage(v));
  };

  // Stable, URL-safe key for a variation.
  window.tjVariantKey = function(v) {
    return window.tjSlugify(window.tjOptionLabel(v));
  };

  // Resolve a ?variant= value back to a row: match id first, then option slug.
  window.tjFindVariation = function(variations, key) {
    if (!key || !variations || !variations.length) return null;
    const k = String(key).toLowerCase();
    return variations.find(v => String(v.id).toLowerCase() === k) ||
           variations.find(v => window.tjVariantKey(v) === k) ||
           null;
  };

  window.tjVariantUrl = function(product, v) {
    const slug = (product && (product.slug || product.id)) || '';
    return '/product/' + slug;
  };

  window.tjFindProductByVariation = function(v, currentProductId) {
    if (!v || !allProducts || allProducts.length === 0) return null;
    const vName = String(v.variation_name || '').trim().toLowerCase();
    if (!vName) return null;
    const match = allProducts.find(p => String(p.title || '').trim().toLowerCase() === vName);
    if (match && String(match.id) !== String(currentProductId)) {
      return match;
    }
    return null;
  };

  // Inline onerror attribute: swap to the fallback once, never loop.
  window.tjImgFallbackAttr = function(productForFallback) {
    const fb = (typeof getProductFallbackImage === 'function' && productForFallback)
      ? getProductFallbackImage(productForFallback)
      : 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?q=80&w=600&auto=format&fit=cover';
    return `onerror="this.onerror=null;this.src='${fb}'"`;
  };

  window.renderHeroSlider = function(container, slides) {
    const isMobile = window.innerWidth <= 768;
    if (!slides || slides.length === 0) {
      slides = [{
        desktop_image: 'https://res.cloudinary.com/dxiasatlk/image/upload/v1783425078/banner-1_uyw1j3.jpg',
        mobile_image: 'https://res.cloudinary.com/dxiasatlk/image/upload/v1783425078/banner-1_uyw1j3.jpg',
        link_url: '#tj-products-section'
      }];
    }

    // On desktop show 2 slides at once; on mobile show 1
    const visibleCount = isMobile ? 1 : 2;
    const slideWidthPct = 100 / visibleCount; // 50% on desktop, 100% on mobile
    const gapPx = isMobile ? 0 : 12; // gap between slides on desktop

    let html = `<div class="tj-hero-slides-wrap" id="tj-hero-slides-wrap" style="display:flex; height:auto; transition:transform 0.5s ease-in-out; gap:${gapPx}px;">`;
    slides.forEach(slide => {
      const img = slide.image || (isMobile ? (slide.mobile_image || slide.desktop_image) : (slide.desktop_image || slide.mobile_image));
      const formattedImg = formatImageUrl(img);
      const link = slide.link_url || '#tj-products-section';
      html += `
        <div class="tj-hero-slide" onclick="window.location.href='${link}'" style="flex: 0 0 calc(${slideWidthPct}% - ${gapPx * (visibleCount-1) / visibleCount}px); min-width: 0; border-radius: ${isMobile ? '0' : '10px'}; overflow:hidden; cursor:pointer;">
          <img src="${formattedImg}" alt="Banner" style="width: 100%; height: auto; display: block;">
        </div>
      `;
    });
    html += `</div>`;

    html += `
      <button class="tj-hero-carousel-arrow prev" onclick="event.stopPropagation(); changeHeroSlide(-1)">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button class="tj-hero-carousel-arrow next" onclick="event.stopPropagation(); changeHeroSlide(1)">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <div class="tj-hero-carousel-dots">
        ${slides.map((_, i) => `<button class="tj-hero-carousel-dot ${i === 0 ? 'active' : ''}" onclick="event.stopPropagation(); setHeroSlide(${i})"></button>`).join('')}
      </div>
    `;

    container.innerHTML = html;

    let currentSlideIdx = 0;
    const maxSlideIdx = Math.max(0, slides.length - visibleCount);
    const wrap = container.querySelector('#tj-hero-slides-wrap');
    const dots = container.querySelectorAll('.tj-hero-carousel-dot');
    let autoPlayInterval = null;

    function updateSlide() {
      if (wrap) {
        // Move by slideWidthPct + gap offset per step
        const moveAmt = (slideWidthPct + (gapPx / (container.offsetWidth / 100)));
        wrap.style.transform = `translateX(-${currentSlideIdx * moveAmt}%)`;
      }
      dots.forEach((dot, idx) => {
        dot.classList.toggle('active', idx === currentSlideIdx);
      });
    }

    window.changeHeroSlide = function(dir) {
      let nextIdx = currentSlideIdx + dir;
      if (nextIdx > maxSlideIdx) {
        nextIdx = 0;
      } else if (nextIdx < 0) {
        nextIdx = maxSlideIdx;
      }
      currentSlideIdx = nextIdx;
      updateSlide();
      resetInterval();
    };

    window.setHeroSlide = function(idx) {
      currentSlideIdx = Math.min(idx, maxSlideIdx);
      updateSlide();
      resetInterval();
    };

    function startInterval() {
      autoPlayInterval = setInterval(() => {
        currentSlideIdx = currentSlideIdx >= maxSlideIdx ? 0 : currentSlideIdx + 1;
        updateSlide();
      }, 4000);
    }

    function resetInterval() {
      if (autoPlayInterval) clearInterval(autoPlayInterval);
      startInterval();
    }

    startInterval();
  };

  // ─── LIVE SEARCH DROPDOWN ─────────────────────────────────
  (function() {

  .tj-promise-badge::after {
    content: '';
    position: absolute;
    inset: 3px;
    border: 1px dashed var(--gold);
    border-radius: 50%;
  }
  .tj-promise-icon {
    width: 22px;
    height: 22px;
    color: var(--green);
    z-index: 2;
  }
  .tj-promise-text {
    display: flex;
    flex-direction: column;
  }
  .tj-promise-title {
    font-size: 13px;
    font-weight: 700;

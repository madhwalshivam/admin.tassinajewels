                <svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
              </button>
              <div class="tj-products-grid" id="tj-products-grid">
                <!-- Skeleton loading -->
                {% for i in (1..8) %}
                <div class="tj-product-card">
                  <div class="tj-skeleton" style="height:260px;"></div>
                  <div style="padding:20px;">
                    <div class="tj-skeleton" style="height:10px;width:40%;margin-bottom:8px;"></div>
                    <div class="tj-skeleton" style="height:14px;margin-bottom:12px;"></div>
                    <div class="tj-skeleton" style="height:16px;width:30%;margin-bottom:16px;"></div>
                    <div class="tj-skeleton" style="height:36px;border-radius:4px;"></div>
                  </div>
                </div>
                {% endfor %}
              </div>
              <button class="tj-arrow-btn next" onclick="scrollSection('tj-products-grid', 'right')" aria-label="Next">
                <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
              </button>

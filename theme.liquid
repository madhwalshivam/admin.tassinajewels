  window.renderPageViews = function() {
    // Strip tracking params (spm etc.) and normalize legacy links to clean paths
    if (typeof tjCleanUrl === 'function') { try { tjCleanUrl(); } catch(_e){} }

    // If the server delivered a 404 for a client-routed URL, hide that platform
    // content so our own view renders in its place (keeps the clean URL intact).
    try {
      const _p = window.location.pathname || '';
      const _cfl = document.getElementById('tj-content-for-layout');
      if (_cfl && (_p.startsWith('/categories') || _p.startsWith('/product/'))) {
        _cfl.style.setProperty('display', 'none', 'important');
      }
    } catch (_e) {}

    if (typeof parseFiltersFromUrl === 'function') parseFiltersFromUrl();
    const urlParams = new URLSearchParams(window.location.search);
    const pageParam = urlParams.get('page');
    const pathname = window.location.pathname;
    let catParam = urlParams.get('category');
    let productParam = urlParams.get('product');
    // ?v=<variation-id> — the clean, collision-free variation identifier.
    let variantParam = urlParams.get('v') || urlParams.get('variant');
    let openCatDirectory = (pageParam === 'categories');

    if (pathname.startsWith('/product/')) {
      productParam = pathname.replace('/product/', '').replace(/\/$/, '');
    }
    if (pathname.startsWith('/categories/')) {
      const seg = pathname.replace('/categories/', '').replace(/\/$/, '');
      if (seg) { catParam = decodeURIComponent(seg); }
      else { openCatDirectory = true; }
    } else if (pathname === '/categories') {
      openCatDirectory = true;
    }
    
    const heroSec = document.getElementById('tj-hero-banner');
    const goatSec = document.getElementById('tj-goat-deal-outer');
    const topOuterSec = document.getElementById('tj-top-deal-outer');
    const shopStyleSec = document.getElementById('tj-shop-by-category-outer');
    const trendingSec = document.getElementById('tj-trending-outer');
    const arrivalsSec = document.getElementById('tj-new-arrivals-section');
    const bestsellersSec = document.getElementById('tj-bestsellers-section');
    
    const campaignSec = document.querySelector('.tj-campaign-section');
    const promisesSec = document.querySelector('.tj-promises-bar');
    const productsSection = document.getElementById('tj-products-section');
    const categoriesDirSection = document.getElementById('tj-categories-directory-section');
    
    const reelsSec = document.getElementById('tj-reels-section');

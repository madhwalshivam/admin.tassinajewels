  function updateScrollDots(containerId, dotsId) {
    const container = document.getElementById(containerId);
    const dotsContainer = document.getElementById(dotsId);
    if (!container || !dotsContainer) return;
    
    const setupDots = () => {
      if (container.children.length === 0) return;
      const totalItems = container.children.length;
      const cardWidth = container.children[0].clientWidth || 200;
      const itemsPerPage = Math.max(1, Math.floor(container.clientWidth / cardWidth));
      const dotsCount = Math.max(1, Math.ceil(totalItems / itemsPerPage));
      
      dotsContainer.innerHTML = '';
      for (let i = 0; i < dotsCount; i++) {
        const dot = document.createElement('div');
        dot.className = 'tj-deal-dot' + (i === 0 ? ' active' : '');
        dot.onclick = () => {
          container.scrollTo({
            left: i * itemsPerPage * cardWidth,
            behavior: 'smooth'
          });
        };
        dotsContainer.appendChild(dot);
      }
    };
    
    setupDots();
    window.addEventListener('resize', setupDots);
    
    container.addEventListener('scroll', () => {
      if (container.children.length === 0) return;
      const cardWidth = container.children[0].clientWidth || 200;
      const itemsPerPage = Math.max(1, Math.floor(container.clientWidth / cardWidth));
      const activeIdx = Math.round(container.scrollLeft / (itemsPerPage * cardWidth));
      const dots = dotsContainer.children;
      for (let i = 0; i < dots.length; i++) {
        if (i === activeIdx) {
          dots[i].classList.add('active');
        } else {
          dots[i].classList.remove('active');
        }
      }
    });
  }


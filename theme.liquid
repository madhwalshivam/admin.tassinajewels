  // ─── INIT POLLING FOR SUPABASE READY ──────────────────────

  // Run a required loader with retries. `checkOk` verifies the data actually loaded
  // (loaders swallow their own errors, so we confirm the result was populated).
  async function tjRunRequired(fn, name, checkOk, retries) {
    retries = (typeof retries === 'number') ? retries : 2;
    for (var attempt = 0; attempt <= retries; attempt++) {
      try { await fn(); } catch (e) { console.error(name + ' error (attempt ' + (attempt + 1) + ')', e); }
      try { if (!checkOk || checkOk()) return true; } catch (e) {}
      if (attempt < retries) {
        await new Promise(function (r) { setTimeout(r, 700 * (attempt + 1)); });
      }
    }
    return false;
  }

  async function bootStorefront() {
    // Instant, flicker-free first paint from cache: navbar (admin links) + category skeletons.
    try { window.tjRenderNavbar(); } catch (e) {}
    try { renderQuickCategories(); } catch (e) {}

    // Load ALL required backend data. The loader stays up until these are ready.
    // Settings/navbar/footer/hero come from loadSettings; categories from loadFilters;
    // homepage products from loadProducts. Run in parallel with per-loader retries.
    var results = await Promise.all([
      tjRunRequired(loadSettings, 'settings', function () { return !!window.tjStorefrontSettings; }),
      tjRunRequired(loadFilters,  'filters',  function () { return window._tjCategoriesLoaded === true; }),
      tjRunRequired(loadProducts, 'products', function () { return window._tjProductsReady === true || Array.isArray(_cachedProducts); })
    ]);

    window._tjSettingsLoaded = true;

    // Refresh Category deals with settings loaded
    try { refreshShopByCategory(); } catch (e) {}

    // Final, consistent render now that data is available (uses caches, no refetch).
    try { window.tjRenderNavbar(); } catch (e) {}
    try { window.renderPageViews(); } catch (e) {}
    if (typeof renderSidebarFilters === 'function') { try { renderSidebarFilters(); } catch (e) {} }
    try { loadReviews(); } catch (e) {}

    // Products are the only genuinely blocking requirement. Settings and category
    // filters degrade gracefully (defaults + cached navbar), so a hiccup on either
    // must NOT hand the shopper a dead "check your connection" screen while a
    // perfectly good catalog sits in cache.
    var settingsOk = results[0], filtersOk = results[1], productsOk = results[2];
    var haveProducts = (Array.isArray(allProducts) && allProducts.length > 0) ||
                       (Array.isArray(_cachedProducts) && _cachedProducts.length > 0);

    if (haveProducts) {
      if (!settingsOk || !filtersOk) {
        console.warn('[TJ] Booted with partial data — settings:', settingsOk, 'filters:', filtersOk);
      }
      if (typeof window.hidePreloader === 'function') window.hidePreloader();
      // Quietly keep trying for whatever missed, so the page self-heals.
      if (!settingsOk) { tjRunRequired(loadSettings, 'settings-late', function () { return !!window.tjStorefrontSettings; }, 3).then(function (ok) { if (ok) { try { window.tjRenderNavbar(); } catch (e) {} try { refreshShopByCategory(); } catch (e) {} } }); }
      if (!filtersOk)  { tjRunRequired(loadFilters, 'filters-late', function () { return window._tjCategoriesLoaded === true; }, 3).then(function (ok) { if (ok) { try { renderQuickCategories(); } catch (e) {} try { window.tjRenderNavbar(); } catch (e) {} } }); }
      return;
    }

    // Nothing to render at all → honest error with a working Retry.
    console.warn('Required data failed to load after retries:', results);
    if (typeof window.tjShowLoadError === 'function') {
      window.tjShowLoadError(productsOk
        ? 'No products are available right now. Please try again in a moment.'
        : "We couldn't load the catalog. Check your connection and try again.");
    }
  }

  // Wait for the Supabase client to exist, but never wait forever. If every CDN
  // and the REST fallback are unreachable we surface an actionable error instead
  // of spinning until the safety timer fires.
  function tjWaitForSupabase(timeoutMs) {
    timeoutMs = timeoutMs || 15000;
    return new Promise(function (resolve) {
      if (initSupabase()) return resolve(true);
      var started = Date.now();
      var interval = setInterval(function () {
        if (initSupabase()) { clearInterval(interval); return resolve(true); }
        if (Date.now() - started > timeoutMs) {
          clearInterval(interval);
          // Last resort: force the built-in REST client and try once more.
          if (typeof window._tjInstallRestFallback === 'function' && !window._tjRestForced) {
            window._tjRestForced = true;
            try { window._tjInstallRestFallback(); } catch (e) {}
            if (initSupabase()) return resolve(true);
          }
          resolve(false);
        }
      }, 100);
    });
  }

  window.tjStartBoot = async function () {
    var ready = await tjWaitForSupabase(15000);
    if (!ready) {
      if (typeof window.tjShowLoadError === 'function') {
        window.tjShowLoadError('Could not reach our catalog service. This often happens inside in-app browsers — try opening the store in Chrome or Safari.');
      }
      return;
    }
    await bootStorefront();
  };

  // Retry without a full page reload: reset the caches that gate the loader and
  // run the boot sequence again. Falling back to reload() would just repeat the
  // same failing path (and lose the REST fallback we may already have installed).
  window.tjRetryBoot = async function () {
    var btn = document.getElementById('tj-preloader-retry-btn');
    if (btn) { btn.disabled = true; btn.textContent = 'Retrying…'; btn.style.opacity = '0.6'; }
    if (typeof window.tjResetLoadError === 'function') window.tjResetLoadError();
    window._tjCategoriesLoaded = false;
    window._tjProductsReady = false;
    window._tjBootAttempt = (window._tjBootAttempt || 0) + 1;
    // On the second failure, force the REST fallback — the CDN clearly isn't coming.
    if (window._tjBootAttempt >= 2 && typeof window._tjInstallRestFallback === 'function' && !window._tjRestForced) {
      window._tjRestForced = true;
      try { window._tjInstallRestFallback(); db = null; initSupabase(); } catch (e) {}
    }
    await window.tjStartBoot();
  };

  window.addEventListener('DOMContentLoaded', function () { window.tjStartBoot(); });


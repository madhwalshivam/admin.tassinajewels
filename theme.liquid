      const password = document.getElementById('tj-login-password').value;

      const { data, error } = await db.auth.signInWithPassword({ email, password });

      if (error) {
        showAuthMessage(error.message, 'error');
        setAuthLoading('tj-btn-login-submit', false, 'Login to Account');

  window.toggleDealWishlist = function(pid, btn) {
    const isWl = localStorage.getItem('tj_wl_' + pid) === '1';
    if (isWl) {
      localStorage.removeItem('tj_wl_' + pid);
      btn.querySelector('svg').setAttribute('fill','none');
      btn.querySelector('svg').setAttribute('stroke','currentColor');
    } else {
      localStorage.setItem('tj_wl_' + pid, '1');
      btn.querySelector('svg').setAttribute('fill','#e63946');
      btn.querySelector('svg').setAttribute('stroke','#e63946');
    }
    updateWishlistCount();
  };



  function updateScrollDots(containerId, dotsId) {
    const container = document.getElementById(containerId);
    const dotsContainer = document.getElementById(dotsId);
    if (!container || !dotsContainer) return;
    
    const setupDots = () => {
      if (container.children.length === 0) return;
      const totalItems = container.children.length;
      const cardWidth = container.children[0].clientWidth || 200;
      const itemsPerPage = Math.max(1, Math.floor(container.clientWidth / cardWidth));
      const dotsCount = Math.max(1, Math.ceil(totalItems / itemsPerPage));
      
      dotsContainer.innerHTML = '';
      for (let i = 0; i < dotsCount; i++) {
        const dot = document.createElement('div');
        dot.className = 'tj-deal-dot' + (i === 0 ? ' active' : '');
        dot.onclick = () => {
          container.scrollTo({
            left: i * itemsPerPage * cardWidth,
            behavior: 'smooth'
          });
        };
        dotsContainer.appendChild(dot);
      }
    };
    
    setupDots();
    window.addEventListener('resize', setupDots);
    
    container.addEventListener('scroll', () => {
      if (container.children.length === 0) return;
      const cardWidth = container.children[0].clientWidth || 200;
      const itemsPerPage = Math.max(1, Math.floor(container.clientWidth / cardWidth));
      const activeIdx = Math.round(container.scrollLeft / (itemsPerPage * cardWidth));
      const dots = dotsContainer.children;
      for (let i = 0; i < dots.length; i++) {
        if (i === activeIdx) {
          dots[i].classList.add('active');
        } else {
          dots[i].classList.remove('active');
        }
      }
    });
  }

  // Get premium fallback product lifestyle image based on keywords
  function getProductFallbackImage(p) {
    if (!p) return 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?q=80&w=600&auto=format&fit=cover';
    const title = (p.title || '').toLowerCase();
    const cat = (p.category || '').toLowerCase();
    if (title.includes('ring') || cat.includes('ring')) {
      return 'https://images.unsplash.com/photo-1605100804763-247f67b3557e?q=80&w=600&auto=format&fit=cover';
    }
    if (title.includes('neck') || cat.includes('neck') || title.includes('pend') || cat.includes('pend')) {
      return 'https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?q=80&w=600&auto=format&fit=cover';
    }
    if (title.includes('bracelet') || cat.includes('bracelet') || title.includes('bangle') || cat.includes('bangle')) {
      return 'https://images.unsplash.com/photo-1611591437281-460bfbe1220a?q=80&w=600&auto=format&fit=cover';
    }
    if (title.includes('ear') || cat.includes('ear') || title.includes('stud') || cat.includes('stud')) {
      return 'https://images.unsplash.com/photo-1635767798638-3e25273a8236?q=80&w=600&auto=format&fit=cover';
    }
    return 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?q=80&w=600&auto=format&fit=cover';
  }


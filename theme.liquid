        <!-- Category Filters Dropdown -->
        <div class="tj-filters-dropdown-container">
          <label for="tj-category-select" style="font-size: 9px; font-weight: 600; color: var(--gold-dark); text-transform: uppercase; letter-spacing: 2px; display: block; margin-bottom: 6px;">Select Collection</label>
          <div class="tj-select-wrapper">
            <select class="tj-category-select" id="tj-category-select" onchange="filterByCategory(this.value)">
              <option value="all">All Collections</option>
            </select>
            <div class="tj-select-arrow">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </div>
        </div>

        <!-- Info & Sort Bar -->
        <div id="tj-catalog-info-bar" style="display: flex; justify-content: space-between; align-items: center; max-width: 1280px; margin: 20px auto 20px; padding: 0 16px; flex-wrap: wrap; gap: 12px;">
          <div style="font-size: 11px; font-weight: 700; color: #1B4332; text-transform: uppercase; letter-spacing: 1.5px;" id="tj-product-count-label">
            Loading products...
          </div>
          <div style="display: flex; gap: 10px; align-items: center;">
            <button class="tj-filter-drawer-toggle" id="tj-filter-drawer-toggle" onclick="toggleFilterDrawer()" style="display: inline-flex; padding: 8px 16px; font-size: 11px; font-weight: 600; color: #1B4332; border: 1px solid #eae6e0; border-radius: 8px; background: #ffffff; cursor: pointer; align-items: center; gap: 8px; font-family: var(--font-sans);">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 6h16M7 12h10M10 18h4"/></svg>
              Filters
            </button>
            <div class="tj-sort-wrapper" style="position: relative;">
              <select id="tj-sort-select" onchange="handleSortChange(this.value)" style="appearance: none; -webkit-appearance: none; background: #ffffff; border: 1px solid #eae6e0; border-radius: 8px; padding: 8px 30px 8px 12px; font-size: 11px; color: #1B4332; font-weight: 600; outline: none; cursor: pointer; min-width: 150px; font-family: var(--font-sans);">
                <option value="default">Sort by: Default</option>
                <option value="price_asc">Price: Low to High</option>
                <option value="price_desc">Price: High to Low</option>
              </select>
              <div style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); pointer-events: none; color: #1B4332; display: flex; align-items: center;">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Subcategory Filters (dynamic) -->

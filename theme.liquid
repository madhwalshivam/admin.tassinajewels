                <div class="tj-drawer-row">
                  <a href="#tj-products-section" onclick="toggleMobileMenu(); navigateToCategory('${cat.slug}')">${cat.name}</a>
                  <button class="tj-drawer-toggle-btn" onclick="toggleMobileSubmenu(event, this)">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
                  </button>
                </div>
                <div class="tj-drawer-submenu">
                  ${cat.subcategories.map(sub => `
                    <a href="#tj-products-section" onclick="toggleMobileMenu(); navigateToCategory('${sub.slug}')">${sub.name}</a>
                  `).join('')}
                </div>
              </div>
            `;
          } else {
            return `<a href="#tj-products-section" onclick="toggleMobileMenu(); navigateToCategory('${cat.slug}')">${cat.name}</a>`;
          }
        }).join('') + `
        <a href="javascript:void(0)" onclick="toggleMobileMenu(); handleAccountNav()">Login</a>
      `;
    }
  };

  // Loading state for the navbar — shows subtle skeletons, NEVER categories.
  window.tjRenderNavbarLoading = function() {
    const navLinks = document.querySelector('.tj-nav-links');
    if (navLinks && !navLinks.dataset.tjReady) {
      navLinks.innerHTML =
        '<span class="tj-nav-skeleton"></span><span class="tj-nav-skeleton"></span><span class="tj-nav-skeleton"></span><span class="tj-nav-skeleton"></span>';
    }
    const drawerLinks = document.querySelector('.tj-drawer-links');
    if (drawerLinks && !drawerLinks.dataset.tjReady) {
      drawerLinks.innerHTML = '<a href="javascript:void(0)" onclick="toggleMobileMenu(); handleAccountNav()">Login</a>';
    }
  };

  // Builds + renders the navbar STRICTLY from the Admin Panel's Navbar Links
  // (navbar_menu storefront setting). Never uses product categories, and never
  // falls back to them. Cached for instant paint; re-renders only when changed.
  window.tjRenderNavbar = function() {
    const sMap = window.tjStorefrontSettings || {};
    let raw = sMap.navbar_menu || null;
    if (!raw) { try { raw = localStorage.getItem('tj_navbar_menu_v1'); } catch (_e) {} }

    // No navbar links available yet.
    if (!raw) {
      if (window._tjSettingsLoaded) {
        // Settings finished loading and no navbar links are configured →
        // render a clean, empty navbar (NEVER product categories).
        renderNavigation([]);
        const nl = document.querySelector('.tj-nav-links'); if (nl) nl.dataset.tjReady = '1';
        const dl = document.querySelector('.tj-drawer-links'); if (dl) dl.dataset.tjReady = '1';
      } else {
        // Still loading → loading state (never categories).
        window.tjRenderNavbarLoading();
      }
      return;
    }

    // Avoid unnecessary re-renders / flicker.
    if (raw === window._tjNavbarRenderedRaw) return;

    let links = [];
    try {
      const parsed = JSON.parse(raw);
      if (Array.isArray(parsed)) {
        links = parsed
          .filter(item => item && item.visible !== false)
          .map(item => ({
            id: item.id || item.slug,
            name: item.name,
            slug: item.slug,
            subcategories: (item.subcategories || [])
              .filter(sub => sub && sub.visible !== false)
              .map(sub => ({ id: sub.id || sub.slug, name: sub.name, slug: sub.slug }))
          }));
      }
    } catch (e) {
      console.error('navbar_menu parse error', e);
      links = [];
    }

    navigationTree = links; // navbar reflects admin links only
    renderNavigation(links);
    window._tjNavbarRenderedRaw = raw;

    const navLinks = document.querySelector('.tj-nav-links');
    if (navLinks) navLinks.dataset.tjReady = '1';
    const drawerLinks = document.querySelector('.tj-drawer-links');
    if (drawerLinks) drawerLinks.dataset.tjReady = '1';
  };

  window.toggleMobileSubmenu = function(e, btn) {
    e.stopPropagation();
    const item = btn.closest('.tj-drawer-item');
    if (!item) return;
    const submenu = item.querySelector('.tj-drawer-submenu');
    if (!submenu) return;
    const isOpen = submenu.style.display === 'flex';
    submenu.style.display = isOpen ? 'none' : 'flex';
    btn.classList.toggle('open', !isOpen);
  };

  window.renderSidebarFilters = function() {
    const sidebar = document.getElementById('tj-catalog-sidebar');
    if (!sidebar) return;

    // Build sidebar HTML starting with mobile header
    let html = `
      <div class="tj-sidebar-mobile-header" style="display: none; justify-content: space-between; align-items: center; padding-bottom: 16px; margin-bottom: 16px; border-bottom: 1px solid rgba(27,67,50,0.1);">
        <h3 style="font-size: 14px; font-weight: 700; color: var(--green); text-transform: uppercase; letter-spacing: 1px; margin: 0;">Filters</h3>
        <button class="tj-drawer-close" onclick="toggleFilterDrawer()" style="background: none; border: none; font-size: 18px; color: var(--green); cursor: pointer; padding: 4px;">✕</button>
      </div>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
        <span style="font-size: 10px; font-weight: 700; color: var(--green); text-transform: uppercase; letter-spacing: 1px;">Active Filters</span>
        <button onclick="clearAllFilters()" style="background: none; border: none; font-size: 10px; font-weight: 600; color: var(--gold); cursor: pointer; text-transform: uppercase; letter-spacing: 0.5px; padding: 0;">Clear All</button>
      </div>
    `;

    // 1. Availability Filter Section
    html += `
      <div class="tj-filter-section">
        <button class="tj-filter-section-header" onclick="toggleFilterSection(event, this)">
          Availability
          <svg class="tj-caret-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="tj-filter-section-content">
          <label style="display: flex; align-items: center; gap: 8px; font-size: 12px; color: #4a5568; cursor: pointer; font-family: var(--font-sans);">
            <input type="radio" name="availability" value="all" ${activeFilters.availability === 'all' ? 'checked' : ''} onchange="handleAvailabilityChange(this.value)" style="accent-color: var(--green); cursor: pointer;">
            All Products
          </label>
          <label style="display: flex; align-items: center; gap: 8px; font-size: 12px; color: #4a5568; cursor: pointer; font-family: var(--font-sans);">
            <input type="radio" name="availability" value="in-stock" ${activeFilters.availability === 'in-stock' ? 'checked' : ''} onchange="handleAvailabilityChange(this.value)" style="accent-color: var(--green); cursor: pointer;">
            In Stock
          </label>
        </div>
      </div>
    `;

    // 2. Price Range Filter Section
    html += `
      <div class="tj-filter-section">
        <button class="tj-filter-section-header" onclick="toggleFilterSection(event, this)">
          Price Range
          <svg class="tj-caret-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="tj-filter-section-content" style="display: flex; flex-direction: column; gap: 8px;">
          <div style="display: flex; gap: 8px; align-items: center;">
            <input type="number" placeholder="Min" value="${activeFilters.priceMin || ''}" onchange="handlePriceFilterChange('priceMin', this.value)" style="width: 100%; padding: 6px 10px; font-size: 12px; border: 1px solid #eae6e0; border-radius: 6px; outline: none; font-family: var(--font-sans);">
            <span style="font-size: 12px; color: #aaa;">to</span>
            <input type="number" placeholder="Max" value="${activeFilters.priceMax || ''}" onchange="handlePriceFilterChange('priceMax', this.value)" style="width: 100%; padding: 6px 10px; font-size: 12px; border: 1px solid #eae6e0; border-radius: 6px; outline: none; font-family: var(--font-sans);">
          </div>
        </div>
      </div>
    `;

    // 3. Subcategories Filter Section
    const currentCatObj = navigationTree.find(c => c.slug === currentCategory);
    if (currentCatObj && currentCatObj.subcategories && currentCatObj.subcategories.length > 0) {
      html += `
        <div class="tj-filter-section">
          <button class="tj-filter-section-header" onclick="toggleFilterSection(event, this)">
            Subcategory
            <svg class="tj-caret-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="tj-filter-section-content">
            ${currentCatObj.subcategories.map(sub => {
              const isChecked = activeFilters.subcategories.includes(sub.slug) || activeFilters.subcategories.includes(sub.id);
              const val = sub.id || sub.slug;
              return `
                <label style="display: flex; align-items: center; gap: 8px; font-size: 12px; color: #4a5568; cursor: pointer; font-family: var(--font-sans);">
                  <input type="checkbox" value="${val}" ${isChecked ? 'checked' : ''} onchange="handleFilterChange('subcategories', '${val}', this.checked)" style="accent-color: var(--green); cursor: pointer;">
                  ${sub.name}
                </label>
              `;
            }).join('')}
          </div>
        </div>
      `;
    }

    // 4. Dynamic Custom Attributes Filter Groups (Plating, Color, Material, Gender, Stone Type)
    const activeProducts = allProducts.filter(p => isProductInCategory(p, currentCategory));

    const filterKeys = [
      { key: 'gender', name: 'Gender' },
      { key: 'plating', name: 'Plating' },
      { key: 'material', name: 'Material' },
      { key: 'color', name: 'Color' },
      { key: 'stone-type', name: 'Stone Type' }
    ];

    filterKeys.forEach(fKey => {
      let options = new Set();
      
      if (allProductFilterValues && allProductFilterValues.length > 0) {
        activeProducts.forEach(p => {
          allProductFilterValues.forEach(pfv => {
            if (pfv.product_id === p.id) {
              const fv = allFilterValues.find(v => v.id === pfv.filter_value_id);
              if (fv) {
                const group = allFilterGroups.find(g => g.id === fv.filter_group_id);
                if (group && group.slug === fKey.key) {
                  options.add(fv.value);
                }
              }
            }
          });
        });
      }
      
      if (options.size === 0) {
        const fallbackOptionMap = {
          gender: ["Men", "Women", "Unisex"],
          plating: ["18K Gold", "Plated", "Silver Plated", "Rose Gold"],
          material: ["Stainless Steel", "Sterling Silver", "Copper", "Natural Stone", "Brass", "Zircon"],
          color: ["Gold", "Silver", "Rose Gold", "Black", "Green", "Blue", "Red", "White"],
          'stone-type': ["Zircon", "Agate", "Tiger Eye", "Obsidian", "Opal", "Turquoise", "Quartz", "Amethyst", "Lapis Lazuli", "Malachite", "Jade"]
        };
        
        const possibleOptions = fallbackOptionMap[fKey.key] || [];
        possibleOptions.forEach(opt => {
          const normOpt = opt.toLowerCase();
          const matches = activeProducts.some(p => {
            const text = `${p.title} ${p.description} ${p.material || ''}`.toLowerCase();
            return text.includes(normOpt);
          });
          if (matches) {
            options.add(opt);
          }
        });
      }

      if (options.size > 0) {
        html += `
          <div class="tj-filter-section">
            <button class="tj-filter-section-header" onclick="toggleFilterSection(event, this)">
              ${fKey.name}
              <svg class="tj-caret-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="tj-filter-section-content">
              ${Array.from(options).map(opt => {
                const isChecked = (activeFilters[fKey.key] || []).includes(opt);
                return `
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 12px; color: #4a5568; cursor: pointer; font-family: var(--font-sans);">
                    <input type="checkbox" value="${opt}" ${isChecked ? 'checked' : ''} onchange="handleFilterChange('${fKey.key}', '${opt}', this.checked)" style="accent-color: var(--green); cursor: pointer;">
                    ${opt}
                  </label>
                `;
              }).join('')}
            </div>
          </div>
        `;
      }
    });

    sidebar.innerHTML = html;
  };

  window.toggleFilterSection = function(e, btn) {
    btn.classList.toggle('collapsed');
  };

  // Inject filter-modal styles once
  window.tjEnsureFilterModalStyles = function() {
    if (document.getElementById('tj-fm-style')) return;
    const s = document.createElement('style');
    s.id = 'tj-fm-style';
    s.textContent = `
      #tj-filter-modal{position:fixed;inset:0;z-index:100050;}
      #tj-filter-modal .tj-fm-overlay{position:absolute;inset:0;background:rgba(15,30,22,.5);animation:tjFmFade .25s ease both;}
      #tj-filter-modal.closing .tj-fm-overlay{opacity:0;transition:opacity .22s ease;animation:none;}
      #tj-filter-modal .tj-fm-sheet{position:absolute;left:0;right:0;bottom:0;background:#fff;border-radius:20px 20px 0 0;max-height:88vh;display:flex;flex-direction:column;box-shadow:0 -8px 40px rgba(0,0,0,.2);animation:tjFmUp .3s cubic-bezier(.16,1,.3,1) both;}
      #tj-filter-modal.closing .tj-fm-sheet{transform:translateY(100%);transition:transform .24s ease;animation:none;}
      #tj-filter-modal .tj-fm-grabber{width:40px;height:4px;border-radius:99px;background:#d8d2c8;margin:10px auto 2px;flex-shrink:0;}
      #tj-filter-modal .tj-fm-head{display:flex;align-items:center;justify-content:space-between;padding:8px 20px 12px;border-bottom:1px solid rgba(27,67,50,.08);flex-shrink:0;}
      #tj-filter-modal .tj-fm-title{font-family:var(--font-serif);font-size:17px;color:var(--green);letter-spacing:.5px;}
      #tj-filter-modal .tj-fm-x{background:#f4f1ec;border:none;width:30px;height:30px;border-radius:50%;font-size:13px;color:var(--green);cursor:pointer;display:flex;align-items:center;justify-content:center;}
      #tj-filter-modal .tj-fm-body{padding:4px 20px 16px;overflow-y:auto;flex:1;-webkit-overflow-scrolling:touch;}
      #tj-filter-modal .tj-fm-body .tj-sidebar-mobile-header{display:none !important;}
      #tj-filter-modal .tj-fm-foot{display:flex;gap:12px;padding:14px 20px calc(14px + env(safe-area-inset-bottom));border-top:1px solid rgba(27,67,50,.08);background:#fff;flex-shrink:0;}
      #tj-filter-modal .tj-fm-clear{flex:1;padding:13px;border:1px solid var(--green);background:#fff;color:var(--green);border-radius:12px;font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:1px;cursor:pointer;font-family:var(--font-sans);}
      #tj-filter-modal .tj-fm-apply{flex:2;padding:13px;border:none;background:var(--green);color:var(--gold);border-radius:12px;font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:1px;cursor:pointer;font-family:var(--font-sans);}
      @keyframes tjFmFade{from{opacity:0}to{opacity:1}}
      @keyframes tjFmUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
      @keyframes tjFmPop{from{opacity:0;transform:translate(-50%,-46%)}to{opacity:1;transform:translate(-50%,-50%)}}
      @media(min-width:769px){
        #tj-filter-modal .tj-fm-sheet{left:50%;top:50%;right:auto;bottom:auto;transform:translate(-50%,-50%);width:400px;max-height:82vh;border-radius:16px;animation:tjFmPop .25s ease both;}
        #tj-filter-modal.closing .tj-fm-sheet{transform:translate(-50%,-46%);opacity:0;transition:all .2s ease;animation:none;}
        #tj-filter-modal .tj-fm-grabber{display:none;}

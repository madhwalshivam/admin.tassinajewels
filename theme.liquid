      list.innerHTML = '<p style="color:#666;font-size:12px;text-align:center;grid-column:span 4;padding:20px;">No categories found.</p>';
    }
    
    drawer.style.display = 'block';
    if (overlay) overlay.style.display = 'block';
    
    // Force reflow
    drawer.offsetHeight;
    if (overlay) overlay.offsetHeight;
    
    drawer.style.transform = 'translateY(0)';
    if (overlay) overlay.style.opacity = '1';
    document.body.style.overflow = 'hidden';
  };

  window.closeCategoriesDrawer = function() {
    const drawer = document.getElementById('tj-cat-drawer');
    const overlay = document.getElementById('tj-cat-drawer-overlay');
    if (drawer) drawer.style.transform = 'translateY(100%)';
    if (overlay) overlay.style.opacity = '0';
    document.body.style.overflow = '';
    
    setTimeout(() => {
      if (drawer && drawer.style.transform === 'translateY(100%)') {
        drawer.style.display = 'none';
      }
      if (overlay && overlay.style.opacity === '0') {
        overlay.style.display = 'none';
      }
    }, 300);
  };

  window.toggleMobileMenu = function() {
    const drawer = document.getElementById('tj-mobile-drawer');
    if (!drawer) return;
    drawer.classList.toggle('open');
    if (drawer.classList.contains('open')) {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = '';
    }
  };

  window.copyWeChatId = function() {
    const wechatId = '15986738500';
    navigator.clipboard.writeText(wechatId).then(() => {
      showToast(`WeChat ID "${wechatId}" copied!`);
    }).catch(() => {
      showToast(`WeChat ID: ${wechatId}`);
    });

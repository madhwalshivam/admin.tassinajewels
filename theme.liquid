  window.submitReview = async function(e) {
    e.preventDefault();
    const name = document.getElementById('review-name').value.trim();
    const rating = parseInt(document.getElementById('review-rating-value').value);
    const comment = document.getElementById('review-comment').value.trim();
    
    const submitBtn = document.getElementById('tj-review-submit-btn');
    if (submitBtn) {
      submitBtn.setAttribute('disabled', 'true');
      submitBtn.textContent = 'Submitting...';
    }
    
    const reviewData = { name, rating, comment, approved: true, created_at: new Date().toISOString() };
    
    try {
      if (db) {
        const { error } = await db.from('reviews').insert([reviewData]);
        if (error) {
          console.error("Supabase insert review failed, falling back to local storage:", error.message);
        }
      }
      
      let localReviews = JSON.parse(localStorage.getItem('tj_local_reviews') || '[]');
      localReviews.push(reviewData);
      localStorage.setItem('tj_local_reviews', JSON.stringify(localReviews));
      
      appendReviewToSlider(reviewData);
      
      document.getElementById('tj-review-form-content').style.display = 'none';
      document.getElementById('tj-review-success-content').style.display = 'block';
    } catch (err) {
      console.error("Error submitting review:", err);
      document.getElementById('tj-review-form-content').style.display = 'none';
      document.getElementById('tj-review-success-content').style.display = 'block';
    } finally {
      if (submitBtn) {
        submitBtn.removeAttribute('disabled');
        submitBtn.textContent = 'Submit Review';
      }
    }
  };


    overflow: hidden;
    font-family: var(--font-sans);
    margin: 3px 0 4px;
  }
  .tj-deal-card-price-row {
    display: flex;
    align-items: baseline;
    gap: 5px;
    margin-top: auto;
  }
  .tj-deal-card-price {
    font-size: 13px;
    font-weight: 800;
    color: #1B4332;
    font-family: var(--font-sans);
  }
  .tj-deal-card-compare {

            </div>
          </div>
          <button onclick="document.getElementById('tj-account-drawer').remove();document.body.style.overflow='';selectBottomNav('nav-home');" style="position:absolute;top:20px;right:20px;background:rgba(255,255,255,0.1);border:none;border-radius:50%;width:32px;height:32px;cursor:pointer;color:#fff;font-size:16px;display:flex;align-items:center;justify-content:center;">✕</button>
        </div>

        <!-- Dashboard Tab Bar -->
        <div style="display:flex;background:#f9f8f6;border-bottom:1px solid #f0ede8;flex-shrink:0;">
          <div onclick="switchDashTab('inquiries')" id="dash-tab-inquiries" class="dash-tab active" style="flex:1;text-align:center;padding:12px 6px;font-size:11px;text-transform:uppercase;letter-spacing:1px;font-weight:600;color:#1B4332;cursor:pointer;border-bottom:2px solid #E3BA45;">Inquiries (${userInquiries.length})</div>
          <div onclick="switchDashTab('wishlist')" id="dash-tab-wishlist" class="dash-tab" style="flex:1;text-align:center;padding:12px 6px;font-size:11px;text-transform:uppercase;letter-spacing:1px;font-weight:600;color:#666;cursor:pointer;border-bottom:2px solid transparent;">Wishlist (${wishlisted.length})</div>
          <div onclick="switchDashTab('profile')" id="dash-tab-profile" class="dash-tab" style="flex:1;text-align:center;padding:12px 6px;font-size:11px;text-transform:uppercase;letter-spacing:1px;font-weight:600;color:#666;cursor:pointer;border-bottom:2px solid transparent;">Profile</div>
        </div>

        <div style="flex:1;overflow-y:auto;padding:16px;">
          <!-- INQUIRIES VIEW -->
          <div id="dash-view-inquiries" class="dash-view active" style="display:block;">
            ${userInquiries.length === 0 ? `
              <div style="text-align:center;padding:50px 20px;">
                <svg style="width:48px;height:48px;color:#ccc;margin:0 auto 12px;display:block;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" /></svg>
                <p style="font-size:13px;color:#888;">No inquiries logged.</p>
                <p style="font-size:11px;color:#bbb;margin-top:4px;">Request quotes directly on any product page.</p>
                <button onclick="document.getElementById('tj-account-drawer').remove();document.body.style.overflow='';const s=document.getElementById('tj-products-section');if(s)s.scrollIntoView({behavior:'smooth'});" style="margin-top:16px;background:#1B4332;color:#E3BA45;border:none;padding:8px 16px;font-size:10px;text-transform:uppercase;letter-spacing:1px;border-radius:6px;font-weight:600;cursor:pointer;">Browse Catalog</button>
              </div>
            ` : userInquiries.map(inq => {
              const statusColors = {
                'pending': { bg: '#fff8e1', text: '#b78103', label: 'Pending Review' },
                'processing': { bg: '#e3f2fd', text: '#0d47a1', label: 'Processing' },
                'completed': { bg: '#e8f5e9', text: '#1b5e20', label: 'Completed' }
              };
              const st = statusColors[inq.status] || { bg: '#f5f5f5', text: '#616161', label: inq.status || 'Received' };
              const dateStr = inq.created_at ? new Date(inq.created_at).toLocaleDateString(undefined, {month:'short', day:'numeric', year:'numeric'}) : 'Recently';
              
              return `
                <div style="border:1px solid #f0ede8;border-radius:12px;padding:14px;margin-bottom:12px;background:#fff;">
                  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;">
                    <div>
                      <div style="font-size:13px;font-weight:600;color:#1B4332;">${inq.product_title}</div>
                      <div style="font-size:10px;color:#888;margin-top:2px;">Logged: ${dateStr}</div>
                    </div>
                    <span style="background:${st.bg};color:${st.text};font-size:9px;font-weight:700;text-transform:uppercase;padding:4px 8px;border-radius:6px;letter-spacing:0.5px;">${st.label}</span>
                  </div>
                  <div style="font-size:11px;color:#555;margin-top:6px;line-height:1.4;background:#f9f8f6;padding:8px 10px;border-radius:6px;border-left:2px solid #E3BA45;">
                    <strong>Qty Requested:</strong> ${inq.quantity || 1} pcs<br>
                    <strong>Message:</strong> "${inq.message || 'No additional message.'}"
                  </div>
                </div>
              `;
            }).join('')}
          </div>

          <!-- WISHLIST VIEW -->
          <div id="dash-view-wishlist" class="dash-view" style="display:none;">
            ${wishlisted.length === 0 ? `
              <div style="text-align:center;padding:50px 20px;">
                <svg style="width:48px;height:48px;color:#ccc;margin:0 auto 12px;display:block;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
                <p style="font-size:13px;color:#888;">Your wishlist is empty.</p>
              </div>
            ` : wishlisted.map(p => {
              const img = p.image_url ? formatImageUrl(p.image_url) : getProductFallbackImage(p);
              const globalIdx = allProducts.findIndex(ap => ap.id === p.id);
              return `
                <div id="dash-wl-item-${p.id}" style="display:flex;gap:12px;align-items:flex-start;padding:12px;border:1px solid #f0ede8;border-radius:10px;position:relative;margin-bottom:10px;background:#fff;">
                  <img src="${img}" style="width:60px;height:60px;object-fit:cover;border-radius:8px;cursor:pointer;flex-shrink:0;" onclick="document.getElementById('tj-account-drawer').remove();document.body.style.overflow='';openProductDetail(${globalIdx});" alt="${p.title}">
                  <div style="flex:1;min-width:0;">
                    <div style="font-size:12px;color:#1B4332;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer;" onclick="document.getElementById('tj-account-drawer').remove();document.body.style.overflow='';openProductDetail(${globalIdx});">${p.title}</div>
                    <div style="font-size:11px;color:#666;margin-top:2px;">MOQ: ${p.moq || 2} pcs</div>
                    <div style="font-size:13px;color:#1B4332;font-weight:700;margin-top:4px;">$${parseFloat(p.price || 0).toFixed(2)}</div>
                    <button onclick="document.getElementById('tj-account-drawer').remove();document.body.style.overflow='';openProductDetail(${globalIdx});" style="margin-top:8px;background:#1B4332;color:#E3BA45;border:none;padding:6px 12px;font-size:9px;text-transform:uppercase;letter-spacing:1.05px;cursor:pointer;border-radius:5px;font-weight:600;">Book Now</button>
                  </div>
                  <button onclick="removeWishlistItemFromDash('${p.id}')" title="Remove" style="position:absolute;top:10px;right:10px;background:#fee;border:none;border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#e63946;font-size:11px;">✕</button>
                </div>
              `;
            }).join('')}
          </div>

          <!-- PROFILE DETAILS VIEW -->
          <div id="dash-view-profile" class="dash-view" style="display:none;">
            <div style="border:1px solid #f0ede8;border-radius:12px;padding:16px;background:#f9f8f6;margin-bottom:16px;">
              <div style="margin-bottom:12px;">
                <label style="font-size:10px;color:#888;text-transform:uppercase;font-weight:600;letter-spacing:0.5px;">First Name</label>
                <div style="font-size:14px;color:#1B4332;font-weight:500;margin-top:3px;">${meta.first_name || '-'}</div>
              </div>
              <div style="margin-bottom:12px;">
                <label style="font-size:10px;color:#888;text-transform:uppercase;font-weight:600;letter-spacing:0.5px;">Last Name</label>
                <div style="font-size:14px;color:#1B4332;font-weight:500;margin-top:3px;">${meta.last_name || '-'}</div>
              </div>
              <div style="margin-bottom:12px;">
                <label style="font-size:10px;color:#888;text-transform:uppercase;font-weight:600;letter-spacing:0.5px;">Email Address</label>
                <div style="font-size:14px;color:#1B4332;font-weight:500;margin-top:3px;">${user.email}</div>
              </div>
              <div style="margin-bottom:12px;">
                <label style="font-size:10px;color:#888;text-transform:uppercase;font-weight:600;letter-spacing:0.5px;">Phone / WhatsApp</label>
                <div style="font-size:14px;color:#1B4332;font-weight:500;margin-top:3px;">${meta.phone || '-'}</div>
              </div>
              <div>
                <label style="font-size:10px;color:#888;text-transform:uppercase;font-weight:600;letter-spacing:0.5px;">Company Name</label>
                <div style="font-size:14px;color:#1B4332;font-weight:500;margin-top:3px;">${meta.company || '-'}</div>
              </div>
            </div>
            
            <button onclick="signOut()" style="width:100%;padding:12px;background:#fee;border:none;border-radius:10px;color:#c00;font-size:12px;font-weight:600;cursor:pointer;text-transform:uppercase;letter-spacing:1px;transition:all 0.2s;">Sign Out</button>
          </div>
        </div>
      `;
    };

    window.switchDashTab = function(tabName) {
      document.querySelectorAll('.dash-tab').forEach(el => {
        el.style.color = '#666';
        el.style.borderBottomColor = 'transparent';
      });
      document.querySelectorAll('.dash-view').forEach(el => {
        el.style.display = 'none';
      });
      
      const activeTab = document.getElementById('dash-tab-' + tabName);
      if (activeTab) {
        activeTab.style.color = '#1B4332';
        activeTab.style.borderBottomColor = '#E3BA45';
      }
      const activeView = document.getElementById('dash-view-' + tabName);
      if (activeView) {
        activeView.style.display = 'block';
      }
    };

    window.removeWishlistItemFromDash = function(productId) {
      localStorage.removeItem('tj_wl_' + productId);
      document.querySelectorAll(`[id^="wl-btn-${productId}"], [id^="wl-new-${productId}"]`).forEach(b => {
        b.style.background = 'transparent';
        b.style.color = 'var(--green)';
        const svg = b.querySelector('svg');
        if (svg) svg.setAttribute('fill', 'none');
      });
      updateWishlistCount();
      renderDashboard(); // Re-render inside drawer
    };

    renderDashboard();
    overlay.addEventListener('click', e => { if (e.target === overlay) { overlay.remove(); document.body.style.overflow = ''; selectBottomNav('nav-home'); } });
    document.body.appendChild(overlay);
    document.body.style.overflow = 'hidden';
  }

  window.signOut = async function() {
    await db.auth.signOut();
    const d = document.getElementById('tj-account-drawer');
    if (d) d.remove();
    document.body.style.overflow = '';
    selectBottomNav('nav-home');
    showToast('Signed out successfully');
  };

  // ─── PRODUCT DETAIL OVERLAY ───────────────────────────────
  // Navigate to a URL through the client router, falling back to a hard load.
  function tjGoTo(target) {
    if (typeof window.tjIsClientRoutable === 'function' ? window.tjIsClientRoutable() : true) {
      window.history.pushState({}, '', target);
      window.renderPageViews();
      window.scrollTo({ top: 0, behavior: 'instant' in window ? 'instant' : 'auto' });
    } else {
      window.location.href = target;
    }
  }

  // ── In-place variation switcher ─────────────────────────────────────
  // Clicking a variation button updates ALL page fields immediately from the
  // cached variation data — NO navigation, NO URL change, NO page reload.
  // The product URL is always the parent product's own link.
  window.tjSwitchVariant = function(btn) {
    if (!btn) return;
    const vid = btn.getAttribute('data-vid');
    if (!vid) return;

    const p   = window._tjPdpParentProduct;
    const src = window._tjPdpVariationSource || [];
    if (!p) return;

    // Find the clicked variation in the cached source.
    const v = src.find(x => String(x.id) === String(vid)) || null;
    if (!v) return;

    // ── Update active/pressed state on buttons ─────────────────────────
    document.querySelectorAll('#tj-pdp-variants .tj-pdp-variant-badge, #tj-pdp-variants .tj-pdp-variant-tile')
      .forEach(el => {
        const isNow = el.getAttribute('data-vid') === vid;
        el.classList.toggle('active', isNow);
        el.setAttribute('aria-pressed', isNow ? 'true' : 'false');
      });

    window.tjSelectedVariation = v;
    window.tjActiveVariation   = v;

    // ── Price ──────────────────────────────────────────────────────────
    const vPrice = window.tjVariationPrice(v, p);
    const priceEl = document.getElementById('tj-pdp-price');
    if (priceEl) priceEl.textContent = '$' + vPrice.price.toFixed(2);

    const compEl  = document.getElementById('tj-pdp-compare-price');
    const badgeEl = document.getElementById('tj-pdp-discount-badge');
    if (compEl && badgeEl) {
      if (vPrice.compare && vPrice.compare > vPrice.price) {
        compEl.textContent  = '$' + vPrice.compare.toFixed(2);
        compEl.style.display  = 'inline-block';
        badgeEl.textContent = Math.round((1 - vPrice.price / vPrice.compare) * 100) + '% OFF';
        badgeEl.style.display = 'inline-block';
      } else {
        compEl.style.display  = 'none';
        badgeEl.style.display = 'none';
      }
    }

    // ── Title — keep parent title (no variation suffix) ────────────────
    const titleEl = document.getElementById('tj-pdp-title');
    if (titleEl) titleEl.textContent = p.title;

    // ── Description ────────────────────────────────────────────────────
    const vHas  = (key) => v && v[key] !== undefined && v[key] !== null && String(v[key]).trim() !== '';
    const pick  = (key, fb) => vHas(key) ? v[key] : fb;

    const shortEl = document.getElementById('tj-pdp-short-desc');
    if (shortEl) shortEl.textContent = pick('short_description', p.short_description) || '';

    const fullEl = document.getElementById('tj-pdp-full-desc');
    if (fullEl) fullEl.textContent = pick('description', p.description) || '';

    // ── Specs ──────────────────────────────────────────────────────────
    let activeSpecs = {};
    try {
      if (v.specifications) {
        activeSpecs = typeof v.specifications === 'string' ? JSON.parse(v.specifications) : v.specifications;
      }
    } catch (e) {}
    const getSpec = (key, fb) => {
      if (activeSpecs && activeSpecs[key] != null) return activeSpecs[key];
      if (v && v[key] != null && String(v[key]).trim() !== '') return v[key];
      return fb;
    };
    const matEl  = document.getElementById('tj-pdp-material');
    if (matEl) matEl.textContent = getSpec('material', p.material) || getSpec('Material', p.material) || 'Premium Alloy & Plating';
    const wEl    = document.getElementById('tj-pdp-weight');
    if (wEl)   wEl.textContent   = getSpec('weight', p.weight)   || getSpec('Weight',   p.weight)   || 'Standard';
    const moqEl  = document.getElementById('tj-pdp-moq');
    if (moqEl) moqEl.textContent = (getSpec('moq', p.moq) || 2) + ' pieces';
    const tblMat = document.getElementById('tj-pdp-table-material');
    if (tblMat) tblMat.textContent = getSpec('material', p.material) || 'Premium Gold Plated Alloy';
    const tblMoq = document.getElementById('tj-pdp-table-moq');
    if (tblMoq) tblMoq.textContent = (getSpec('moq', p.moq) || 2) + ' Units Minimum';

    // ── Stock ──────────────────────────────────────────────────────────
    const isOut = window.tjVariationOutOfStock(v);
    const stockDot  = document.getElementById('tj-pdp-stock-dot');
    const stockText = document.getElementById('tj-pdp-stock-text');
    if (stockDot && stockText) {
      stockDot.style.background = isOut ? '#E3BA45' : '#0f9d58';
      stockText.textContent = isOut ? 'Made to Order · Lead time applies' : 'In Stock / Wholesale Ready';
      if (stockText.parentElement) stockText.parentElement.style.color = isOut ? '#B7860B' : '#0f9d58';
    }

    // ── SKU ────────────────────────────────────────────────────────────
    const skuWrap = document.getElementById('tj-pdp-sku-wrap');
    const skuEl   = document.getElementById('tj-pdp-sku');
    if (skuWrap && skuEl) {
      const sku = v.sku || p.sku;
      if (sku) { skuEl.textContent = sku; skuWrap.style.display = 'block'; }
      else { skuWrap.style.display = 'none'; }
    }

    // ── Gallery ────────────────────────────────────────────────────────
    // Use variation's own images if it has any; otherwise fall back to parent.
    const varImgs = window.tjUniqueImagesFn
      ? window.tjUniqueImagesFn(window.tjVariationImages(v))
      : (function(list) {
          const seen = new Set(); const out = [];
          (list || []).forEach(u => {
            if (typeof u !== 'string') return;
            const t = u.trim(); if (!t) return;
            const k = formatImageUrl(t) || t;
            if (seen.has(k)) return; seen.add(k); out.push(t);
          });
          return out;
        })(window.tjVariationImages(v));

    const galleryImages = (varImgs && varImgs.length)
      ? varImgs
      : (window._tjPdpParentImages && window._tjPdpParentImages.length
          ? window._tjPdpParentImages
          : [typeof getProductFallbackImage === 'function' ? getProductFallbackImage(p) : '']);

    if (typeof window.tjGalleryGoTo === 'function') {
      window.tjGalleryImages = galleryImages;
      window.tjGalleryIndex  = 0;

      // Update main image
      const mainImg = document.getElementById('tj-pdp-main-image');
      if (mainImg) {
        mainImg.style.transition = 'opacity 0.12s ease';
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = window.tjImgSrc(galleryImages[0], p);
          mainImg.style.opacity = '1';
        }, 100);
      }

      // Rebuild thumbnails
      const thumbWrap = document.getElementById('tj-pdp-thumbnails');
      if (thumbWrap) {
        const n = galleryImages.length;
        if (n <= 1) {
          thumbWrap.innerHTML = '';
        } else {
          thumbWrap.innerHTML = galleryImages.map((src, i) => {
            const fsrc = window.tjImgSrc(src, p);
            return `<img src="${fsrc}" class="tj-pdp-thumb${i === 0 ? ' active' : ''}" data-idx="${i}" onclick="tjGalleryGoTo(${i})" alt="Image ${i+1}" loading="lazy" ${window.tjImgFallbackAttr(p)}>`;
          }).join('');
        }
        const prevBtn = document.getElementById('tj-pdp-prev-btn');
        const nextBtn = document.getElementById('tj-pdp-next-btn');
        const counter = document.getElementById('tj-pdp-img-counter');
        if (prevBtn) prevBtn.style.display = n > 1 ? 'flex' : 'none';
        if (nextBtn) nextBtn.style.display = n > 1 ? 'flex' : 'none';
        if (counter) { counter.textContent = '1 / ' + n; counter.style.display = n > 1 ? 'block' : 'none'; }
      }
    }

    // ── Quotation modal carries the variation ──────────────────────────
    window.tjSelectedVariationLabel = window.tjOptionGroup(v) + ': ' + window.tjOptionLabel(v);
  };

  // (kept for legacy callers — no-op since we switched to in-place updates)
  window.tjSelectVariant = function(event, href) {
    if (event) event.preventDefault();
    return false;
  };


  // Open a catalog entry. A variation entry opens its OWN page via ?variant=,
  // so the URL is shareable and survives refresh (REQ 2).
  window.tjOpenEntry = function(entryId) {
    const e = window.tjFindEntry(entryId);
    if (!e) { showToast('That piece is no longer available.'); return; }
    const parent = allProducts.find(x => String(x.id) === String(e._parentId));
    if (!parent) { showToast('Product not found.'); return; }
    const target = window.tjVariantUrl(parent, e._variation);
    tjGoTo(target);
  };

  // Book straight from a card, carrying the variation through to the quotation.
  window.tjBookEntry = function(entryId) {
    const e = window.tjFindEntry(entryId);
    if (!e) { showToast('That piece is no longer available.'); return; }
    const parent = allProducts.find(x => String(x.id) === String(e._parentId)) || e;
    const label = e._isVariant && e._variation
      ? window.tjOptionGroup(e._variation) + ': ' + window.tjOptionLabel(e._variation)
      : '';
    window.openModal(parent, { price: e.price, variationLabel: label, title: e.title });
  };

  window.openProductDetail = function(index) {
    const p = allProducts[index];
    if (!p) return;
    tjGoTo(window.tjVariantUrl(p, null));
  };

  // ─── B2B QUOTATION MODAL ──────────────────────────────────
  window.tjModalProduct = null;

  // opts (optional) lets a listing card state the variation explicitly instead of
  // relying on whatever the product page happens to have selected.
  window.openModal = function(product, opts) {
    const overlay = document.getElementById('tj-modal');
    if (!overlay) return;
    opts = opts || {};

    window.tjModalProduct = product || null;

    // Reset to the form view — a returning shopper must not land on the
    // success screen from a previous inquiry.
    const formC = document.getElementById('tj-form-content');
    const okC = document.getElementById('tj-success-content');
    if (formC) formC.style.display = 'block';
    if (okC) okC.style.display = 'none';

    const infoBox = document.getElementById('tj-selected-product-info');
    const titleEl = document.getElementById('tj-selected-title');
    const priceEl = document.getElementById('tj-selected-price');
    const varEl = document.getElementById('tj-selected-variation-display');
    const idIn = document.getElementById('tj-product-id');
    const titleIn = document.getElementById('tj-product-title');
    const varIn = document.getElementById('tj-product-variation');

    // An explicit label from a card wins. Otherwise carry the product page's
    // selection, but only when the modal was opened from that same product page —
    // attaching a stale selection to a different product would be worse than none.
    const onSamePdp = product && window.tjCurrentPdpProduct && window.tjCurrentPdpProduct.id === product.id;
    const varLabel = (typeof opts.variationLabel === 'string' && opts.variationLabel)
      ? opts.variationLabel
      : (onSamePdp ? (window.tjSelectedVariationLabel || '') : '');

    if (product) {
      if (infoBox) infoBox.style.display = 'block';
      if (titleEl) titleEl.textContent = opts.title || product.title || 'Selected Piece';

      let shown = parseFloat(product.price || 0);
      if (opts.price !== undefined && opts.price !== null) {
        shown = parseFloat(opts.price);
      } else if (onSamePdp) {
        const live = document.getElementById('tj-pdp-price');
        if (live && live.textContent) shown = parseFloat(live.textContent.replace(/[^0-9.]/g, '')) || shown;
      }
      const moq = product.moq || 2;
      if (priceEl) priceEl.textContent = '$' + shown.toFixed(2) + ' · MOQ ' + moq + ' pcs';

      if (varEl) {
        if (varLabel) { varEl.textContent = varLabel; varEl.style.display = 'block'; }
        else { varEl.style.display = 'none'; varEl.textContent = ''; }
      }
      if (idIn) idIn.value = product.id || '';
      if (titleIn) titleIn.value = opts.title || product.title || '';
      if (varIn) varIn.value = varLabel;

      const qty = overlay.querySelector('[name="quantity"]');
      if (qty) { qty.min = moq; qty.placeholder = 'Min ' + moq; }
    } else {
      // General "Inquire Now" — no product attached.
      if (infoBox) infoBox.style.display = 'none';
      if (idIn) idIn.value = '';
      if (titleIn) titleIn.value = 'General Inquiry';
      if (varIn) varIn.value = '';
      if (varEl) varEl.style.display = 'none';
    }

    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';

    // Prefill from the signed-in account so a buyer never retypes their details.
    try {
      const u = window.currentUser;
      if (u) {
        const em = overlay.querySelector('[name="email"]');
        if (em && !em.value) em.value = u.email || '';
        const nm = overlay.querySelector('[name="name"]');
        const meta = u.user_metadata || {};
        if (nm && !nm.value) nm.value = meta.full_name || meta.name || '';
        const co = overlay.querySelector('[name="company"]');
        if (co && !co.value) co.value = meta.company || '';
      }
    } catch (e) {}

    setTimeout(function () {
      const first = overlay.querySelector('[name="name"]');
      if (first && window.innerWidth > 768) first.focus();
    }, 120);
  };

  window.openModalByIndex = function(index) {
    const p = allProducts[index];
    if (!p) { showToast('That piece is no longer available.'); return; }
    window.openModal(p);
  };

  window.closeModal = function() {
    const overlay = document.getElementById('tj-modal');
    if (!overlay) return;
    overlay.classList.remove('open');
    document.body.style.overflow = '';
    window.tjModalProduct = null;
  };

  // Click the backdrop or press Escape to dismiss.
  (function () {
    const overlay = document.getElementById('tj-modal');
    if (overlay) {
      overlay.addEventListener('click', function (e) {
        if (e.target === overlay) window.closeModal();
      });
    }
    document.addEventListener('keydown', function (e) {
      if (e.key !== 'Escape') return;
      const o = document.getElementById('tj-modal');
      if (o && o.classList.contains('open')) window.closeModal();
    });
  })();

  // ─── QUOTATION SUBMIT ─────────────────────────────────────
  (function () {
    const form = document.getElementById('tj-inquiry-form');
    if (!form) return;

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      const btn = document.getElementById('tj-submit-btn');
      const fd = new FormData(form);

      const name = (fd.get('name') || '').toString().trim();
      const email = (fd.get('email') || '').toString().trim();
      if (!name || !email) { showToast('Please add your name and email.'); return; }

      const product = window.tjModalProduct;
      const moq = product && product.moq ? parseInt(product.moq, 10) : 1;
      let qty = parseInt(fd.get('quantity'), 10);
      if (!qty || qty < 1) qty = moq;

      const payload = {
        product_id: (fd.get('product_id') || '').toString() || null,
        product_title: (fd.get('product_title') || 'General Inquiry').toString(),
        product_variation: (fd.get('product_variation') || '').toString() || null,
        name: name,
        company: (fd.get('company') || '').toString() || null,
        email: email,
        whatsapp: (fd.get('whatsapp') || '').toString() || null,
        quantity: qty,
        message: (fd.get('message') || '').toString() || null,
        status: 'pending'
      };

      if (btn) { btn.disabled = true; btn.dataset.label = btn.textContent; btn.textContent = 'Submitting…'; btn.style.opacity = '0.7'; }

      let saved = false;
      try {
        if (db) {
          const res = await db.from('inquiries').insert(payload);
          if (res && res.error) console.error('Inquiry insert failed:', res.error);
          else saved = true;
        }
      } catch (err) {
        console.error('Inquiry submit error:', err);
      }

      if (btn) { btn.disabled = false; btn.textContent = btn.dataset.label || 'Submit Quotation Request'; btn.style.opacity = '1'; }

      if (saved) {
        const formC = document.getElementById('tj-form-content');
        const okC = document.getElementById('tj-success-content');
        if (formC) formC.style.display = 'none';
        if (okC) okC.style.display = 'block';
        form.reset();
        return;
      }

      // Saving failed — do not swallow the lead. Hand it to WhatsApp instead.
      const lines = [
        'B2B Quotation Request',
        'Product: ' + payload.product_title,
        payload.product_variation ? 'Option: ' + payload.product_variation : '',
        'Quantity: ' + payload.quantity + ' pcs',
        'Name: ' + payload.name,
        payload.company ? 'Company: ' + payload.company : '',
        'Email: ' + payload.email,
        payload.whatsapp ? 'WhatsApp: ' + payload.whatsapp : '',
        payload.message ? 'Requirements: ' + payload.message : ''
      ].filter(Boolean).join('\n');
      showToast('Network issue — opening WhatsApp so your request still reaches us.');
      window.open('https://wa.me/8615986738500?text=' + encodeURIComponent(lines), '_blank');
    });
  })();

  window.toggleWishlistDetail = function(productId, index) {
    const key = 'tj_wl_' + productId;
    const isNow = localStorage.getItem(key) !== '1';
    if (isNow) localStorage.setItem(key, '1'); else localStorage.removeItem(key);
    updateWishlistCount();
    // Update detail buttons
    const b1 = document.getElementById('detail-wl-btn');
    const b2 = document.getElementById('detail-wl-btn2');
    if (b1) { b1.style.background = isNow ? '#E3BA45' : 'rgba(255,255,255,0.1)'; b1.style.color = isNow ? '#1B4332' : '#fff'; }
    if (b2) { b2.style.borderColor = isNow ? '#E3BA45' : '#eae6e0'; b2.style.background = isNow ? '#fff8e0' : '#fff'; b2.style.color = isNow ? '#E3BA45' : '#ccc'; }
    // Update all card buttons
    document.querySelectorAll(`[id^="wl-btn-${productId}"], [id^="wl-new-${productId}"]`).forEach(b => {
      b.style.background = isNow ? 'var(--green)' : 'transparent';
      b.style.color = isNow ? 'var(--gold)' : 'var(--green)';
      const svg = b.querySelector('svg'); if (svg) svg.setAttribute('fill', isNow ? 'currentColor' : 'none');
    });
    showToast(isNow ? '❤ Added to wishlist' : 'Removed from wishlist');
  };

  </script>

</body>
</html>

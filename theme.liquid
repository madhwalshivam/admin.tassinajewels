  // "Load more" lives directly under the grid and is created on demand, so it
  // cannot drift out of sync with the grid's markup.
  function renderLoadMore() {
    const grid = document.getElementById('tj-products-grid');
    if (!grid) return;

    let wrap = document.getElementById('tj-load-more-wrap');
    const total = Array.isArray(tjCurrentFiltered) ? tjCurrentFiltered.length : 0;
    const shown = Math.min(tjVisibleCount, total);

    if (total === 0 || shown >= total) {
      if (wrap) wrap.remove();
      return;
    }

    if (!wrap) {
      wrap = document.createElement('div');
      wrap.id = 'tj-load-more-wrap';
      wrap.style.cssText = 'text-align:center;width:100%;margin:32px 0 8px;';
      const slider = grid.closest('.tj-slider-wrapper') || grid;
      slider.parentNode.insertBefore(wrap, slider.nextSibling);
    }

    const remaining = total - shown;
    const next = Math.min(TJ_PAGE_SIZE, remaining);
    wrap.innerHTML = `
      <button class="tj-load-more-btn" onclick="tjLoadMore()">
        Load ${next} More
        <span class="tj-load-more-count">(${shown} of ${total})</span>
      </button>`;
  }

  window.tjLoadMore = function() {
    tjVisibleCount += TJ_PAGE_SIZE;
    renderProducts(tjCurrentFiltered.slice(0, tjVisibleCount));
    renderLoadMore();
  };


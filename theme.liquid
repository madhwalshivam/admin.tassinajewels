  // ─── RENDER PRODUCT DETAILS PAGE ─────────────────────────
  // ─── BACK ARROW: go to previous page, fallback Home ─────
  window.tjGoBack = function() {
    if (window.history.length > 1) {
      window.history.back();
    } else {
      window.history.pushState({}, "", "/");
      window.renderPageViews();
    }
    window.scrollTo({ top: 0, behavior: "auto" });

  /* ---- CATEGORIES POPUP MODAL ---- */
  .tj-cat-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 100000;
    background: rgba(10, 25, 18, 0.65);
    backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tj-cat-modal-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }
  .tj-cat-modal-container {
    background: #FAF9F6;
    width: 95%;
    max-width: 720px;
    border-radius: 24px;
    box-shadow: 0 20px 50px rgba(10, 25, 18, 0.25);
    border: 1px solid rgba(227, 186, 69, 0.2);
    overflow: hidden;
    transform: scale(0.95);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    max-height: 85vh;
    display: flex;
    flex-direction: column;
  }
  .tj-cat-modal-overlay.active .tj-cat-modal-container {
    transform: scale(1);
  }
  .tj-cat-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 32px 18px;
    border-bottom: 1px solid rgba(27, 67, 50, 0.08);
    background: #ffffff;
  }
  .tj-cat-modal-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 700;
    color: #1B4332;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .tj-cat-modal-close {
    background: rgba(27, 67, 50, 0.05);
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    cursor: pointer;
    color: #1B4332;
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }
  .tj-cat-modal-close:hover {
    background: rgba(27, 67, 50, 0.1);
    transform: rotate(90deg);
  }
  .tj-cat-modal-body {
    padding: 32px;
    overflow-y: auto;
    flex: 1;
    min-height: 200px;
    background: #FAF9F6;
  }
  .tj-cat-modal-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    padding-bottom: 8px;
  }
  .tj-cat-modal-card {
    background: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(27, 67, 50, 0.05);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .tj-cat-modal-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 28px rgba(27, 67, 50, 0.12);
    border-color: #E3BA45;
  }
  .tj-cat-modal-card-img-wrap {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    position: relative;
    background: #FAF9F6;
  }
  .tj-cat-modal-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tj-cat-modal-card:hover .tj-cat-modal-card-img {
    transform: scale(1.06);
  }
  .tj-cat-modal-card-info {
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #ffffff;
    flex-grow: 1;
  }
  .tj-cat-modal-card-name {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    color: #1B4332;
    margin: 0;
    text-transform: capitalize;
    letter-spacing: 0.5px;
    transition: color 0.3s ease;
  }
  .tj-cat-modal-card:hover .tj-cat-modal-card-name {
    color: #E3BA45;
  }
  .tj-cat-modal-card-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(27, 67, 50, 0.04);
    color: #1B4332;
    transition: all 0.3s ease;
  }
  .tj-cat-modal-card:hover .tj-cat-modal-card-arrow {
    background: #1B4332;
    color: #E3BA45;
    transform: translateX(3px);
  }
  @media (max-width: 640px) {
    .tj-cat-modal-header {
      padding: 18px 24px 14px;
    }
    .tj-cat-modal-title {
      font-size: 18px;
    }
    .tj-cat-modal-body {
      padding: 20px;
    }
    .tj-cat-modal-grid {
      gap: 16px;
    }
    .tj-cat-modal-card-info {
      padding: 12px 14px;
    }
    .tj-cat-modal-card-name {
      font-size: 12px;
    }
    .tj-cat-modal-card-arrow {
      width: 24px;
      height: 24px;
    }
  }



  /* ══ GLOBAL: ARROWS VISIBILITY BY SCREEN SIZE ══ */
  /* All arrows visible on all screen sizes */

  /* Brand Preloader Overlay */
  #tj-preloader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: #1B4332;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 999999;
    transition: opacity 0.6s cubic-bezier(0.25, 1, 0.5, 1), visibility 0.6s ease;
  }
  .tj-preloader-logo-wrap {
    position: relative;
    width: 130px;
    height: 130px;
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.04);
    padding: 20px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    animation: tj-pulse-logo 2.2s infinite ease-in-out;
  }
  .tj-preloader-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .tj-preloader-glow {
    position: absolute;
    top: -8px;
    left: -8px;
    right: -8px;
    bottom: -8px;
    border: 2px solid #E3BA45;
    border-radius: 50%;
    opacity: 0;
    animation: tj-loader-ripple 2.2s infinite cubic-bezier(0.215, 0.610, 0.355, 1);
  }
  .tj-loader-dots {
    display: flex;
    gap: 8px;
    margin-top: 10px;
  }
  .tj-loader-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #E3BA45;
    animation: tj-dot-bounce 1.4s infinite ease-in-out both;
  }
  .tj-loader-dot:nth-child(1) { animation-delay: -0.32s; }
  .tj-loader-dot:nth-child(2) { animation-delay: -0.16s; }

  @keyframes tj-pulse-logo {
    0%, 100% { transform: scale(0.95); box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15); }
    50% { transform: scale(1.05); box-shadow: 0 12px 48px rgba(227, 186, 69, 0.25); }
  }
  @keyframes tj-loader-ripple {
    0% { transform: scale(0.85); opacity: 0.8; }
    100% { transform: scale(1.25); opacity: 0; }
  }
  @keyframes tj-dot-bounce {
    0%, 80%, 100% { transform: scale(0); }
    40% { transform: scale(1.0); }
  }

  /* ---- PRODUCT DETAILS PAGE (PDP) ---- */
  .tj-pdp-breadcrumb a {
    color: #666;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .tj-pdp-breadcrumb a:hover {
    color: #1B4332;
  }
  .tj-pdp-thumb {
    width: 72px;
    height: 72px;
    object-fit: cover;
    border-radius: 10px;
    border: 2.5px solid transparent;
    cursor: pointer;
    background: #ffffff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    transition: all 0.22s ease;
    flex-shrink: 0;
  }
  .tj-pdp-thumb.active {
    border-color: #1B4332;
    box-shadow: 0 0 0 3px rgba(27,67,50,0.15);
    transform: scale(1.06);
  }
  .tj-pdp-thumb:hover:not(.active) {
    border-color: #E3BA45;
    transform: scale(1.04);
  }
  #tj-pdp-thumbnails::-webkit-scrollbar { display: none; }
  /* ── Variant / option selector (PDP) ───────────────────────── */
  .tj-pdp-variation-group { margin-bottom: 20px; width: 100%; }
  /* Group heading is hidden (REQ 3) but kept in the DOM for assistive tech. */
  .tj-pdp-variation-head {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .tj-pdp-variation-options { display: flex; gap: 9px; flex-wrap: wrap; }

  /* Variation option buttons — reset native button appearance so they look identical
     to the previous anchor-based design. */
  .tj-pdp-variant-badge,
  .tj-pdp-variant-tile {
    -webkit-appearance: none;
    appearance: none;
    font-family: var(--font-sans, inherit);
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .tj-pdp-variant-badge:hover,
  .tj-pdp-variant-tile:hover { text-decoration: none; }

  /* Sold-out options stay readable and linkable but never look clickable. */
  .tj-pdp-variant-badge.is-disabled,
  .tj-pdp-variant-tile.is-disabled { pointer-events: none; }

  .tj-pdp-variant-badge {
    position: relative;
    min-width: 52px;
    padding: 10px 16px;
    background: #ffffff;
    border: 1.5px solid rgba(27, 67, 50, 0.14);
    color: #1B4332;
    border-radius: 10px;
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: 0.3px;
    text-align: center;
    cursor: pointer;
    user-select: none;
    transition: border-color 0.18s ease, background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease, transform 0.12s ease;
  }
  .tj-pdp-variant-badge:hover:not(.active):not(.is-disabled) {
    border-color: #E3BA45;
    transform: translateY(-1px);
  }
  .tj-pdp-variant-badge:active:not(.is-disabled) { transform: translateY(0); }
  .tj-pdp-variant-badge.active {
    background: #1B4332;
    color: #E3BA45;
    border-color: #1B4332;
    box-shadow: 0 0 0 3px rgba(227, 186, 69, 0.22);
  }
  .tj-pdp-variant-badge:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgba(227, 186, 69, 0.45);
  }

  /* Sold-out options stay visible (they inform) but are clearly unselectable */
  .tj-pdp-variant-badge.is-disabled {
    cursor: not-allowed;
    color: #b9b5ac;
    background: #faf9f7;
    border-color: rgba(27, 67, 50, 0.07);
    border-style: dashed;
  }
  .tj-pdp-variant-badge.is-disabled .tj-variant-value { text-decoration: line-through; }

  .tj-pdp-variant-badge .tj-variant-sub {
    display: block;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2px;
    margin-top: 3px;
    opacity: 0.72;
  }
  .tj-pdp-variant-badge.active .tj-variant-sub { opacity: 0.85; }

  /* Colour-dot swatch (used when an option has a known colour but no photo) */
  .tj-pdp-variant-badge.is-swatch {
    min-width: 0; padding: 5px; border-radius: 50%;
    width: 40px; height: 40px; display: inline-flex;
    align-items: center; justify-content: center;
  }
  .tj-pdp-variant-badge.is-swatch .tj-variant-swatch {
    width: 100%; height: 100%; border-radius: 50%;
    border: 1px solid rgba(0,0,0,0.08);
  }

  /* ── Amazon-style image tiles ──────────────────────────────
     When an option carries its own photo, show the photo + its price,
     the way a buyer expects to pick a colour/metal on a marketplace. */
  .tj-pdp-variation-options.is-tiles {
    gap: 10px;
  }
  .tj-pdp-variant-tile {
    position: relative;
    width: 78px;
    padding: 4px 4px 6px;
    background: #ffffff;
    border: 1.5px solid rgba(27, 67, 50, 0.14);
    border-radius: 10px;
    cursor: pointer;
    user-select: none;
    text-align: center;
    transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.12s ease;
  }
  .tj-pdp-variant-tile:hover:not(.active):not(.is-disabled) {
    border-color: #E3BA45;
    transform: translateY(-1px);
  }
  .tj-pdp-variant-tile.active {
    border-color: #1B4332;
    border-width: 2px;
    padding: 3.5px 3.5px 5.5px;
    box-shadow: 0 0 0 3px rgba(227, 186, 69, 0.22);
  }
  .tj-pdp-variant-tile:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgba(227, 186, 69, 0.45);
  }
  .tj-pdp-variant-tile .tj-tile-img-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 7px;
    overflow: hidden;
    background: #faf9f7;
  }
  .tj-pdp-variant-tile .tj-tile-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .tj-pdp-variant-tile .tj-tile-price {
    display: block;
    margin-top: 5px;
    font-size: 11px;
    font-weight: 700;
    color: #1B4332;
    letter-spacing: 0.2px;
    line-height: 1.25;
  }
  .tj-pdp-variant-tile .tj-tile-compare {
    display: block;
    font-size: 9.5px;
    font-weight: 500;
    color: #9b9689;
    text-decoration: line-through;
    line-height: 1.3;
  }
  .tj-pdp-variant-tile .tj-tile-label {
    display: block;
    margin-top: 3px;
    font-size: 9.5px;
    font-weight: 600;
    color: #6f6b60;
    letter-spacing: 0.3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  /* Sold-out tiles: visible but plainly unavailable */
  .tj-pdp-variant-tile.is-disabled {
    cursor: not-allowed;
    border-style: dashed;
    border-color: rgba(27, 67, 50, 0.07);
  }
  .tj-pdp-variant-tile.is-disabled .tj-tile-img-wrap { opacity: 0.4; }
  .tj-pdp-variant-tile.is-disabled .tj-tile-price { color: #b9b5ac; text-decoration: line-through; }
  .tj-pdp-variant-tile .tj-tile-soldout {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%) rotate(-8deg);
    background: rgba(255,255,255,0.94);
    color: #8a8578;
    font-size: 8px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.6px;
    padding: 2px 6px; border-radius: 4px;
    border: 1px solid rgba(27,67,50,0.12);
    pointer-events: none;
  }

  @media (max-width: 480px) {
    .tj-pdp-variant-tile { width: 68px; }
    .tj-pdp-variant-tile .tj-tile-price { font-size: 10px; }
  }

  .tj-pdp-variant-note {
    font-size: 11px; color: #8a8578; margin: 10px 0 0; line-height: 1.5;
  }
  /* PDP Back Arrow (premium circular) */
  .tj-pdp-back-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #ffffff;
    border: 1px solid rgba(27,67,50,0.12);
    color: #1B4332;
    cursor: pointer;
    margin-bottom: 16px;
    box-shadow: 0 4px 14px rgba(27,67,50,0.12);
    transition: transform 0.25s cubic-bezier(0.16,1,0.3,1), background 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
  }
  .tj-pdp-back-btn:hover {
    background: #1B4332;
    color: #E3BA45;
    box-shadow: 0 8px 20px rgba(27,67,50,0.22);
    transform: translateY(-2px) scale(1.05);
  }
  .tj-pdp-back-btn:active { transform: scale(0.92); }
  .tj-pdp-back-btn svg { width: 20px; height: 20px; }
  /* Thumbnail strip — visible on all screen sizes, scrolls horizontally on mobile */
  #tj-product-detail-page #tj-pdp-thumbnails {
    display: flex !important;
    gap: 8px;
    overflow-x: auto;
    padding: 12px 0 4px;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  #tj-product-detail-page #tj-pdp-thumbnails::-webkit-scrollbar { display: none; }
  #tj-product-detail-page .tj-pdp-thumb {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    object-fit: cover;
    border-radius: 8px;
    border: 2px solid transparent;
    cursor: pointer;
    transition: border-color 0.18s ease, transform 0.15s ease, box-shadow 0.18s ease;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
  }
  #tj-product-detail-page .tj-pdp-thumb.active {
    border-color: #1B4332;

      overflow-x: unset !important;
      scrollbar-width: none;
    }
    .tj-bestsellers-grid::-webkit-scrollbar { display: none; }
    .tj-bestsellers-grid > * { flex: none !important; width: 100% !important; }
    .tj-products-grid {
      display: grid !important;
      grid-template-columns: 1fr 1fr !important;

  .tj-deal-arrow-btn:hover { background: #1B4332; color: #E3BA45; transform: scale(1.08); }
  .tj-deal-arrow-btn svg { width: 18px; height: 18px; fill: currentColor; pointer-events: none; }
  /* Dots */
  .tj-deal-dots { display: flex; justify-content: center; gap: 6px; }
  .tj-deal-dot {
    width: 6px; height: 6px;
    border-radius: 50%;

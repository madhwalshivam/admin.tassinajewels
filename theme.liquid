  <!-- Supabase JS — resilient multi-CDN loader.
       jsDelivr is intermittently blocked by some ISPs and by in-app browsers
       (WhatsApp / Instagram WebView). A single <script src> there means the whole
       storefront never boots. We try mirrors in order, then fall back to a tiny
       REST client that talks to Supabase directly over fetch(). -->
  <script>
  (function () {
    var CDNS = [
      'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2',
      'https://unpkg.com/@supabase/supabase-js@2',
      'https://cdn.skypack.dev/@supabase/supabase-js@2',
      'https://cdnjs.cloudflare.com/ajax/libs/supabase-js/2.39.7/umd/supabase.min.js'
    ];
    window._tjSupabaseSource = null;

    function loadNext(i) {
      if (typeof window.supabase !== 'undefined' && window.supabase.createClient) {
        window._tjSupabaseSource = 'cdn';
        window._tjSupabaseReady = true;
        return;
      }
      if (i >= CDNS.length) {
        // Every CDN failed → install the built-in REST fallback so the catalog
        // still renders. api.supabase.co itself is what actually matters.
        installRestFallback();
        return;
      }
      var el = document.createElement('script');
      el.src = CDNS[i];
      el.async = false;
      var settled = false;
      var timer = setTimeout(function () {
        if (settled) return;
        settled = true;
        try { el.parentNode && el.parentNode.removeChild(el); } catch (e) {}
        loadNext(i + 1);
      }, 6000);
      el.onload = function () {
        if (settled) return;
        settled = true;
        clearTimeout(timer);
        if (typeof window.supabase !== 'undefined' && window.supabase.createClient) {
          window._tjSupabaseSource = 'cdn';
          window._tjSupabaseReady = true;
        } else {
          loadNext(i + 1);
        }
      };
      el.onerror = function () {
        if (settled) return;
        settled = true;
        clearTimeout(timer);
        loadNext(i + 1);
      };
      document.head.appendChild(el);
    }

    // ── Minimal Supabase REST client (read + insert only) ──
    // Enough to run the storefront: settings, categories, products, images,
    // variations, reviews, inquiry insert. Auth degrades to a no-op stub.
    function installRestFallback() {
      function Builder(base, table, key) {
        this._base = base; this._table = table; this._key = key;
        this._filters = []; this._order = null; this._limit = null;
        this._select = '*'; this._insert = null; this._single = false;
      }
      Builder.prototype.select = function (cols) { this._select = cols || '*'; return this; };
      Builder.prototype.eq  = function (c, v) { this._filters.push(c + '=eq.' + encodeURIComponent(v)); return this; };
      Builder.prototype.neq = function (c, v) { this._filters.push(c + '=neq.' + encodeURIComponent(v)); return this; };
      Builder.prototype.gt  = function (c, v) { this._filters.push(c + '=gt.' + encodeURIComponent(v)); return this; };
      Builder.prototype.lt  = function (c, v) { this._filters.push(c + '=lt.' + encodeURIComponent(v)); return this; };
      Builder.prototype.in  = function (c, a) { this._filters.push(c + '=in.(' + a.map(encodeURIComponent).join(',') + ')'); return this; };
      Builder.prototype.limit = function (n) { this._limit = n; return this; };
      Builder.prototype.single = function () { this._single = true; return this; };
      Builder.prototype.maybeSingle = function () { this._single = true; return this; };
      Builder.prototype.order = function (col, opts) {
        var asc = !(opts && opts.ascending === false);
        this._order = col + '.' + (asc ? 'asc' : 'desc');
        return this;
      };
      Builder.prototype.insert = function (rows) {
        this._insert = Array.isArray(rows) ? rows : [rows];
        return this;
      };
      Builder.prototype._url = function () {
        var q = this._filters.slice();
        if (!this._insert) q.unshift('select=' + encodeURIComponent(this._select));
        if (this._order) q.push('order=' + this._order);
        if (this._limit != null) q.push('limit=' + this._limit);
        return this._base + '/rest/v1/' + this._table + (q.length ? '?' + q.join('&') : '');
      };
      Builder.prototype._run = function () {
        var self = this;
        var headers = {
          'apikey': this._key,
          'Authorization': 'Bearer ' + this._key,
          'Content-Type': 'application/json'
        };
        var opts = { method: this._insert ? 'POST' : 'GET', headers: headers };
        if (this._insert) {
          opts.body = JSON.stringify(this._insert);
          headers['Prefer'] = 'return=representation';
        }
        return fetch(this._url(), opts).then(function (r) {
          return r.text().then(function (t) {
            var body = null;
            try { body = t ? JSON.parse(t) : null; } catch (e) { body = null; }
            if (!r.ok) return { data: null, error: { message: (body && body.message) || ('HTTP ' + r.status), status: r.status } };
            var d = body;
            if (self._single) d = (Array.isArray(body) && body.length) ? body[0] : null;
            return { data: d, error: null };
          });
        }).catch(function (e) {
          return { data: null, error: { message: (e && e.message) || 'network error' } };
        });
      };
      Builder.prototype.then = function (res, rej) { return this._run().then(res, rej); };
      Builder.prototype.catch = function (rej) { return this._run().catch(rej); };

      var noAuth = function () {
        return Promise.resolve({ data: { user: null, session: null }, error: { message: 'Sign-in is unavailable in offline mode. Please open the store in your main browser.' } });
      };

      window.supabase = {
        createClient: function (url, key) {
          return {
            _tjRest: true,
            from: function (table) { return new Builder(url.replace(/\/$/, ''), table, key); },
            auth: {
              onAuthStateChange: function () { return { data: { subscription: { unsubscribe: function () {} } } }; },
              getSession: function () { return Promise.resolve({ data: { session: null }, error: null }); },
              getUser: function () { return Promise.resolve({ data: { user: null }, error: null }); },
              signInWithPassword: noAuth,
              signInWithOtp: noAuth,
              signUp: noAuth,
              signOut: function () { return Promise.resolve({ error: null }); },
              resetPasswordForEmail: noAuth
            }
          };
        }
      };
      window._tjSupabaseSource = 'rest-fallback';
      window._tjSupabaseReady = true;
      try { console.warn('[TJ] Supabase CDN unreachable — using built-in REST fallback.'); } catch (e) {}
    }

    window._tjInstallRestFallback = installRestFallback;
    loadNext(0);
  })();
  </script>


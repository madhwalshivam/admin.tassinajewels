    width: 100%;
    font-family: var(--font-sans);
    transition: background 0.2s, color 0.2s;
  }
  .tj-deal-card-cta:hover { background: #E3BA45; color: #1B4332; }
  

  /* SWIPER ARROW BUTTONS — Bottom controls row */
  .tj-deal-controls-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 16px;
    width: 100%;
  }
  .tj-deal-arrow-btn {
    position: relative;
    width: 34px;
    height: 34px;
    border-radius: 50%;

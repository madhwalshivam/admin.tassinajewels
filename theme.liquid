  // Get premium fallback category lifestyle image based on keywords
  function getCategoryFallbackImage(cat) {
    if (!cat) return 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?q=80&w=600&auto=format&fit=cover';
    const slug = (cat.slug || '').toLowerCase();
    const name = (cat.name || '').toLowerCase();
    if (slug.includes('ring') || name.includes('ring')) {
      return 'https://images.unsplash.com/photo-1605100804763-247f67b3557e?q=80&w=600&auto=format&fit=cover';
    }
    if (slug.includes('neck') || name.includes('neck') || slug.includes('pend') || name.includes('pend')) {
      return 'https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?q=80&w=600&auto=format&fit=cover';
    }
    if (slug.includes('bracelet') || name.includes('bracelet') || slug.includes('bangle') || name.includes('bangle')) {
      return 'https://images.unsplash.com/photo-1611591437281-460bfbe1220a?q=80&w=600&auto=format&fit=cover';
    }
    if (slug.includes('ear') || name.includes('ear') || slug.includes('stud') || name.includes('stud')) {
      return 'https://images.unsplash.com/photo-1635767798638-3e25273a8236?q=80&w=600&auto=format&fit=cover';
    }
    return 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?q=80&w=600&auto=format&fit=cover';
  }
  window.getCategoryFallbackImage = getCategoryFallbackImage;


















      























      









          








































  // ─── HELPER FUNCTIONS FOR NAVIGATION AND CONTACTS ─────────
  window.scrollSection = function(elementId, direction) {
    const container = document.getElementById(elementId);
    if (!container) return;
    // Clear auto-slide if user manually interacts via navigation arrows
    if (elementId === 'tj-qcat-row-1' && container._autoSlide) {
      clearInterval(container._autoSlide);
      container._autoSlide = null;
    }
    const scrollAmount = container.clientWidth * 0.75;
    if (direction === 'left') {
      container.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    } else {
      container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    }
  };

  // ─── CATEGORIES BOTTOM DRAWER ──────────────────────────
  window.openCategoriesDrawer = function() {
    const drawer = document.getElementById('tj-cat-drawer');
    const overlay = document.getElementById('tj-cat-drawer-overlay');
    const list = document.getElementById('tj-cat-drawer-list');
    if (!drawer) return;
    
    const GREEN = '#1B4332';
    
    if (list && list.children.length === 0 && allCategories.length > 0) {
      list.innerHTML = allCategories.map(cat => {
        const img = cat.image_url ? formatImageUrl(cat.image_url) : getCategoryFallbackImage(cat);
        const slug = cat.slug;

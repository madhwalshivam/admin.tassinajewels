      <script>
        function toggleMute(btn) {
          const video = btn.parentElement.querySelector('video');
          if (video) {
            video.muted = !video.muted;
            if (video.muted) {
              btn.innerHTML = '<svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>';
            } else {
              btn.innerHTML = '<svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>';
            }
          }
        }
      </script>

      <!-- ===== DYNAMIC BEST QUALITY SECTION (Trending-style) ===== -->
      <section id="tj-best-quality-outer" style="display:none; background:#EDF3EE; padding: 24px 0 30px;">
        <div style="max-width:1280px; margin:0 auto; padding:0 16px;">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
            <div>
              <h2 id="tj-best-quality-title" style="font-size:20px; font-weight:700; color:#1B4332; font-family:var(--font-serif); margin:0 0 4px;">Best Quality</h2>
              <p id="tj-best-quality-subtitle" style="font-size:11px; color:#666; margin:0; text-transform:uppercase; letter-spacing:1px;">Premium handcrafted masterpieces</p>
            </div>
            
          </div>
          <div id="tj-best-quality-mobile" style="display:none; grid-template-columns:1fr 1fr; gap:12px;"></div>
          <div class="tj-slider-wrapper" id="tj-best-quality-desktop-wrap">
            <button class="tj-arrow-btn prev" onclick="scrollSection('tj-best-quality-container','left')" aria-label="Previous"><svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg></button>
            <div id="tj-best-quality-container" style="display:flex;gap:14px;overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch;scroll-snap-type:x mandatory;padding:4px 0 12px;"></div>
            <button class="tj-arrow-btn next" onclick="scrollSection('tj-best-quality-container','right')" aria-label="Next"><svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg></button>
          </div>
        </div>
      </section>

      <!-- ===== TASSINA PRODUCTS SECTION ===== -->
      <section class="tj-section" id="tj-products-section" style="background: #EDF3EE;">
        <h2 class="tj-section-title" id="tj-catalog-heading">Our Collections</h2>
        <p class="tj-section-subtitle" id="tj-catalog-subtitle">Handcrafted luxury jewellery &mdash; explore our complete range</p>

        <!-- Category Filters Dropdown -->
        <div class="tj-filters-dropdown-container">
          <label for="tj-category-select" style="font-size: 9px; font-weight: 600; color: var(--gold-dark); text-transform: uppercase; letter-spacing: 2px; display: block; margin-bottom: 6px;">Select Collection</label>
          <div class="tj-select-wrapper">
            <select class="tj-category-select" id="tj-category-select" onchange="filterByCategory(this.value)">
              <option value="all">All Collections</option>
            </select>
            <div class="tj-select-arrow">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </div>
        </div>

        <!-- Info & Sort Bar -->
        <div id="tj-catalog-info-bar" style="display: flex; justify-content: space-between; align-items: center; max-width: 1280px; margin: 20px auto 20px; padding: 0 16px; flex-wrap: wrap; gap: 12px;">
          <div style="font-size: 11px; font-weight: 700; color: #1B4332; text-transform: uppercase; letter-spacing: 1.5px;" id="tj-product-count-label">
            Loading products...
          </div>
          <div style="display: flex; gap: 10px; align-items: center;">
            <button class="tj-filter-drawer-toggle" id="tj-filter-drawer-toggle" onclick="toggleFilterDrawer()" style="display: inline-flex; padding: 8px 16px; font-size: 11px; font-weight: 600; color: #1B4332; border: 1px solid #eae6e0; border-radius: 8px; background: #ffffff; cursor: pointer; align-items: center; gap: 8px; font-family: var(--font-sans);">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 6h16M7 12h10M10 18h4"/></svg>
              Filters
            </button>
            <div class="tj-sort-wrapper" style="position: relative;">
              <select id="tj-sort-select" onchange="handleSortChange(this.value)" style="appearance: none; -webkit-appearance: none; background: #ffffff; border: 1px solid #eae6e0; border-radius: 8px; padding: 8px 30px 8px 12px; font-size: 11px; color: #1B4332; font-weight: 600; outline: none; cursor: pointer; min-width: 150px; font-family: var(--font-sans);">
                <option value="default">Sort by: Default</option>
                <option value="price_asc">Price: Low to High</option>
                <option value="price_desc">Price: High to Low</option>
              </select>
              <div style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); pointer-events: none; color: #1B4332; display: flex; align-items: center;">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Subcategory Filters (dynamic) -->
        {% comment %}
        <div class="tj-subfilters" id="tj-subfilters" style="display: none;">
          <!-- Loaded dynamically -->
        </div>
        {% endcomment %}

        <!-- Sidebar overlay for mobile -->
        <div class="tj-sidebar-overlay" id="tj-sidebar-overlay" onclick="toggleFilterDrawer()" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 99999;"></div>

        <!-- Catalog Layout Container -->
        <div class="tj-catalog-layout-container">
          <!-- Sidebar Filters -->
          <aside class="tj-catalog-sidebar" id="tj-catalog-sidebar">
            <!-- Dynamically populated filters -->
          </aside>

          <!-- Catalog Main Column -->
          <div class="tj-catalog-main-col">
            <!-- Products Grid -->
            <div class="tj-slider-wrapper">
              <button class="tj-arrow-btn prev" onclick="scrollSection('tj-products-grid', 'left')" aria-label="Previous">
                <svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
              </button>
              <div class="tj-products-grid" id="tj-products-grid">
                <!-- Skeleton loading -->
                {% for i in (1..8) %}
                <div class="tj-product-card">
                  <div class="tj-skeleton" style="height:260px;"></div>
                  <div style="padding:20px;">
                    <div class="tj-skeleton" style="height:10px;width:40%;margin-bottom:8px;"></div>
                    <div class="tj-skeleton" style="height:14px;margin-bottom:12px;"></div>
                    <div class="tj-skeleton" style="height:16px;width:30%;margin-bottom:16px;"></div>
                    <div class="tj-skeleton" style="height:36px;border-radius:4px;"></div>
                  </div>
                </div>
                {% endfor %}
              </div>
              <button class="tj-arrow-btn next" onclick="scrollSection('tj-products-grid', 'right')" aria-label="Next">
                <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
              </button>
            </div>
            <!-- Pagination Container -->
            <div id="tj-products-pagination" style="display: flex; justify-content: center; align-items: center; gap: 8px; margin-top: 36px; padding-bottom: 24px; flex-wrap: wrap;"></div>
          </div>
        </div>
      </section>
      <!-- ===== END PRODUCTS SECTION ===== -->

      <!-- ===== PRODUCT DETAIL PAGE SECTION (inspired by Amazon) ===== -->
      <section class="tj-section" id="tj-product-detail-page" style="display: none; background: #FAF9F6; min-height: 85vh; padding: 30px 16px 60px;">
        <div style="max-width: 1280px; margin: 0 auto;">
          <!-- Back Arrow (Product Details Page) -->
          <button class="tj-pdp-back-btn" onclick="tjGoBack()" aria-label="Go back" title="Go back">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5m7-7-7 7 7 7"/></svg>
          </button>
          <!-- Breadcrumb Navigation -->
          <div class="tj-pdp-breadcrumb" id="tj-pdp-breadcrumb" style="font-size: 12px; color: #666; margin-bottom: 24px; font-family: var(--font-sans);">
            <!-- Dynamic breadcrumb (Home > Category > Product Name) -->
          </div>

          <!-- Product Main Block (Gallery + Info) -->
          <div class="tj-pdp-main-grid" style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 40px; margin-bottom: 48px; align-items: start;">
            
            <!-- Left Side: Image Gallery (Amazon-style) -->
            <div class="tj-pdp-gallery-wrap" style="position: sticky; top: 100px;">
              <!-- Main Large Image with zoom support -->
              <div class="tj-pdp-main-image-wrap" id="tj-pdp-main-image-wrap" style="width:100%; aspect-ratio:1; border-radius:16px; overflow:hidden; background:#ffffff; border:1px solid rgba(27,67,50,0.05); box-shadow:0 4px 20px rgba(0,0,0,0.04); position:relative; cursor:zoom-in;">
                <img id="tj-pdp-main-image" src="" alt="" style="width:100%; height:100%; object-fit:cover; transition:transform 0.18s ease-out; transform-origin:center center; user-select:none; -webkit-user-drag:none;">
                <!-- Prev / Next arrows -->
                <button id="tj-pdp-prev-btn" onclick="tjGalleryNav(-1)" aria-label="Previous" style="position:absolute; left:10px; top:50%; transform:translateY(-50%); width:36px; height:36px; border-radius:50%; background:rgba(255,255,255,0.92); border:1px solid rgba(27,67,50,0.12); display:none; align-items:center; justify-content:center; cursor:pointer; z-index:4; box-shadow:0 2px 8px rgba(0,0,0,0.12); transition:all 0.2s;">
                  <svg width="14" height="14" fill="none" stroke="#1B4332" stroke-width="2.5" viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
                </button>
                <button id="tj-pdp-next-btn" onclick="tjGalleryNav(1)" aria-label="Next" style="position:absolute; right:10px; top:50%; transform:translateY(-50%); width:36px; height:36px; border-radius:50%; background:rgba(255,255,255,0.92); border:1px solid rgba(27,67,50,0.12); display:none; align-items:center; justify-content:center; cursor:pointer; z-index:4; box-shadow:0 2px 8px rgba(0,0,0,0.12); transition:all 0.2s;">
                  <svg width="14" height="14" fill="none" stroke="#1B4332" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
                </button>
                <!-- Image counter badge -->
                <div id="tj-pdp-img-counter" style="position:absolute; bottom:10px; right:12px; background:rgba(0,0,0,0.45); color:#fff; font-size:10px; font-weight:600; padding:3px 9px; border-radius:20px; display:none; letter-spacing:0.5px;"></div>
              </div>

              <!-- Thumbnail strip with scroll -->
              <div style="position:relative; margin-top:14px;">
                <div class="tj-pdp-thumbnails" id="tj-pdp-thumbnails" style="display:flex; gap:10px; overflow-x:auto; padding-bottom:4px; scroll-behavior:smooth; scrollbar-width:none;">
                  <!-- Dynamically loaded thumbnails -->
                </div>
              </div>
            </div>

            <!-- Right Side: Product Details & Sticky Action Section -->
            <div class="tj-pdp-details-wrap" style="font-family: var(--font-sans);">
              <div style="border-bottom: 1px solid rgba(27,67,50,0.08); padding-bottom: 20px; margin-bottom: 24px;">
                <span id="tj-pdp-category-badge" style="font-size: 10px; font-weight: 700; color: #E3BA45; text-transform: uppercase; letter-spacing: 1.5px; display: inline-block; margin-bottom: 8px;"></span>
                <h1 id="tj-pdp-title" style="font-family: var(--font-serif); font-size: 28px; color: #1B4332; font-weight: 700; margin: 0 0 12px; line-height: 1.25;"></h1>
                
                <!-- Rating Info -->
                <div style="display: flex; align-items: center; gap: 12px;">
                  <span id="tj-pdp-stars" style="color: #E3BA45; font-size: 16px;">★★★★★</span>
                  <span style="font-size: 12px; color: #666; font-weight: 500;">(Wholesale Verified Masterpiece)</span>
                </div>
              </div>

              <!-- Price & MOQ Section -->
              <div class="tj-pdp-info-card" style="background: #ffffff; border-radius: 16px; padding: 24px; border: 1px solid rgba(27,67,50,0.05); box-shadow: 0 8px 30px rgba(0,0,0,0.02); margin-bottom: 24px;">
                <div style="display: flex; align-items: flex-end; gap: 12px; margin-bottom: 16px;">
                  <span id="tj-pdp-price" style="font-size: 32px; font-weight: 700; color: #1B4332;"></span>
                  <span id="tj-pdp-compare-price" style="font-size: 16px; color: #999; text-decoration: line-through; display: none;"></span>
                  <span id="tj-pdp-discount-badge" style="font-size: 12px; font-weight: 700; color: #e63946; background: #fee; padding: 2px 8px; border-radius: 4px; display: none;"></span>
                </div>

                <div class="tj-pdp-meta-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; border-top: 1px solid rgba(0,0,0,0.04); padding-top: 16px; margin-bottom: 24px;">
                  <div>
                    <span style="font-size: 10px; color: #999; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 4px;">Minimum Order Quantity</span>
                    <span id="tj-pdp-moq" style="font-size: 14px; font-weight: 600; color: #1B4332;"></span>
                  </div>
                  <div>
                    <span style="font-size: 10px; color: #999; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 4px;">Material Details</span>
                    <span id="tj-pdp-material" style="font-size: 14px; font-weight: 600; color: #1B4332;"></span>
                  </div>
                  <div>
                    <span style="font-size: 10px; color: #999; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 4px;">Average Weight</span>
                    <span id="tj-pdp-weight" style="font-size: 14px; font-weight: 600; color: #1B4332;"></span>
                  </div>
                  <div>
                    <span style="font-size: 10px; color: #999; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 4px;">Availability</span>
                    <span id="tj-pdp-stock-status" style="font-size: 14px; font-weight: 600; color: #0f9d58; display: flex; align-items: center; gap: 4px;">
                      <span id="tj-pdp-stock-dot" style="width: 8px; height: 8px; border-radius: 50%; background: #0f9d58; display: inline-block;"></span>
                      <span id="tj-pdp-stock-text">In Stock / Wholesale Ready</span>
                    </span>
                  </div>
                  <div id="tj-pdp-sku-wrap" style="display: none;">
                    <span style="font-size: 10px; color: #999; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 4px;">Product SKU</span>
                    <span id="tj-pdp-sku" style="font-size: 14px; font-weight: 600; color: #1B4332;"></span>
                  </div>
                </div>

                <div class="tj-pdp-actions" style="display: flex; gap: 12px;">
                  <button id="tj-pdp-book-btn" style="flex: 1; padding: 16px; background: #1B4332; color: #E3BA45; border: none; border-radius: 12px; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; cursor: pointer; transition: all 0.25s ease;" onmouseover="this.style.background='#132F23'" onmouseout="this.style.background='#1B4332'">Book Wholesale Order</button>
                  <button id="tj-pdp-wishlist-btn" style="width: 52px; height: 52px; border: 2px solid #eae6e0; background: #ffffff; border-radius: 12px; cursor: pointer; font-size: 20px; color: #ccc; display: flex; align-items: center; justify-content: center; transition: all 0.25s ease;">♥</button>
                </div>
              </div>

              <!-- Variation options — directly under price, above Overview (Amazon order).
                   No group titles: the options speak for themselves. -->
              <div id="tj-pdp-variants-wrap" style="margin-bottom: 24px; display: none;">
                <div id="tj-pdp-variants"></div>
              </div>

              <!-- Short Description -->
              <div style="margin-bottom: 24px;">
                <h4 style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #999; margin: 0 0 8px;">Overview</h4>
                <p id="tj-pdp-short-desc" style="font-size: 14px; color: #4a5568; line-height: 1.6; margin: 0;"></p>
              </div>
            </div>
          </div>

          <!-- Product Tabs / Detailed Sections (inspired by premium descriptions) -->
          <div style="border-top: 1px solid rgba(27,67,50,0.08); padding-top: 40px; margin-bottom: 48px; display: grid; grid-template-columns: 1fr; gap: 32px;">
            
            <!-- Description Section -->
            <div class="tj-pdp-spec-card" style="background: #ffffff; border-radius: 16px; padding: 32px; border: 1px solid rgba(27,67,50,0.05); box-shadow: 0 4px 20px rgba(0,0,0,0.01);">
              <h3 style="font-family: var(--font-serif); font-size: 20px; color: #1B4332; margin: 0 0 16px;">Product Specifications & Description</h3>
              <p id="tj-pdp-full-desc" style="font-size: 14px; color: #4a5568; line-height: 1.8; margin: 0 0 24px; white-space: pre-line;"></p>
              
              <!-- Material Details Table -->
              <div style="max-width: 600px;">
                <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #f0ede8; font-size: 13px;">
                  <span style="color: #666; font-weight: 500;">Material Composition</span>
                  <span id="tj-pdp-table-material" style="font-weight: 600; color: #1B4332;"></span>
                </div>
                <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #f0ede8; font-size: 13px;">
                  <span style="color: #666; font-weight: 500;">MOQ Requirement</span>
                  <span id="tj-pdp-table-moq" style="font-weight: 600; color: #1B4332;"></span>
                </div>
                <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #f0ede8; font-size: 13px;">
                  <span style="color: #666; font-weight: 500;">Shipping Turnaround</span>
                  <span style="font-weight: 600; color: #1B4332;">7 - 12 Business Days</span>
                </div>
              </div>
            </div>

            <!-- Features & Care Instructions -->
            <div class="tj-pdp-features-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">

  // variantKey addresses one variation of this product (REQ 2). Absent → parent page.
  window.renderProductDetailsPage = async function(slugOrId, variantKey) {
    // ── Clear stale data immediately so the visitor never sees the previous
    //    product's details while the next one is loading. ─────────────────
    (function clearStalePdp() {
      const ids = ['tj-pdp-title', 'tj-pdp-price', 'tj-pdp-compare-price',
                   'tj-pdp-discount-badge', 'tj-pdp-moq', 'tj-pdp-material',
                   'tj-pdp-weight', 'tj-pdp-sku', 'tj-pdp-short-desc', 'tj-pdp-full-desc',
                   'tj-pdp-category-badge', 'tj-pdp-breadcrumb', 'tj-pdp-stock-text'];
      ids.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = '';
      });
      // Reset compare-price / discount visibility
      const cmp = document.getElementById('tj-pdp-compare-price');
      const dsc = document.getElementById('tj-pdp-discount-badge');
      if (cmp) cmp.style.display = 'none';
      if (dsc) dsc.style.display = 'none';
      // Clear gallery
      const mainImg = document.getElementById('tj-pdp-main-image');
      if (mainImg) { mainImg.src = ''; mainImg.alt = ''; }
      const thumbWrap = document.getElementById('tj-pdp-thumbnails');
      if (thumbWrap) thumbWrap.innerHTML = '';
      const prevBtn = document.getElementById('tj-pdp-prev-btn');
      const nextBtn = document.getElementById('tj-pdp-next-btn');
      const counter = document.getElementById('tj-pdp-img-counter');
      if (prevBtn) prevBtn.style.display = 'none';
      if (nextBtn) nextBtn.style.display = 'none';
      if (counter) counter.style.display = 'none';
      // Hide variation wrap
      const varWrap = document.getElementById('tj-pdp-variants-wrap');
      if (varWrap) varWrap.style.display = 'none';
    })();

    if (!allProducts || allProducts.length === 0) {
      if (typeof loadProducts === 'function') {
        await loadProducts();
      } else {
        return;
      }
    }
    
    let p = null;
    let activeVariation = null;
    let activeVariantKey = variantKey;

    // 1. Try direct match in allProducts (exact slug or ID)
    p = allProducts.find(x => String(x.id) === String(slugOrId) || x.slug === slugOrId);

    // 2. "/product/<slug>" with ?v=<variation-id> — resolve the variation by ID directly.
    //    This is the primary path for variation navigation (reliable, no ambiguity).
    if (p && variantKey) {
      // variantKey here may be a UUID (from ?v=) or a slug (legacy ?variant=).
      const isUuid = /^[0-9a-f]{8}-[0-9a-f]{4}-/i.test(variantKey);
      const vars = window.tjVariationsFor(p.id);
      if (isUuid) {
        activeVariation = vars.find(v => String(v.id) === String(variantKey)) || null;
      }
      if (!activeVariation) {
        activeVariation = window.tjFindVariation(vars, variantKey);
      }
      if (activeVariation) activeVariantKey = window.tjVariantKey(activeVariation);
    }

    // 3. Path suffix matching: "/product/<slug>-<variantKey>" (legacy / no ?v= param).
    if (!p) {
      const candidates = allProducts
        .filter(x => (x.slug && slugOrId.startsWith(x.slug + '-')) ||
                     (x.id && slugOrId.startsWith(String(x.id) + '-')))
        .sort((a, b) => (b.slug || String(b.id)).length - (a.slug || String(a.id)).length);

      for (let ci = 0; ci < candidates.length; ci++) {
        const cand = candidates[ci];
        const base = (cand.slug && slugOrId.startsWith(cand.slug + '-')) ? cand.slug : String(cand.id);
        const remainder = slugOrId.substring(base.length + 1);
        if (!remainder) continue;
        const match = window.tjFindVariation(window.tjVariationsFor(cand.id), remainder);
        if (match) {
          p = cand;
          activeVariation = match;
          activeVariantKey = window.tjVariantKey(match);
          break;
        }
      }

      if (!p && candidates.length) {
        p = candidates[0];
        activeVariantKey = null;
      }
    }

    // 3. Try UUID direct lookup in product_variations if still not found
    if (db && (!p || !activeVariation)) {
      try {
        const isUuid = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(slugOrId);
        if (isUuid) {
          const { data: varData } = await db.from('product_variations').select('*').eq('id', slugOrId).maybeSingle();
          if (varData) {
            activeVariation = varData;
            const { data: prodData } = await db.from('products').select('*').eq('id', activeVariation.product_id).maybeSingle();
            if (prodData) {
              p = prodData;
              activeVariantKey = window.tjVariantKey(activeVariation);
            }
          }
        }
      } catch (err) {
        console.error('Error fetching via UUID direct lookup:', err);
      }
    }

    if (!p) {
      const pdp = document.getElementById('tj-product-detail-page');
      if (pdp) {
        pdp.innerHTML = `<div style="text-align:center; padding: 100px 20px;">
          <h2 style="font-family: var(--font-serif); color: #1B4332;">Product Not Found</h2>
          <p style="color: #666; margin-bottom: 24px;">The masterpiece you're looking for could not be located.</p>
          <a href="/" style="display:inline-block; padding: 12px 24px; background: #1B4332; color: #E3BA45; border-radius: 8px; text-decoration: none; text-transform: uppercase; font-size: 11px; font-weight: 700; letter-spacing: 1px;">Return to Collections</a>
        </div>`;
      }
      return;
    }

    const catName = p.category || 'Fine Jewelry';
    window.tjCurrentPdpProduct = p;

    // Fetch fresh database variations and images for the specific product
    let dbImages = [];
    let dbVariations = [];
    if (db) {
      try {
        const [imagesRes, variationsRes] = await Promise.all([
          db.from('product_images').select('*').eq('product_id', p.id).order('display_order', { ascending: true }),
          db.from('product_variations').select('*').eq('product_id', p.id).order('display_order', { ascending: true })
        ]);
        if (!imagesRes.error && imagesRes.data) dbImages = imagesRes.data;
        if (!variationsRes.error && variationsRes.data) dbVariations = window.tjUsableVariations(variationsRes.data);
      } catch (err) {
        console.error('Error fetching variations/images:', err);
      }
    }

    // Does the bare "/product/<slug>" URL show the product, or auto-jump to its
    // first variation?
    //   false → the product page shows the PRODUCT's own price, SKU, copy and
    //           gallery. Variations are options you click. (Matches the rule that
    //           the main gallery shows only the product's own images, and that a
    //           variation's copy must not replace the parent's until you open it.)
    //   true  → the bare URL redirects to the first in-stock variation.
    if (window.TJ_PDP_DEFAULT_VARIANT === undefined) window.TJ_PDP_DEFAULT_VARIANT = false;

    if (!activeVariation && activeVariantKey && dbVariations.length > 0) {
      // UUID match first (from ?v= param) — then slug key fallback.
      const isUuid = /^[0-9a-f]{8}-[0-9a-f]{4}-/i.test(activeVariantKey);
      if (isUuid) {
        activeVariation = dbVariations.find(v => String(v.id) === String(activeVariantKey)) || null;
      }
      if (!activeVariation) {
        activeVariation = window.tjFindVariation(dbVariations, activeVariantKey);
      }
    }

    if (window.TJ_PDP_DEFAULT_VARIANT && !activeVariation && dbVariations && dbVariations.length > 0) {
      const defaultVar = dbVariations.find(v => !window.tjVariationOutOfStock(v)) || dbVariations[0];
      if (defaultVar) {
        activeVariation = defaultVar;
        activeVariantKey = window.tjVariantKey(defaultVar);
      }
    }

    // An unusable key must never leave a stale variation applied.
    if (!activeVariation) activeVariantKey = null;

    window.tjActiveVariation = activeVariation;
    window.tjCurrentVariantKey = activeVariantKey || null;

    // Optional per-variation gallery table. It does not exist in every project,
    // so probe once and remember — a missing relation must not cost a round-trip
    // and a console error on every single product view.
    let dbVarImages = [];
    if (db && activeVariation && window._tjVariationImagesTable !== false) {
      try {
        const varImgsRes = await db.from('variation_images')
          .select('*')
          .eq('variation_id', activeVariation.id)
          .order('display_order', { ascending: true });
        if (varImgsRes.error) {
          const msg = String(varImgsRes.error.message || '');
          const code = String(varImgsRes.error.code || '');
          if (code === '42P01' || code === 'PGRST205' || /does not exist|not find the table/i.test(msg)) {
            window._tjVariationImagesTable = false;
            console.info('[TJ] No variation_images table in this project — using the ' +
                         'image columns on product_variations instead.');
          }
        } else if (varImgsRes.data) {
          window._tjVariationImagesTable = true;
          dbVarImages = varImgsRes.data;
        }
      } catch (err) {
        window._tjVariationImagesTable = false;
      }
    }

    // Silently sync browser URL to the canonical variation URL.
    if (activeVariation) {
      try {
        const expectedUrl = window.tjVariantUrl(p, activeVariation);
        const currentUrl = window.location.pathname + window.location.search;
        if (currentUrl !== expectedUrl) {
          window.history.replaceState({}, '', expectedUrl);
        }
      } catch (e) {}
    }

    const mainImg = document.getElementById('tj-pdp-main-image');

    // ── GALLERY ENGINE ────────────────────────────────────────
    window.tjGalleryImages = [];
    window.tjGalleryIndex = 0;

    function tjGalleryRender(images, startIdx) {
      window.tjGalleryImages = images || [];
      window.tjGalleryIndex = startIdx || 0;

      const mainImg = document.getElementById('tj-pdp-main-image');
      const thumbWrap = document.getElementById('tj-pdp-thumbnails');
      const prevBtn = document.getElementById('tj-pdp-prev-btn');
      const nextBtn = document.getElementById('tj-pdp-next-btn');
      const counter = document.getElementById('tj-pdp-img-counter');

      const imgs = window.tjGalleryImages;
      const n = imgs.length;

      if (!mainImg || n === 0) return;
      mainImg.src = window.tjImgSrc(imgs[0], p);
      mainImg.alt = p.title || '';
      mainImg.onerror = function () {
        this.onerror = null;
        this.src = getProductFallbackImage(p);
      };

      // Thumbnails
      if (thumbWrap) {
        if (n <= 1) {
          thumbWrap.innerHTML = '';
        } else {
          thumbWrap.innerHTML = imgs.map((src, i) => {
            const fsrc = window.tjImgSrc(src, p);
            return `<img src="${fsrc}" class="tj-pdp-thumb${i === 0 ? ' active' : ''}" data-idx="${i}" onclick="tjGalleryGoTo(${i})" alt="Image ${i+1}" loading="lazy" ${window.tjImgFallbackAttr(p)}>`;
          }).join('');
        }
      }

      // Arrows
      if (prevBtn) prevBtn.style.display = n > 1 ? 'flex' : 'none';
      if (nextBtn) nextBtn.style.display = n > 1 ? 'flex' : 'none';
      if (counter) { counter.textContent = '1 / ' + n; counter.style.display = n > 1 ? 'block' : 'none'; }

      if (startIdx && startIdx > 0) tjGalleryGoTo(startIdx);
    }

    window.tjGalleryGoTo = function(idx) {
      const imgs = window.tjGalleryImages;
      if (!imgs || imgs.length === 0) return;
      idx = ((idx % imgs.length) + imgs.length) % imgs.length;
      window.tjGalleryIndex = idx;

      const mainImg = document.getElementById('tj-pdp-main-image');
      if (mainImg) {
        const zooming = !!window._tjZooming;
        mainImg.style.transition = 'opacity 0.15s ease';
        mainImg.style.opacity = '0';
        // Only touch transform when NOT zooming — otherwise the crossfade yanks
        // the image out of the zoom the shopper is holding.
        if (!zooming) mainImg.style.transform = 'scale(0.97)';
        setTimeout(() => {
          mainImg.src = window.tjImgSrc(imgs[idx], p);
          mainImg.style.opacity = '1';
          if (!window._tjZooming) {
            mainImg.style.transform = 'scale(1)';
            mainImg.style.transformOrigin = 'center center';
          }
        }, 120);
      }

      document.querySelectorAll('.tj-pdp-thumb').forEach((t, i) => {
        t.classList.toggle('active', i === idx);
        if (i === idx) t.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      });

      const counter = document.getElementById('tj-pdp-img-counter');
      if (counter) counter.textContent = (idx + 1) + ' / ' + imgs.length;
    };

    window.tjGalleryNav = function(dir) { tjGalleryGoTo(window.tjGalleryIndex + dir); };

    // Swipe + hover-zoom are bound ONCE. The wrap element is static markup, so
    // re-binding per product view stacked duplicate handlers on every navigation.
    if (!window._tjGalleryBound) {
      window._tjGalleryBound = true;
      const wrap = document.getElementById('tj-pdp-main-image-wrap');
      const mainImg = document.getElementById('tj-pdp-main-image');

      if (wrap) {
        // ── Swipe between images (touch) ──
        let sx = 0, sy = 0;
        wrap.addEventListener('touchstart', e => {
          sx = e.touches[0].clientX; sy = e.touches[0].clientY;
        }, { passive: true });
        wrap.addEventListener('touchend', e => {
          const dx = e.changedTouches[0].clientX - sx;
          const dy = e.changedTouches[0].clientY - sy;
          // Ignore mostly-vertical drags so page scrolling never flips the image.
          if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) window.tjGalleryNav(dx < 0 ? 1 : -1);
        }, { passive: true });
      }

      if (wrap && mainImg) {
        // ── Hover zoom (pointer devices only) ──
        // A coarse pointer means touch: zooming there fights scrolling and leaves
        // the image stuck scaled after a tap.
        const finePointer = () => {
          try { return window.matchMedia('(hover: hover) and (pointer: fine)').matches; }
          catch (e) { return window.innerWidth > 900; }
        };

        wrap.addEventListener('mouseenter', () => {
          if (!finePointer()) return;
          window._tjZooming = true;
          wrap.style.cursor = 'zoom-in';
        });

        wrap.addEventListener('mousemove', e => {
          if (!window._tjZooming || !finePointer()) return;
          const rect = wrap.getBoundingClientRect();
          const x = Math.max(0, Math.min(100, ((e.clientX - rect.left) / rect.width) * 100));
          const y = Math.max(0, Math.min(100, ((e.clientY - rect.top) / rect.height) * 100));
          mainImg.style.transformOrigin = x + '% ' + y + '%';
          mainImg.style.transform = 'scale(' + (window.TJ_PDP_ZOOM || 2.2) + ')';
          mainImg.style.transition = 'transform 0.08s ease-out';
        });

        wrap.addEventListener('mouseleave', () => {
          window._tjZooming = false;
          mainImg.style.transform = 'scale(1)';
          mainImg.style.transformOrigin = 'center center';
          mainImg.style.transition = 'transform 0.3s cubic-bezier(0.16, 1, 0.3, 1)';
        });
      }
    }

    // Leaving zoom state behind would keep the next product's hero scaled 2.2x.
    (function resetZoom() {
      const mainImg = document.getElementById('tj-pdp-main-image');
      if (!mainImg) return;
      window._tjZooming = false;
      mainImg.style.transform = 'scale(1)';
      mainImg.style.transformOrigin = 'center center';
    })();

    // ── GALLERY SOURCES (REQ 1, 6, 7) ─────────────────────────
    // De-dupe while preserving upload order.
    function tjUniqueImages(list) {
      const seen = new Set();
      const out = [];
      (list || []).forEach(u => {
        if (typeof u !== 'string') return;
        const t = u.trim();
        if (!t) return;
        const key = (formatImageUrl(t) || t);
        if (seen.has(key)) return;
        seen.add(key);
        out.push(t);
      });
      return out;
    }

    // Parent gallery — the images uploaded against the product, cover first.
    const TJ_COVER_FLAGS = ['is_primary', 'is_cover', 'is_default', 'is_featured', 'primary', 'cover', 'featured'];
    const tjIsCoverRow = (row) => {
      if (!row) return false;
      for (let i = 0; i < TJ_COVER_FLAGS.length; i++) {
        const f = row[TJ_COVER_FLAGS[i]];
        if (f === true || f === 1 || f === '1' || f === 'true') return true;
      }
      return false;
    };

    // Same asset written two ways (relative vs absolute) must compare equal.
    const tjSameImage = (a, b) => {
      if (!a || !b) return false;
      if (a === b) return true;
      const ra = formatImageUrl(a), rb = formatImageUrl(b);
      return !!ra && ra === rb;
    };

    let parentImages = [];
    if (dbImages.length > 0) {
      const ordered = dbImages.slice().sort((a, b) => (a.display_order || 0) - (b.display_order || 0));

      // Cover = an explicitly flagged row, else the row matching products.image_url
      // (which is what the listing card renders, so the two must agree).
      let coverIdx = ordered.findIndex(tjIsCoverRow);
      if (coverIdx < 0 && p.image_url) {
        coverIdx = ordered.findIndex(img => tjSameImage(img.image_url, p.image_url));
      }
      if (coverIdx > 0) ordered.unshift(ordered.splice(coverIdx, 1)[0]);

      const urls = ordered.map(img => img.image_url);

      // The admin's cover lives on products.image_url. If it is not among the
      // gallery rows it is still a real product image — lead with it rather than
      // never showing it. Dedupe means no phantom extra when it IS in the list.
      if (p.image_url && !urls.some(u => tjSameImage(u, p.image_url))) {
        urls.unshift(p.image_url);
      }
      parentImages = tjUniqueImages(urls);
    } else {
      const legacy = [];
      if (p.image_url) legacy.push(p.image_url);
      try {
        if (p.gallery_images) {
          const parsed = (typeof p.gallery_images === 'string') ? JSON.parse(p.gallery_images) : p.gallery_images;
          if (Array.isArray(parsed)) parsed.forEach(u => legacy.push(typeof u === 'string' ? u : (u && (u.image_url || u.url))));
        }
      } catch (e) {}
      parentImages = tjUniqueImages(legacy);
    }
    window.tjParentGalleryImages = parentImages.slice();

    // Variation gallery — that variation's own images, from variation_images or variation's main image
    let variationImages = [];
    if (activeVariation) {
      if (dbVarImages.length > 0) {
        variationImages = tjUniqueImages(dbVarImages.map(img => img.image_url));
      } else {
        variationImages = tjUniqueImages(window.tjVariationImages(activeVariation));
      }
    }

    // The gallery shows exactly one set. A variation with no images of its own
    // falls back to the parent's — it never mixes.
    let images = activeVariation && variationImages.length ? variationImages : parentImages;
    if (images.length === 0) images = [getProductFallbackImage(p)];

    window.tjBaseGalleryImages = images.slice();
    tjGalleryRender(images, 0);

    // Kept for compatibility: variation selection no longer touches the gallery,
    // because selecting a variation now navigates to that variation's own page.
    window.tjSwitchGalleryForVariation = function() { /* intentionally inert — see REQ 1 */ };

    // ── VARIATION-AWARE FIELDS (REQ 2, 7) ─────────────────────
    const V = activeVariation;
    const vHas = (key) => V && V[key] !== undefined && V[key] !== null && String(V[key]).trim() !== '';
    const pick = (key, fallback) => vHas(key) ? V[key] : fallback;

    // Always show the parent product title — no variation suffix.
    const displayTitle = p.title;
    const vPrice = window.tjVariationPrice(V, p);

    const bCrumb = document.getElementById('tj-pdp-breadcrumb');
    if (bCrumb) {
      bCrumb.innerHTML = `<a href="/">Home</a> &nbsp;/&nbsp; <a href="/?category=${p.category_slug || 'all'}">${catName}</a>` +
        ` &nbsp;/&nbsp; <span style="color: #1B4332; font-weight: 500;">${p.title}</span>`;
    }

    const catBadge = document.getElementById('tj-pdp-category-badge');
    if (catBadge) catBadge.textContent = catName;
    const titleEl = document.getElementById('tj-pdp-title');
    if (titleEl) titleEl.textContent = displayTitle;
    const priceEl = document.getElementById('tj-pdp-price');
    if (priceEl) priceEl.textContent = '$' + vPrice.price.toFixed(2);

    const compEl = document.getElementById('tj-pdp-compare-price');
    const badgeEl = document.getElementById('tj-pdp-discount-badge');
    if (compEl && badgeEl) {
      if (vPrice.compare && vPrice.compare > vPrice.price) {
        compEl.textContent = '$' + vPrice.compare.toFixed(2);
        compEl.style.display = 'inline-block';
        badgeEl.textContent = Math.round((1 - vPrice.price / vPrice.compare) * 100) + '% OFF';
        badgeEl.style.display = 'inline-block';
      } else {
        compEl.style.display = 'none';
        badgeEl.style.display = 'none';
      }
    }

    // Determine variation-specific specifications (if available in JSON format or columns)
    let activeSpecs = {};
    if (V && V.specifications) {
      try {
        activeSpecs = typeof V.specifications === 'string' ? JSON.parse(V.specifications) : V.specifications;
      } catch (e) {}
    }

    const getSpec = (key, fallback) => {
      if (activeSpecs && activeSpecs[key] !== undefined && activeSpecs[key] !== null) {
        return activeSpecs[key];
      }
      if (V && V[key] !== undefined && V[key] !== null && String(V[key]).trim() !== '') {
        return V[key];
      }
      return fallback;
    };

    const displayMaterial = getSpec('material', p.material) || getSpec('Material', p.material);
    const displayWeight = getSpec('weight', p.weight) || getSpec('Weight', p.weight);
    const displayMoq = getSpec('moq', p.moq) || getSpec('MOQ', p.moq);

    const moqEl = document.getElementById('tj-pdp-moq');
    if (moqEl) moqEl.textContent = (displayMoq || 2) + ' pieces';
    const matEl = document.getElementById('tj-pdp-material');
    if (matEl) matEl.textContent = displayMaterial || 'Premium Alloy & Plating';
    const wEl = document.getElementById('tj-pdp-weight');
    if (wEl) wEl.textContent = displayWeight || 'Standard';

    const shortEl = document.getElementById('tj-pdp-short-desc');
    if (shortEl) shortEl.textContent = pick('short_description', p.short_description) || 'A timeless, meticulously crafted masterpiece designed for elegance and durability. Available exclusively for our wholesale partners.';

    const fullEl = document.getElementById('tj-pdp-full-desc');
    if (fullEl) fullEl.textContent = pick('description', p.description) || 'Elevate your jewelry collection with this exquisite piece. Designed with absolute precision by master craftsmen, it offers unparalleled shine and longevity. Our rigorous quality control ensures that each item meets international premium standards, making it perfect for your retail storefront.\n\nAll our pieces undergo rigorous hypoallergenic testing and are guaranteed skin-friendly, giving your customers the ultimate comfort and confidence.';

    const tblMat = document.getElementById('tj-pdp-table-material');
    if (tblMat) tblMat.textContent = displayMaterial || 'Premium Gold Plated Alloy';
    const tblMoq = document.getElementById('tj-pdp-table-moq');
    if (tblMoq) tblMoq.textContent = (displayMoq || 2) + ' Units Minimum';

    // Page metadata + canonical follow the variation (REQ 2).
    try {
      const metaTitle = pick('meta_title', null) || (displayTitle + ' | Tassina Jewels');
      document.title = metaTitle;
      const metaDesc = pick('meta_description', p.meta_description) ||
                       pick('short_description', p.short_description) || '';
      let mdEl = document.querySelector('meta[name="description"]');
      if (!mdEl) { mdEl = document.createElement('meta'); mdEl.setAttribute('name', 'description'); document.head.appendChild(mdEl); }
      if (metaDesc) mdEl.setAttribute('content', String(metaDesc).slice(0, 300));

      let linkEl = document.querySelector('link[rel="canonical"]');
      if (!linkEl) { linkEl = document.createElement('link'); linkEl.setAttribute('rel', 'canonical'); document.head.appendChild(linkEl); }
      linkEl.setAttribute('href', window.location.origin + window.tjVariantUrl(p, V));
    } catch (e) {}

    const featWrap = document.getElementById('tj-pdp-features');
    if (featWrap) {
      featWrap.innerHTML = `
        <li><strong>Handcrafted Precision:</strong> Each stone is set meticulously by experienced artisans.</li>
        <li><strong>Durability:</strong> Anti-tarnish coating to ensure a long-lasting brilliant finish.</li>
        <li><strong>Comfort Fit:</strong> Designed with smooth edges for all-day comfortable wear.</li>
        <li><strong>Versatile Elegance:</strong> Perfect for both high-end events and daily chic styles.</li>
      `;
    }
    // ─── VARIATION OPTIONS ───────────────────────────────────
    const tjMoney = (n) => '$' + parseFloat(n || 0).toFixed(2);

    // Stock line reflects whatever this page represents.
    const stockDot = document.getElementById('tj-pdp-stock-dot');
    const stockText = document.getElementById('tj-pdp-stock-text');
    const pageOut = V
      ? window.tjVariationOutOfStock(V)
      : (p.stock_status === 'out_of_stock' ||
         (p.stock_quantity !== undefined && p.stock_quantity !== null && Number(p.stock_quantity) <= 0));
    if (stockDot && stockText) {
      stockDot.style.background = pageOut ? '#E3BA45' : '#0f9d58';
      stockText.textContent = pageOut ? 'Made to Order · Lead time applies' : 'In Stock / Wholesale Ready';
      if (stockText.parentElement) stockText.parentElement.style.color = pageOut ? '#B7860B' : '#0f9d58';
    }

    const skuWrap = document.getElementById('tj-pdp-sku-wrap');
    const skuEl = document.getElementById('tj-pdp-sku');
    if (skuWrap && skuEl) {
      const activeSku = (V && V.sku) ? V.sku : p.sku;
      if (activeSku) { skuEl.textContent = activeSku; skuWrap.style.display = 'block'; }
      else { skuWrap.style.display = 'none'; }
    }

    // What the quotation should record for this page.
    window.tjSelectedVariation = V || null;
    window.tjSelectedVariationLabel = V ? (window.tjOptionGroup(V) + ': ' + window.tjOptionLabel(V)) : '';

    const bookBtn0 = document.getElementById('tj-pdp-book-btn');
    if (bookBtn0) bookBtn0.textContent = 'Book Wholesale Order';

    const varWrap = document.getElementById('tj-pdp-variants-wrap');
    const varBox = document.getElementById('tj-pdp-variants');

    if (varWrap && varBox) {
      // Normalise the legacy `variants` JSON column into the same row shape so
      // both storage styles render identically.
      let source = dbVariations;
      if (!source || !source.length) {
        let legacy = [];
        try {
          if (p.variants) legacy = typeof p.variants === 'string' ? JSON.parse(p.variants) : p.variants;
        } catch (e) {}
        if (Array.isArray(legacy) && legacy.length) {
          source = legacy.map((v, idx) => ({
            id: 'legacy-' + idx,
            product_id: p.id,
            variation_name: (v && (v.group || v.variation_name)) || 'Option',
            option_value: (v && (v.name || v.value || v.option_value)) || String(v),
            price: v && v.price,
            sale_price: v && v.sale_price,
            sku: v && v.sku,
            stock_status: v && v.stock_status,
            stock_quantity: v && v.stock_quantity,
            image_url: v && (v.image_url || v.image),
            display_order: idx
          }));
        }
      }

      const groups = window.tjGroupVariations(source || []);
      const groupNames = Object.keys(groups);

      if (!groupNames.length) {
        varWrap.style.display = 'none';
        varBox.innerHTML = '';
      } else {
        varWrap.style.display = 'block';
        let html = '';

        // Store all variation data in JS so in-place update works without a new fetch.
        window._tjPdpVariationSource = source || [];
        window._tjPdpParentProduct = p;
        window._tjPdpParentImages = parentImages.slice();

        groupNames.forEach(groupName => {
          const opts = groups[groupName];
          const useTiles = opts.some(v => {
            const img = window.tjVariationImage(v);
            return img && formatImageUrl(img);
          });

          // No group heading rendered — just the options row.
          html += '<div class="tj-pdp-variation-group">' +
            '<div class="tj-pdp-variation-options' + (useTiles ? ' is-tiles' : '') + '" role="group" aria-label="' + groupName + '">' +
              opts.map(v => {
                const out = window.tjVariationOutOfStock(v);
                const isActive = !!(V && String(V.id) === String(v.id));
                const label = window.tjOptionLabel(v);
                const safeLabel = label.replace(/"/g, '&quot;');
                const pr = window.tjVariationPrice(v, p);
                // Encode the variation data for in-place switching (no navigation).
                const vidAttr = 'data-vid="' + v.id + '"';

                // Resolve to standalone product if it was imported separately.
                const targetProduct = window.tjFindProductByVariation(v, p.id);
                const targetUrl = targetProduct ? ('/product/' + (targetProduct.slug || targetProduct.id)) : window.tjVariantUrl(p);
                const onClickAttr = targetProduct 
                  ? 'onclick="event.preventDefault(); tjGoTo(\'' + targetUrl + '\')"' 
                  : 'onclick="event.preventDefault(); tjSwitchVariant(this)"';

                if (useTiles) {
                  const raw = window.tjVariationImage(v);
                  const src = raw ? window.tjImgSrc(raw, p) : window.tjImgSrc(p.image_url, p);
                  const cls = ['tj-pdp-variant-tile'];
                  if (isActive) cls.push('active');
                  if (out) cls.push('is-disabled');
                  return '<a href="' + targetUrl + '" role="button" class="' + cls.join(' ') + '" ' + vidAttr + ' ' + onClickAttr + ' title="' + safeLabel + (out ? ' — sold out' : '') + '" aria-pressed="' + isActive + '">' +
                    '<div class="tj-tile-img-wrap">' +
                      '<img class="tj-tile-img" src="' + src + '" alt="' + safeLabel + '" loading="lazy" ' + window.tjImgFallbackAttr(p) + '>' +
                    '</div>' +
                    (out ? '<span class="tj-tile-soldout">Sold out</span>' : '') +
                    '<span class="tj-tile-price">' + tjMoney(pr.price) + '</span>' +
                    ((pr.compare && pr.compare > pr.price) ? '<span class="tj-tile-compare">' + tjMoney(pr.compare) + '</span>' : '') +
                    '<span class="tj-tile-label">' + label + '</span>' +
                  '</a>';
                }

                const cls = ['tj-pdp-variant-badge'];
                if (isActive) cls.push('active');
                if (out) cls.push('is-disabled');
                const basePrice = window.tjVariationPrice(V || opts[0], p).price;
                let sub = '';
                if (out) sub = '<span class="tj-variant-sub">Sold out</span>';
                else if (Math.abs(pr.price - basePrice) >= 0.01) {
                  const d = pr.price - basePrice;
                  sub = '<span class="tj-variant-sub">' + (d > 0 ? '+' : '−') + tjMoney(Math.abs(d)) + '</span>';
                }
                return '<a href="' + targetUrl + '" role="button" class="' + cls.join(' ') + '" ' + vidAttr + ' ' + onClickAttr + ' aria-pressed="' + isActive + '">' + '<span class="tj-variant-value">' + label + '</span>' + sub + '</a>';
              }).join('') +
            '</div>' +
          '</div>';
        });

        varBox.innerHTML = html;
      }
    }

    // Action buttons
    const wlBtn = document.getElementById('tj-pdp-wishlist-btn');
    if (wlBtn) {
      const wlKey = 'tj_wl_' + p.id;
      const isNow = localStorage.getItem(wlKey) === '1';
      wlBtn.style.borderColor = isNow ? '#E3BA45' : '#eae6e0';
      wlBtn.style.background = isNow ? '#fff8e0' : '#ffffff';
      wlBtn.style.color = isNow ? '#E3BA45' : '#ccc';
      
      const pIdx = allProducts.findIndex(x => x.id === p.id);
      wlBtn.onclick = function() {
        if (typeof toggleWishlistDetail === 'function') toggleWishlistDetail(p.id, pIdx);
        const isSet = localStorage.getItem(wlKey) === '1';
        wlBtn.style.borderColor = isSet ? '#E3BA45' : '#eae6e0';
        wlBtn.style.background = isSet ? '#fff8e0' : '#ffffff';
        wlBtn.style.color = isSet ? '#E3BA45' : '#ccc';

  window.handleSortChange = function(val) {
    currentSort = val;
    loadProducts();
  };

  // In-memory cache
  let _cachedProducts = null;
  let _cachedCategories = null;
  let _cachedSubcategories = null;
  let _cachedSettings = null;

  // Persistent product cache (versioned so schema/format changes bust old copies).
  const TJ_PRODUCTS_KEY = 'tj_c_products_v2';
  const TJ_PRODUCTS_MAX_AGE = 12 * 60 * 60 * 1000; // 12h instant-paint window

  // One-time cleanup: remove old/stale cache keys from previous versions so
  // clients never get stuck showing outdated content.
  try {
    ['tj_c_products', 'tj_c_products_v1'].forEach(k => {
      sessionStorage.removeItem(k);
      localStorage.removeItem(k);
    });
  } catch(_e) {}

  // On page reload, drop cached settings/categories so admin changes appear immediately.
  // Products still paint instantly from cache but are always revalidated (see loadProducts).
  try {
    const navEntry = performance.getEntriesByType('navigation')[0];
    if (navEntry && navEntry.type === 'reload') {
      ['tj_c_categories','tj_c_subcats','tj_c_settings'].forEach(k => sessionStorage.removeItem(k));
    }
  } catch(_e) {}

  function formatImageUrl(url) {
    if (!url || typeof url !== 'string') return '';
    
    // If the image is already a secure remote URL (like Cloudinary or Unsplash), return it as is
    if (url.startsWith('https://')) {
      return url;
    }
    
    const isPageSecure = window.location.protocol === 'https:';
    const adminDomain = window.ADMIN_DOMAIN || 'http://localhost:3000';
    
    // Mixed content protection: fallback only if we are loading local images over secure HTTPS
    if (isPageSecure && adminDomain.startsWith('http://localhost')) {
      if (url.startsWith('http://localhost') || url.includes('dfix/')) {
        return 'https://res.cloudinary.com/dxiasatlk/image/upload/v1783425078/Screenshot_20260707_171938_WhatsApp.jpg_nw1spq.jpg';
      }
    }

    let targetDomain = adminDomain;
    if (url.startsWith('http://localhost:3000') && targetDomain !== 'http://localhost:3000') {
      url = url.replace('http://localhost:3000', targetDomain);
    }
    if (url.includes('dfix/')) {
      const parts = url.split('dfix/');
      const filename = parts[1].split('?')[0];
      const cleanFilename = filename.startsWith('/') ? filename.substring(1) : filename;
      
      // Always proxy through the admin API because the direct R2 bucket is private (returns 401)
      return `${targetDomain}/api/image/dfix/${cleanFilename}`;
    }
    if (url.startsWith('http://') || url.startsWith('https://')) {
      return url;
    }
    return url;
  }

  window.renderHeroSlider = function(container, slides) {
    const isMobile = window.innerWidth <= 768;
    if (!slides || slides.length === 0) {
      slides = [{
        desktop_image: 'https://res.cloudinary.com/dxiasatlk/image/upload/v1783425078/banner-1_uyw1j3.jpg',
        mobile_image: 'https://res.cloudinary.com/dxiasatlk/image/upload/v1783425078/banner-1_uyw1j3.jpg',
        link_url: '#tj-products-section'
      }];
    }

    // On desktop show 2 slides at once; on mobile show 1
    const visibleCount = isMobile ? 1 : 2;
    const slideWidthPct = 100 / visibleCount; // 50% on desktop, 100% on mobile
    const gapPx = isMobile ? 0 : 12; // gap between slides on desktop

    let html = `<div class="tj-hero-slides-wrap" id="tj-hero-slides-wrap" style="display:flex; height:auto; transition:transform 0.5s ease-in-out; gap:${gapPx}px;">`;
    slides.forEach(slide => {
      const img = slide.image || (isMobile ? (slide.mobile_image || slide.desktop_image) : (slide.desktop_image || slide.mobile_image));
      const formattedImg = formatImageUrl(img);
      const link = slide.link_url || '#tj-products-section';
      html += `
        <div class="tj-hero-slide" onclick="window.location.href='${link}'" style="flex: 0 0 calc(${slideWidthPct}% - ${gapPx * (visibleCount-1) / visibleCount}px); min-width: 0; border-radius: ${isMobile ? '0' : '10px'}; overflow:hidden; cursor:pointer;">
          <img src="${formattedImg}" alt="Banner" style="width: 100%; height: auto; display: block;">
        </div>
      `;
    });
    html += `</div>`;

    html += `
      <button class="tj-hero-carousel-arrow prev" onclick="event.stopPropagation(); changeHeroSlide(-1)">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button class="tj-hero-carousel-arrow next" onclick="event.stopPropagation(); changeHeroSlide(1)">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <div class="tj-hero-carousel-dots">
        ${slides.map((_, i) => `<button class="tj-hero-carousel-dot ${i === 0 ? 'active' : ''}" onclick="event.stopPropagation(); setHeroSlide(${i})"></button>`).join('')}
      </div>
    `;

    container.innerHTML = html;

    let currentSlideIdx = 0;
    const maxSlideIdx = Math.max(0, slides.length - visibleCount);
    const wrap = container.querySelector('#tj-hero-slides-wrap');
    const dots = container.querySelectorAll('.tj-hero-carousel-dot');
    let autoPlayInterval = null;

    function updateSlide() {
      if (wrap) {
        // Move by slideWidthPct + gap offset per step
        const moveAmt = (slideWidthPct + (gapPx / (container.offsetWidth / 100)));
        wrap.style.transform = `translateX(-${currentSlideIdx * moveAmt}%)`;
      }
      dots.forEach((dot, idx) => {
        dot.classList.toggle('active', idx === currentSlideIdx);
      });
    }

    window.changeHeroSlide = function(dir) {
      let nextIdx = currentSlideIdx + dir;
      if (nextIdx > maxSlideIdx) {
        nextIdx = 0;
      } else if (nextIdx < 0) {
        nextIdx = maxSlideIdx;
      }
      currentSlideIdx = nextIdx;
      updateSlide();
      resetInterval();
    };

    window.setHeroSlide = function(idx) {
      currentSlideIdx = Math.min(idx, maxSlideIdx);
      updateSlide();
      resetInterval();
    };

    function startInterval() {
      autoPlayInterval = setInterval(() => {
        currentSlideIdx = currentSlideIdx >= maxSlideIdx ? 0 : currentSlideIdx + 1;
        updateSlide();
      }, 4000);
    }

    function resetInterval() {
      if (autoPlayInterval) clearInterval(autoPlayInterval);
      startInterval();
    }

    startInterval();
  };

  // ─── LIVE SEARCH DROPDOWN ─────────────────────────────────
  (function() {
    const input = document.getElementById('tj-nav-search-input');
    const clearBtn = document.getElementById('tj-search-clear');
    const resultsBox = document.getElementById('tj-search-results');

    if (!input) return;

    input.addEventListener('input', function() {
      const q = this.value.trim().toLowerCase();
      clearBtn && (clearBtn.className = q ? 'tj-search-clear visible' : 'tj-search-clear');

      if (!q) {
        resultsBox.innerHTML = '';
        resultsBox.classList.remove('open');
        return;
      }

      const matches = allProducts.filter(p =>
        (p.title || '').toLowerCase().includes(q) ||
        (p.category || '').toLowerCase().includes(q) ||
        (p.description || '').toLowerCase().includes(q)
      ).slice(0, 8);

      if (matches.length === 0) {
        resultsBox.innerHTML = '<div class="tj-search-no-results">No results found</div>';
      } else {
        resultsBox.innerHTML = matches.map((p, i) => {
          const img = p.image_url ? formatImageUrl(p.image_url) : '';
          const globalIdx = allProducts.findIndex(ap => ap.id === p.id);
          return `
            <div class="tj-search-result-item" onclick="closeSearch(); openProductDetail(${globalIdx});">
              ${img ? `<img class="tj-search-result-img" src="${img}" alt="">` : '<div class="tj-search-result-img"></div>'}
              <div class="tj-search-result-info">
                <div class="tj-search-result-title">${p.title}</div>
                <div class="tj-search-result-cat">${p.category || ''}</div>
              </div>
              <div class="tj-search-result-price">$${parseFloat(p.price || 0).toFixed(2)}</div>
            </div>`;
        }).join('');
      }
      resultsBox.classList.add('open');
    });

    clearBtn && clearBtn.addEventListener('click', function() {
      input.value = '';
      this.className = 'tj-search-clear';
      resultsBox.innerHTML = '';
      resultsBox.classList.remove('open');
      input.focus();
    });

    document.addEventListener('click', function(e) {
      if (!document.getElementById('tj-search-wrapper')?.contains(e.target)) {
        resultsBox && resultsBox.classList.remove('open');
      }
    });
  })();

  window.closeSearch = function() {
    const r = document.getElementById('tj-search-results');
    if (r) r.classList.remove('open');
  };

  // Legacy compat
  window.handleNavSearch = function(query) {};



  // ─── SUPABASE INITIALIZATION ──────────────────────────────
  function initSupabase() {
    if (typeof supabase !== 'undefined') {
      try {
        db = supabase.createClient(window.SUPABASE_URL, window.SUPABASE_ANON_KEY);
        
        // Listen to auth changes to update navigation text and cache user state
        db.auth.onAuthStateChange((event, session) => {
          window.currentUser = session ? session.user : null;
          
          // Update all handleAccountNav links — preserve SVG icons by targeting <span> when present
          const navLinks = document.querySelectorAll('a[onclick*="handleAccountNav"]');
          navLinks.forEach(link => {
            const isBottomNav = link.id === 'nav-account';
            const loggedOutText = isBottomNav ? 'Account' : 'Login';
            const newText = window.currentUser ? 'Profile' : loggedOutText;
            const span = link.querySelector('span');
            if (span) {
              span.textContent = newText; // safe — doesn't wipe SVG icon
            } else {
              link.textContent = newText;
            }
          });
        });

        return true;
      } catch (err) {
        console.error("Supabase init error:", err);
      }
    }
    return false;
  }

  // ─── LOAD STOREFRONT SETTINGS (BANNER, WHATSAPP, ETC) ──────
  async function loadSettings() {
    if (!db) return;
    try {
      const res = await db.from('storefront_settings')
        .select('*')
        .neq('key', 'cache_bypass_' + Math.random());
      if (res.error || !res.data) {
        console.error("Failed to load settings from Supabase:", res.error);
        return;
      }
      const data = res.data;
      _cachedSettings = data;

      const settingsMap = {};
      data.forEach(item => {
        settingsMap[item.key] = item.value;
      });
      window.tjStorefrontSettings = settingsMap;
      window._tjSettingsLoaded = true;

      // ── NAVBAR (Admin Panel → Navbar Links) ──
      // Cache the navbar links for instant paint on the next visit, then render
      // the navbar from the admin links ONLY (never product categories).
      try {
        if (settingsMap.navbar_menu) {
          localStorage.setItem('tj_navbar_menu_v1', settingsMap.navbar_menu);
        } else {
          localStorage.removeItem('tj_navbar_menu_v1');
        }
      } catch (_e) {}
      if (typeof window.tjRenderNavbar === 'function') {
        try { window.tjRenderNavbar(); } catch (e) { console.error('tjRenderNavbar', e); }
      }

      if (settingsMap.admin_domain) {
        window.ADMIN_DOMAIN = settingsMap.admin_domain;
      }

      // ── HERO BANNER SLIDER ──
      const heroSec = document.getElementById('tj-hero-banner');
      if (heroSec) {
        let slides = [];
        try {
          if (settingsMap.hero_slides) {
            const parsed = JSON.parse(settingsMap.hero_slides);
            if (Array.isArray(parsed)) {
              slides = parsed;
            } else if (parsed && typeof parsed === 'object') {
              slides = [parsed];
            }
          }
        } catch (e) {
          console.error("Error parsing hero_slides", e);
        }
        
        if (!slides || slides.length === 0) {
          const desktopFallback = settingsMap.hero_banner_desktop || 'https://res.cloudinary.com/dxiasatlk/image/upload/v1783425078/Screenshot_20260707_171938_WhatsApp.jpg_nw1spq.jpg';
          const mobileFallback = settingsMap.hero_banner_mobile || 'https://res.cloudinary.com/dxiasatlk/image/upload/v1783425078/Screenshot_20260707_171938_WhatsApp.jpg_nw1spq.jpg';
          slides = [
            { desktop_image: desktopFallback, mobile_image: mobileFallback, link_url: '#tj-products-section' }
          ];
        }

        console.log("Rendering Hero Slider with slides:", slides);
        renderHeroSlider(heroSec, slides);
      }

      // ── ANNOUNCEMENT BAR ──
      const annBar = document.getElementById('tj-announcement-bar');
      const annTextEl = document.getElementById('tj-announcement-text');
      const annLinkEl = document.getElementById('tj-announcement-link');
      if (annBar && settingsMap.announcement_text && settingsMap.announcement_show !== 'false') {
        if (annTextEl) annTextEl.textContent = settingsMap.announcement_text;
        if (annLinkEl && settingsMap.announcement_link) annLinkEl.href = settingsMap.announcement_link;
        annBar.style.display = 'flex';
        const hdr = document.getElementById('tj-custom-header');
        if (hdr) hdr.style.top = '32px';
        
        const updatePadding = () => {
          let headerHeight = 84;
          if (window.innerWidth <= 600) {
            headerHeight = 64;
          } else if (window.innerWidth <= 1024) {
            headerHeight = 74;
          }
          document.body.style.paddingTop = (headerHeight + 32) + 'px';
        };
        updatePadding();
        window.addEventListener('resize', updatePadding);
      } else {
        if (annBar) annBar.style.display = 'none';
        const hdr = document.getElementById('tj-custom-header');
        if (hdr) hdr.style.top = '0';
        
        const updatePadding = () => {
          let headerHeight = 84;
          if (window.innerWidth <= 600) {
            headerHeight = 64;
          } else if (window.innerWidth <= 1024) {
            headerHeight = 74;
          }
          document.body.style.paddingTop = headerHeight + 'px';
        };
        updatePadding();
        window.addEventListener('resize', updatePadding);
      }

      // ── WHATSAPP ──
      if (settingsMap.whatsapp_number) {
        const formattedNum = settingsMap.whatsapp_number.replace(/\D/g, '');
        const floatWa = document.querySelector('.tj-float-whatsapp');
        if (floatWa) floatWa.href = `https://wa.me/${formattedNum}`;
        const footerWa = document.querySelector('.tj-footer a[href*="wa.me"]');
        if (footerWa) { footerWa.href = `https://wa.me/${formattedNum}`; footerWa.textContent = settingsMap.whatsapp_number; }
      }

      // ── ADMIN LINK ──
      const adminLink = document.querySelector('.admin-link');
      if (adminLink && settingsMap.admin_domain) adminLink.href = settingsMap.admin_domain;

      // ── SHOP BY STYLE CARDS (from admin) ──
      if (settingsMap.style_cards) {
        try {
          const cards = JSON.parse(settingsMap.style_cards);
          const grid = document.getElementById('tj-style-grid');
          if (grid && cards.length > 0) {
            grid.innerHTML = cards.filter(c => c.title || c.image).map(c => `
              <div class="tj-style-card" onclick="filterByCategory('${c.filter||'all'}')">
                <img class="tj-style-img" src="${c.image ? formatImageUrl(c.image) : 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?q=80&w=600&auto=format&fit=cover'}" alt="${c.title}" loading="lazy">
                <div><span class="tj-style-title">${c.title}</span></div>
              </div>`).join('');
          }
        } catch(e) {}
      }

    } catch (err) {
      console.warn('Could not load storefront settings:', err);
    }
  }



  // ─── LOAD CATEGORIES & SUBCATEGORIES ──────────────────────
  async function loadFilters() {
    if (!db) return;
    try {
      isCategoriesLoading = true;
      if (typeof renderCategoriesModalGrid === 'function') {
        renderCategoriesModalGrid();
      }

      // ── FAST PATH: load ONLY the categories table so the navbar / quick
      // categories render immediately. The navbar does not need the heavy
      // filter/junction tables, so we no longer wait on them here. ──
      const catRes = await db.from('categories')
        .select('*')
        .neq('slug', 'cache_bypass_' + Math.random())
        .order('display_order');
      const catData = (catRes && !catRes.error && catRes.data) ? catRes.data : [];
      const subcatData = [];

      _cachedCategories = catData;
      _cachedSubcategories = subcatData;

      allCategories = catData;
      allSubcategories = subcatData;
      isCategoriesLoading = false;
      // Mark categories as successfully loaded (only when the request itself succeeded),
      // so the initial loader can gate on it and retry if it failed.
      if (catRes && !catRes.error) { window._tjCategoriesLoaded = true; }

      // ── BACKGROUND: heavy filter/attribute + junction tables. These are only
      // needed by the filter sidebar and junction-based category matching, so
      // they load AFTER the navbar and never block it. When ready, refresh the
      // sidebar filters and re-filter products if a category is being viewed. ──
      (function loadFilterTablesInBackground() {
        Promise.allSettled([
          db.from('filter_groups').select('*').eq('is_enabled', true).order('display_order'),
          db.from('filter_values').select('*'),
          db.from('category_filters').select('*'),
          db.from('product_filter_values').select('*'),
          db.from('product_categories').select('*')
        ]).then(function (r) {
          const fgRes = r[0], fvRes = r[1], cfRes = r[2], pfvRes = r[3], pcRes = r[4];
          allFilterGroups = (fgRes.status === 'fulfilled' && !fgRes.value.error) ? fgRes.value.data : [];
          allFilterValues = (fvRes.status === 'fulfilled' && !fvRes.value.error) ? fvRes.value.data : [];
          allCategoryFilters = (cfRes.status === 'fulfilled' && !cfRes.value.error) ? cfRes.value.data : [];
          allProductFilterValues = (pfvRes.status === 'fulfilled' && !pfvRes.value.error) ? pfvRes.value.data : [];
          productCategories = (pcRes.status === 'fulfilled' && !pcRes.value.error) ? pcRes.value.data : [];
          productSubcategories = [];
          if (typeof renderSidebarFilters === 'function') { try { renderSidebarFilters(); } catch (e) {} }
          if (currentCategory && currentCategory !== 'all' && typeof loadProducts === 'function') {
            try { loadProducts(); } catch (e) {}
          }
        }).catch(function (e) { console.error('Filter attribute load error:', e); });
      })();

      // NOTE: The navigation menu (navbar) is NOT built here. It is rendered
      // exclusively from the Admin Panel's Navbar Links (navbar_menu setting) via
      // tjRenderNavbar() in loadSettings. Product categories are used only below
      // for internal product organisation (quick-categories, dropdown, filtering).

      // Refresh categories modal grid
      if (typeof renderCategoriesModalGrid === 'function') {
        renderCategoriesModalGrid();
      }

      // Render quick categories bar above banner (uses product categories)
      renderQuickCategories(allCategories);

      // Render Shop by Category deals-style section (respects admin setting)
      {
        const sMapCat = window.tjStorefrontSettings || {};
        if (sMapCat.shop_by_cat_active !== 'false') {
          // Update title if set from admin
          const catTitleEl = document.querySelector('#tj-shop-by-category-outer .tj-deal-main-title');
          if (catTitleEl && sMapCat.shop_by_cat_title) catTitleEl.textContent = sMapCat.shop_by_cat_title;

          // Filter by admin-selected slugs if any are set
          let catsToShow = allCategories;
          try {
            const selectedSlugs = JSON.parse(sMapCat.shop_by_cat_slugs || '[]');
            if (selectedSlugs.length > 0) {
              catsToShow = allCategories.filter(c => selectedSlugs.includes(c.slug));
            }
          } catch(e) {}

          renderCategoryDealSlider(catsToShow);
        } else {
          const catOuter = document.getElementById('tj-shop-by-category-outer');
          if (catOuter) catOuter.style.display = 'none';
        }
      }

      // Populate the "Select Collection" filter dropdown from product categories
      const selectEl = document.getElementById('tj-category-select');
      if (selectEl) {
        selectEl.innerHTML = '<option value="all">All Collections</option>';
        allCategories.forEach(cat => {
          const opt = document.createElement('option');
          opt.value = cat.slug;
          opt.textContent = cat.name;
          selectEl.appendChild(opt);
        });
      }

      // Populate footer collections (if the element exists) from product categories
      const footerColEl = document.getElementById('tj-footer-collections');
      if (footerColEl) {
        footerColEl.innerHTML = allCategories.slice(0, 5).map(cat => `
          <li><a href="#tj-products-section" onclick="navigateToCategory('${cat.slug}')">${cat.name}</a></li>
        `).join('');
      }
    } catch (err) {
      console.error("Error loading filters:", err);
      isCategoriesLoading = false;
      allCategories = [];
      if (typeof renderCategoriesModalGrid === 'function') {
        renderCategoriesModalGrid(true);
      }
    }
  }

  // ─── CUSTOM NAVIGATION & FILTERING HELPERS ────────────────
  window.buildNavigationTree = function(catData, subcatData) {
    const parentCats = catData
      .filter(c => c.visible !== false)
      .sort((a, b) => (a.display_order || 0) - (b.display_order || 0));
      
    return parentCats.map(cat => ({
      id: cat.id,
      name: cat.name,
      slug: cat.slug,
      subcategories: []
    }));
  };

  // Renders the navigation menu from the given Admin Panel navbar links ONLY.
  // (Categories are never passed here.)
  window.renderNavigation = function(tree) {
    tree = Array.isArray(tree) ? tree : [];

    // 1. Desktop Nav Rendering — admin navbar links only
    const navLinks = document.querySelector('.tj-nav-links');
    if (navLinks) {
      navLinks.innerHTML = tree.map(cat => {
          if (cat.subcategories && cat.subcategories.length > 0) {
            return `
              <div class="tj-nav-item">
                <a href="#tj-products-section" onclick="navigateToCategory('${cat.slug}')" class="tj-nav-link-with-arrow">
                  ${cat.name}
                  <svg class="tj-dropdown-arrow" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="margin-left:4px;display:inline-block;vertical-align:middle;"><path d="m6 9 6 6 6-6"/></svg>
                </a>
                <div class="tj-nav-dropdown-content">
                  ${cat.subcategories.map(sub => `
                    <a href="#tj-products-section" onclick="navigateToCategory('${sub.slug}')">${sub.name}</a>
                  `).join('')}
                </div>
              </div>
            `;
          } else {
            return `<a href="#tj-products-section" onclick="navigateToCategory('${cat.slug}')">${cat.name}</a>`;
          }
        }).join('');
    }

    // 2. Mobile Nav Drawer Rendering — admin navbar links + Login (functional)
    const drawerLinks = document.querySelector('.tj-drawer-links');
    if (drawerLinks) {
      drawerLinks.innerHTML = tree.map(cat => {
          if (cat.subcategories && cat.subcategories.length > 0) {
            return `
              <div class="tj-drawer-item">
                <div class="tj-drawer-row">
                  <a href="#tj-products-section" onclick="toggleMobileMenu(); navigateToCategory('${cat.slug}')">${cat.name}</a>
                  <button class="tj-drawer-toggle-btn" onclick="toggleMobileSubmenu(event, this)">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
                  </button>
                </div>
                <div class="tj-drawer-submenu">
                  ${cat.subcategories.map(sub => `
                    <a href="#tj-products-section" onclick="toggleMobileMenu(); navigateToCategory('${sub.slug}')">${sub.name}</a>
                  `).join('')}
                </div>
              </div>
            `;
          } else {
            return `<a href="#tj-products-section" onclick="toggleMobileMenu(); navigateToCategory('${cat.slug}')">${cat.name}</a>`;
          }
        }).join('') + `
        <a href="javascript:void(0)" onclick="toggleMobileMenu(); handleAccountNav()">Login</a>
      `;
    }
  };

  // Loading state for the navbar — shows subtle skeletons, NEVER categories.
  window.tjRenderNavbarLoading = function() {
    const navLinks = document.querySelector('.tj-nav-links');
    if (navLinks && !navLinks.dataset.tjReady) {
      navLinks.innerHTML =
        '<span class="tj-nav-skeleton"></span><span class="tj-nav-skeleton"></span><span class="tj-nav-skeleton"></span><span class="tj-nav-skeleton"></span>';
    }
    const drawerLinks = document.querySelector('.tj-drawer-links');
    if (drawerLinks && !drawerLinks.dataset.tjReady) {
      drawerLinks.innerHTML = '<a href="javascript:void(0)" onclick="toggleMobileMenu(); handleAccountNav()">Login</a>';
    }
  };

  // Builds + renders the navbar STRICTLY from the Admin Panel's Navbar Links
  // (navbar_menu storefront setting). Never uses product categories, and never
  // falls back to them. Cached for instant paint; re-renders only when changed.
  window.tjRenderNavbar = function() {
    const sMap = window.tjStorefrontSettings || {};
    let raw = sMap.navbar_menu || null;
    if (!raw) { try { raw = localStorage.getItem('tj_navbar_menu_v1'); } catch (_e) {} }

    // No navbar links available yet.
    if (!raw) {
      if (window._tjSettingsLoaded) {
        // Settings finished loading and no navbar links are configured →
        // render a clean, empty navbar (NEVER product categories).
        renderNavigation([]);
        const nl = document.querySelector('.tj-nav-links'); if (nl) nl.dataset.tjReady = '1';
        const dl = document.querySelector('.tj-drawer-links'); if (dl) dl.dataset.tjReady = '1';
      } else {
        // Still loading → loading state (never categories).
        window.tjRenderNavbarLoading();
      }
      return;
    }

    // Avoid unnecessary re-renders / flicker.
    if (raw === window._tjNavbarRenderedRaw) return;

    let links = [];
    try {
      const parsed = JSON.parse(raw);
      if (Array.isArray(parsed)) {
        links = parsed
          .filter(item => item && item.visible !== false)
          .map(item => ({
            id: item.id || item.slug,
            name: item.name,
            slug: item.slug,
            subcategories: (item.subcategories || [])
              .filter(sub => sub && sub.visible !== false)
              .map(sub => ({ id: sub.id || sub.slug, name: sub.name, slug: sub.slug }))
          }));
      }
    } catch (e) {
      console.error('navbar_menu parse error', e);
      links = [];
    }

    navigationTree = links; // navbar reflects admin links only
    renderNavigation(links);
    window._tjNavbarRenderedRaw = raw;

    const navLinks = document.querySelector('.tj-nav-links');
    if (navLinks) navLinks.dataset.tjReady = '1';
    const drawerLinks = document.querySelector('.tj-drawer-links');
    if (drawerLinks) drawerLinks.dataset.tjReady = '1';
  };

  window.toggleMobileSubmenu = function(e, btn) {
    e.stopPropagation();
    const item = btn.closest('.tj-drawer-item');
    if (!item) return;
    const submenu = item.querySelector('.tj-drawer-submenu');
    if (!submenu) return;
    const isOpen = submenu.style.display === 'flex';
    submenu.style.display = isOpen ? 'none' : 'flex';
    btn.classList.toggle('open', !isOpen);
  };

  window.renderSidebarFilters = function() {
    const sidebar = document.getElementById('tj-catalog-sidebar');
    if (!sidebar) return;

    // Build sidebar HTML starting with mobile header
    let html = `
      <div class="tj-sidebar-mobile-header" style="display: none; justify-content: space-between; align-items: center; padding-bottom: 16px; margin-bottom: 16px; border-bottom: 1px solid rgba(27,67,50,0.1);">

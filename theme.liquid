    text-transform: uppercase;
    letter-spacing: 1px;
    font-family: var(--font-sans);
    font-weight: 700;
  }
  .tj-deal-card-title {
    font-size: 11px;
    font-weight: 600;
    color: #1B4332;
    line-height: 1.4;

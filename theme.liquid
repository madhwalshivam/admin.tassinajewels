  // Get dynamic category-to-product mapping helper
  function isProductInCategory(p, catSlug) {
    if (!catSlug || catSlug === 'all') return true;

    // 1. If we have the new junction mappings (Migrated Schema)
    if (productCategories && productCategories.length > 0 && allCategories && allCategories.length > 0) {
      const targetCat = allCategories.find(c => c.slug === catSlug);
      if (targetCat) {
        const parentId = p._parentId || p.id;
        return productCategories.some(pc => String(pc.product_id) === String(parentId) && pc.category_id === targetCat.id);
      }
    }

    const cSlugRaw = String(catSlug).toLowerCase().trim();

    // 2. The real key. category_slug is what category links and breadcrumbs are
    //    built from, so match it directly before any fuzzy string work.
    if (p.category_slug && String(p.category_slug).toLowerCase().trim() === cSlugRaw) return true;

    // 2b. Same value written as a display name ("Vintage Rings" vs "vintage-rings").
    if (typeof window.tjSlugify === 'function') {
      if (p.category_slug && window.tjSlugify(p.category_slug) === window.tjSlugify(cSlugRaw)) return true;
      if (p.category && window.tjSlugify(p.category) === window.tjSlugify(cSlugRaw)) return true;
    }

    // 3. Fallback to legacy string column checks (Legacy Schema)
    const pCat = (p.category || '').toLowerCase().trim();
    const cSlug = cSlugRaw;
    
    // Exact match
    if (pCat === cSlug) return true;
    
    // Custom prefix grouping fallback:
    if (cSlug === 'vintage-jewellery' && pCat.startsWith('vintage-')) return true;
    if (cSlug === 'stainless-steel-jewellery' && pCat.startsWith('stainless-steel-')) return true;
    if (cSlug === 'natural-stone-jewellery' && (pCat === 'natural-stones-jewellry' || pCat === 'natural-stone-jewellery')) return true;
    if (cSlug === 'custom-jewellery' && (pCat === 'custom-jewellery' || pCat === 'rings' || pCat === 'necklace' || pCat === 'bracelets' || pCat === 'bracelet')) return true;
    if (cSlug === 'mens' && pCat === 'mens') return true;
    if (cSlug === 'womens' && pCat === 'womens') return true;
    
    // Plural/singular adjustments (remove 's' at the end of either)
    const normPCat = pCat.endsWith('s') ? pCat.slice(0, -1) : pCat;
    const normCSlug = cSlug.endsWith('s') ? cSlug.slice(0, -1) : cSlug;
    if (normPCat === normCSlug) return true;

    // Keyword match: e.g. cSlug: "vintage-rings" contains normPCat: "ring"
    if (cSlug.includes(normPCat) || normPCat.includes(cSlug)) return true;
    
    // Specific match: e.g. "earings" / "earrings" typo
    if ((cSlug.includes('earing') || cSlug.includes('earring')) && (pCat.includes('earing') || pCat.includes('earring'))) return true;
    if ((cSlug.includes('necklace') || cSlug.includes('necklaces')) && (pCat.includes('necklace') || pCat.includes('necklaces'))) return true;
    if ((cSlug.includes('bracelet') || cSlug.includes('bracelets')) && (pCat.includes('bracelet') || pCat.includes('bracelets'))) return true;
    if ((cSlug.includes('jewellry') || cSlug.includes('jewelry')) && (pCat.includes('jewellry') || pCat.includes('jewelry'))) return true;
    
    return false;
  }

  // ─── LOAD PRODUCTS ────────────────────────────────────────
  // Every variation in the catalog, fetched once so the listing can show each
  // variation as its own card without a query per product.
  let _cachedVariations = null;
  const TJ_VARIATIONS_KEY = 'tj_variations_cache_v1';

  async function tjFetchVariationsFresh() {
    if (!db) return null;
    const { data, error } = await db.from('product_variations')
      .select('*')
      .order('display_order', { ascending: true });
    if (error) { console.warn('[TJ] variations fetch failed:', error.message || error); return null; }
    // Incomplete rows are dropped here so they can never reach the listing,
    // the router, or a URL.
    const list = window.tjUsableVariations(data || []);
    _cachedVariations = list;
    window.tjAllVariations = list;
    try { localStorage.setItem(TJ_VARIATIONS_KEY, JSON.stringify({ ts: Date.now(), data: list })); } catch (_e) {}
    return list;
  }

  function tjLoadCachedVariations() {
    try {
      const l = JSON.parse(localStorage.getItem(TJ_VARIATIONS_KEY) || 'null');
      if (l && Array.isArray(l.data) && (Date.now() - l.ts) < TJ_PRODUCTS_MAX_AGE) return l.data;
    } catch (_e) {}
    return null;
  }

  // Variations belonging to one product.
  window.tjVariationsFor = function(productId) {
    const all = _cachedVariations || window.tjAllVariations || [];
    return all.filter(v => String(v.product_id) === String(productId));
  };

  // ── CATALOG EXPANSION (REQ 4) ─────────────────────────────
  // Turn the parent catalog into listing entries. A parent with page-worthy
  // variations is replaced by one card per variation — the parent itself is not
  // listed, exactly like a marketplace listing each colour separately.
  // Entries are product-shaped so the existing filter/sort/search pipeline works
  // on them unchanged.
  window.tjBuildCatalogEntries = function(products) {
    const entries = [];
    (products || []).forEach(p => {
      entries.push(Object.assign({}, p, {
        _entryId: String(p.id),
        _isVariant: false,
        _parentId: p.id,
        _variation: null
      }));
    });
    window.tjCatalogEntries = entries;
    return entries;
  };

  // Rails (New Arrivals / Best Sellers) show one representative card per parent.
  // The main grid lists every variation; a rail of four near-identical colours of
  // the same ring would be noise, not merchandising.
  window.tjEntriesOnePerParent = function(entries) {
    const seen = new Set();
    const out = [];
    (entries || []).forEach(e => {
      const key = String(e._parentId);
      if (seen.has(key)) return;
      seen.add(key);
      out.push(e);
    });
    return out;
  };

  window.tjEntriesForParent = function(parentId) {
    return (window.tjCatalogEntries || []).filter(e => String(e._parentId) === String(parentId));
  };

  window.tjFindEntry = function(entryId) {
    return (window.tjCatalogEntries || []).find(e => e._entryId === String(entryId)) || null;
  };

  async function tjFetchProductsFresh() {
    if (!db) return null;
    const { data, error } = await db.from('products')
      .select('*')
      .eq('available', true)
      .order('created_at', { ascending: false })
      .limit(1000);
    if (error) { console.error(error); return null; }
    const list = data || [];
    _cachedProducts = list;
    try { localStorage.setItem(TJ_PRODUCTS_KEY, JSON.stringify({ ts: Date.now(), data: list })); } catch (_e) {}
    return list;
  }

  async function loadProducts() {
    if (!db) return;
    try {
      let fullProducts = _cachedProducts;

      // Fresh page load (in-memory empty): paint instantly from the persistent
      // cache if available, then ALWAYS revalidate from the network so any admin
      // change shows up — live if the tab stays open, and guaranteed on next refresh.
      if (!fullProducts) {
        let cached = null;
        try {
          const l = JSON.parse(localStorage.getItem(TJ_PRODUCTS_KEY) || 'null');
          if (l && Array.isArray(l.data) && (Date.now() - l.ts) < TJ_PRODUCTS_MAX_AGE) cached = l.data;
        } catch (_e) {}

        if (cached) {
          // Instant paint from cache …
          fullProducts = cached;
          _cachedProducts = cached;
          // … then revalidate in the background and re-render only if data changed.
          tjFetchProductsFresh().then(fresh => {
            if (fresh && JSON.stringify(fresh) !== JSON.stringify(cached)) {
              _cachedProducts = fresh;
              loadProducts();
            }
          }).catch(() => {});
        } else {
          // No usable cache — fetch fresh and wait.
          fullProducts = await tjFetchProductsFresh();
          if (!fullProducts) return;
        }
      }

      allProducts = fullProducts;

      // Variations drive the listing (REQ 4), so they must be present before we
      // expand. Cache-first for instant paint, then revalidate in the background.
      if (!_cachedVariations) {
        const cachedVars = tjLoadCachedVariations();
        if (cachedVars) {
          _cachedVariations = cachedVars;
          window.tjAllVariations = cachedVars;
          tjFetchVariationsFresh().then(fresh => {
            if (fresh && JSON.stringify(fresh) !== JSON.stringify(cachedVars)) loadProducts();
          }).catch(() => {});
        } else {
          await tjFetchVariationsFresh();
        }
      }

      // Parent catalog stays intact in allProducts; the listing renders entries.
      window.tjBuildCatalogEntries(allProducts);

      // Render sidebar filters dynamically based on active products in this category
      if (typeof renderSidebarFilters === 'function') {
        renderSidebarFilters();
      }

      // Filter locally — instant, no network call.
      // Entries are product-shaped, so every filter below works unchanged while
      // each variation is treated as its own listing item.
      let filteredProducts = window.tjCatalogEntries || allProducts;
      if (currentCategory !== 'all') {
        filteredProducts = filteredProducts.filter(p => isProductInCategory(p, currentCategory));
      }

      // Filter by active subcategories
      if (activeFilters.subcategories && activeFilters.subcategories.length > 0) {
        filteredProducts = filteredProducts.filter(p => {
          if (productSubcategories && productSubcategories.length > 0) {
            return productSubcategories.some(psc => 
              psc.product_id === p.id && 
              activeFilters.subcategories.includes(psc.subcategory_id)
            );
          } else {
            // Fallback match using product.category / subcategory_id / matching slugs
            const pCat = (p.category || '').toLowerCase().trim();
            return activeFilters.subcategories.some(subSlug => {
              const normSub = subSlug.toLowerCase().trim();
              return pCat === normSub || pCat.includes(normSub) || p.subcategory_id === normSub;
            });
          }
        });
      }

      // Filter by Price range
      if (activeFilters.priceMin !== null) {
        filteredProducts = filteredProducts.filter(p => parseFloat(p.price || 0) >= activeFilters.priceMin);
      }
      if (activeFilters.priceMax !== null) {
        filteredProducts = filteredProducts.filter(p => parseFloat(p.price || 0) <= activeFilters.priceMax);
      }

      // Filter by Availability
      if (activeFilters.availability === 'in-stock') {
        filteredProducts = filteredProducts.filter(p => p.available);
      } else if (activeFilters.availability === 'out-of-stock') {
        filteredProducts = filteredProducts.filter(p => !p.available);
      }

      // Filter by other dynamic filter groups (gender, plating, material, color, stone-type)
      const dynamicFilterKeys = ['gender', 'plating', 'material', 'color', 'stone-type'];
      dynamicFilterKeys.forEach(key => {
        const selectedValues = activeFilters[key];
        if (selectedValues && selectedValues.length > 0) {
          filteredProducts = filteredProducts.filter(p => {
            // If junction tables are populated
            if (allProductFilterValues && allProductFilterValues.length > 0) {
              return allProductFilterValues.some(pfv => {
                if (pfv.product_id !== p.id) return false;
                const fv = allFilterValues.find(v => v.id === pfv.filter_value_id);
                if (!fv) return false;
                const group = allFilterGroups.find(g => g.id === fv.filter_group_id);
                return group && group.slug === key && selectedValues.includes(fv.value);
              });
            } else {
              // Fallback client-side parsing of text
              const text = `${p.title} ${p.description} ${p.material || ''}`.toLowerCase();
              return selectedValues.some(val => {
                const normVal = val.toLowerCase();
                return text.includes(normVal);
              });
            }
          });
        }
      });

      // Sort locally
      if (currentSort === 'price_asc') {
        filteredProducts = [...filteredProducts].sort((a, b) => parseFloat(a.price || 0) - parseFloat(b.price || 0));
      } else if (currentSort === 'price_desc') {
        filteredProducts = [...filteredProducts].sort((a, b) => parseFloat(b.price || 0) - parseFloat(a.price || 0));
      }

      // Update count label
      const countEl = document.getElementById('tj-product-count-label');
      if (countEl) {
        countEl.textContent = `${filteredProducts.length} ${filteredProducts.length === 1 ? 'Product' : 'Products'} Found`;
      }

      // Load-More pagination — restart at the first page (6 products) on every
      // filter / sort / category (re)load; growth happens only via tjLoadMore().
      tjVisibleCount = TJ_PAGE_SIZE;
      tjCurrentFiltered = filteredProducts;
      renderProducts(filteredProducts.slice(0, tjVisibleCount));
      renderLoadMore();

      // Render New Arrivals (first 4 newest products, one card per product)
      const newArrivals = window.tjEntriesOnePerParent(window.tjCatalogEntries || allProducts).slice(0, 4);
      renderNewArrivals(newArrivals);

      const sMap = window.tjStorefrontSettings || {};

      // Render Best Seller Section (dynamic based on admin config)
      const bestsellersOuter = document.getElementById('tj-bestsellers-section');
      if (bestsellersOuter) {
        if (currentCategory !== 'all' || sMap.bestsellers_active === 'false') {
          bestsellersOuter.style.display = 'none';
        } else {
          const bestsellersTitleEl = bestsellersOuter.querySelector('.tj-section-title');
          if (bestsellersTitleEl && sMap.bestsellers_title) {
            bestsellersTitleEl.textContent = sMap.bestsellers_title;
          }
          let bestsellersFinal = [];
          if (sMap.bestsellers_products) {
            try {
              const ids = JSON.parse(sMap.bestsellers_products);
              if (Array.isArray(ids) && ids.length > 0) {
                bestsellersFinal = window.tjEntriesOnePerParent(
                  (window.tjCatalogEntries || allProducts).filter(e => ids.includes(e._parentId || e.id))
                );
              }
            } catch (e) {
              console.error("Error parsing bestsellers_products:", e);
            }
          }
          if (bestsellersFinal.length === 0) {
            const allEntries = window.tjEntriesOnePerParent(window.tjCatalogEntries || allProducts);
            const featuredSellers = allEntries.filter(e => e.featured);
            bestsellersFinal = featuredSellers.length > 0 ? featuredSellers : allEntries.slice(0, 5);
          }
          if (bestsellersFinal.length >= 1) {
            renderBestSellers(bestsellersFinal);
            bestsellersOuter.style.display = 'block';
          } else {
            bestsellersOuter.style.display = 'none';
          }
        }
      }

      // Render G.O.A.T. Deal Section
      const goatOuter = document.getElementById('tj-goat-deal-outer');
      if (goatOuter) {
        if (currentCategory !== 'all' || sMap.goat_deal_active === 'false') {
          goatOuter.style.display = 'none';
        } else {
          const goatTitleEl = document.getElementById('tj-goat-deal-title');
          if (goatTitleEl && sMap.goat_deal_title) {
            goatTitleEl.textContent = sMap.goat_deal_title;
          }
          let goatFinal = [];
          if (sMap.goat_deal_products) {
            try {
              const ids = JSON.parse(sMap.goat_deal_products);
              if (Array.isArray(ids) && ids.length > 0) {
                goatFinal = allProducts.filter(p => ids.includes(p.id));
              }
            } catch (e) {
              console.error("Error parsing goat_deal_products:", e);
            }
          }
          if (goatFinal.length === 0) {
            const goatDeals = allProducts.filter(p => p.tags && (p.tags.includes('deal-of-the-day') || p.tags.includes('goat-deal')));
            goatFinal = goatDeals.length >= 4 ? goatDeals : allProducts.slice(0, Math.max(4, goatDeals.length));
          }
          if (goatFinal.length >= 1) {
            renderDealSlider('tj-goat-deal-container', goatFinal);
            updateScrollDots('tj-goat-deal-container', 'tj-goat-deal-dots');
            goatOuter.style.display = 'block';

            const moreLink = document.getElementById('tj-goat-more-link');
            if (moreLink) {
              if (sMap.goat_deal_more_url) {
                moreLink.href = sMap.goat_deal_more_url;
                moreLink.style.display = 'inline-block';
              } else {
                moreLink.style.display = 'none';
              }
            }
          } else {
            goatOuter.style.display = 'none';
          }
        }
      }

      // Render Top Deals Section
      const topOuter = document.getElementById('tj-top-deal-outer');
      if (topOuter) {
        if (currentCategory !== 'all' || sMap.top_deals_active === 'false') {
          topOuter.style.display = 'none';
        } else {
          const topTitleEl = document.getElementById('tj-top-deal-title');
          if (topTitleEl && sMap.top_deals_title) {
            topTitleEl.textContent = sMap.top_deals_title;
          }
          let topFinal = [];
          if (sMap.top_deals_products) {
            try {
              const ids = JSON.parse(sMap.top_deals_products);
              if (Array.isArray(ids) && ids.length > 0) {
                topFinal = allProducts.filter(p => ids.includes(p.id));
              }
            } catch (e) {
              console.error("Error parsing top_deals_products:", e);
            }
          }
          if (topFinal.length === 0) {
            const topDeals = allProducts.filter(p => p.tags && p.tags.includes('top-deal'));
            topFinal = topDeals.length >= 4 ? topDeals : allProducts.slice(-Math.max(4, topDeals.length));
          }
          if (topFinal.length >= 1) {
            renderDealSlider('tj-top-deal-container', topFinal);
            updateScrollDots('tj-top-deal-container', 'tj-top-deal-dots');
            topOuter.style.display = 'block';

            const moreLink = document.getElementById('tj-top-more-link');
            if (moreLink) {
              if (sMap.top_deals_more_url) {
                moreLink.href = sMap.top_deals_more_url;
                moreLink.style.display = 'inline-block';
              } else {
                moreLink.style.display = 'none';
              }
            }
          } else {
            topOuter.style.display = 'none';
          }
        }
      }

      // Render Best Quality Section
      const qualityOuter = document.getElementById('tj-best-quality-outer');
      if (qualityOuter) {
        if (currentCategory !== 'all' || sMap.best_quality_active === 'false') {
          qualityOuter.style.display = 'none';
        } else {
          const qualityTitleEl = document.getElementById('tj-best-quality-title');
          if (qualityTitleEl && sMap.best_quality_title) {
            qualityTitleEl.textContent = sMap.best_quality_title;
          }
          let qualityFinal = [];
          if (sMap.best_quality_products) {
            try {
              const ids = JSON.parse(sMap.best_quality_products);
              if (Array.isArray(ids) && ids.length > 0) {
                qualityFinal = allProducts.filter(p => ids.includes(p.id));
              }
            } catch (e) {
              console.error("Error parsing best_quality_products:", e);
            }
          }
          if (qualityFinal.length === 0) {
            const bestQuality = allProducts.filter(p => p.tags && p.tags.includes('best-quality'));
            qualityFinal = bestQuality.length >= 4 ? bestQuality : allProducts.slice(Math.max(0, Math.floor(allProducts.length/2) - 2), Math.floor(allProducts.length/2) + 2);
          }
          if (qualityFinal.length >= 1) {
            renderBestQualityItems(qualityFinal);
            qualityOuter.style.display = 'block';

            const qualityBtn = document.getElementById('tj-best-quality-more-btn');
            if (qualityBtn) {
              if (sMap.best_quality_more_url) {
                qualityBtn.href = sMap.best_quality_more_url;
              } else {
                qualityBtn.onclick = (e) => {
                  e.preventDefault();
                  filterByCategory('all');
                  document.getElementById('tj-products-section').scrollIntoView({ behavior: 'smooth' });
                };
              }
            }
          } else {
            qualityOuter.style.display = 'none';
          }
        }
      }

      // Render Trending Items Section
      const trendingOuter = document.getElementById('tj-trending-outer');
      if (trendingOuter) {
        if (currentCategory !== 'all' || sMap.trending_active === 'false') {
          trendingOuter.style.display = 'none';
        } else {
          const trendingTitleEl = document.getElementById('tj-trending-title');
          if (trendingTitleEl && sMap.trending_title) trendingTitleEl.textContent = sMap.trending_title;
          let trendingFinal = [];
          if (sMap.trending_products) {
            try {
              const ids = JSON.parse(sMap.trending_products);
              if (Array.isArray(ids) && ids.length > 0) {
                trendingFinal = allProducts.filter(p => ids.includes(p.id));
              }
            } catch(e) {}
          }
          if (trendingFinal.length === 0) {
            trendingFinal = allProducts.slice(0, 8);
          }
          if (trendingFinal.length >= 1) {
            renderTrendingItems(trendingFinal);
            trendingOuter.style.display = 'block';
          } else {
            trendingOuter.style.display = 'none';
          }
        }
      }

      // Populate campaign backgrounds dynamically using product images or premium fallbacks
      const camp1 = document.getElementById('tj-camp-1');
      const camp2 = document.getElementById('tj-camp-2');
      const camp3 = document.getElementById('tj-camp-3');
      
      const defaultCamps = [
        'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?q=80&w=800&auto=format&fit=cover',
        'https://images.unsplash.com/photo-1603561591411-07134e71a2a9?q=80&w=800&auto=format&fit=cover',
        'https://images.unsplash.com/photo-1617038260897-41a1f14a8ca0?q=80&w=800&auto=format&fit=cover'
      ];

      if (camp1) {
        const img = (allProducts[0] && allProducts[0].image_url) ? formatImageUrl(allProducts[0].image_url) : defaultCamps[0];
        camp1.style.backgroundImage = `url(${img})`;
      }
      if (camp2) {
        const img = (allProducts[1] && allProducts[1].image_url) ? formatImageUrl(allProducts[1].image_url) : defaultCamps[1];
        camp2.style.backgroundImage = `url(${img})`;
      }
      if (camp3) {
        const img = (allProducts[2] && allProducts[2].image_url) ? formatImageUrl(allProducts[2].image_url) : defaultCamps[2];
        camp3.style.backgroundImage = `url(${img})`;
      }

      // ── DYNAMIC VIDEO SECTION (REELS) ──
      try {
        const reelsSection = document.getElementById('tj-reels-section');
        const sMap = window.tjStorefrontSettings || {};
        if (reelsSection) {
          let reelsList = [];
          if (sMap.reels_videos) {
            try {
              reelsList = JSON.parse(sMap.reels_videos);
            } catch (_) {}
          }
          
          // Filter out empty items
          const validVideos = reelsList.filter(v => v.upload_url || v.url);
          
          if (validVideos.length > 0) {
            const grid = reelsSection.querySelector('.tj-reels-grid');
            if (grid) {
              // Helper to get embed or direct source
              function getEmbedOrVideoSrc(url) {
                if (!url) return null;
                
                // YouTube check
                let ytId = null;
                const ytReg = /(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/ ]{11})/;
                const ytMatch = url.match(ytReg);
                if (ytMatch && ytMatch[1]) {
                  ytId = ytMatch[1];
                  return {
                    type: 'youtube',
                    src: `https://www.youtube.com/embed/${ytId}?autoplay=1&mute=1&loop=1&playlist=${ytId}&controls=0&modestbranding=1&playsinline=1`
                  };
                }
                
                // Vimeo check
                let vimeoId = null;
                const vimeoReg = /(?:vimeo\.com\/(?:video\/)?|player\.vimeo\.com\/video\/)(\d+)/;
                const vimeoMatch = url.match(vimeoReg);
                if (vimeoMatch && vimeoMatch[1]) {
                  vimeoId = vimeoMatch[1];
                  return {
                    type: 'vimeo',
                    src: `https://player.vimeo.com/video/${vimeoId}?autoplay=1&muted=1&loop=1&autopause=0&controls=0`
                  };
                }
                
                // Direct link / fallback
                return {
                  type: 'direct',
                  src: url
                };
              }

              // Rebuild the grid cards dynamically
              grid.innerHTML = '';
              validVideos.forEach(v => {
                const activeUrl = v.upload_url || v.url;
                const videoObj = getEmbedOrVideoSrc(activeUrl);
                if (videoObj) {
                  const card = document.createElement('div');
                  card.className = 'tj-reel-card';
                  
                  if (videoObj.type === 'youtube' || videoObj.type === 'vimeo') {
                    const iframe = document.createElement('iframe');
                    iframe.className = 'tj-reel-media';
                    iframe.src = videoObj.src;
                    iframe.setAttribute('frameborder', '0');
                    iframe.setAttribute('allow', 'autoplay; encrypted-media; picture-in-picture');
                    iframe.setAttribute('allowfullscreen', 'true');
                    iframe.style.width = '100%';
                    iframe.style.height = '100%';
                    iframe.style.objectFit = 'cover';
                    iframe.style.border = 'none';
                    card.appendChild(iframe);
                  } else {
                    const videoEl = document.createElement('video');
                    videoEl.className = 'tj-reel-media';
                    videoEl.autoplay = true;
                    videoEl.loop = true;
                    videoEl.muted = true;
                    videoEl.setAttribute('playsinline', 'true');
                    
                    const sourceEl = document.createElement('source');
                    sourceEl.src = videoObj.src;
                    sourceEl.type = 'video/mp4';
                    videoEl.appendChild(sourceEl);
                    
                    card.appendChild(videoEl);
                    
                    // Create and append mute button for direct HTML5 video
                    const muteBtn = document.createElement('div');
                    muteBtn.className = 'tj-reel-mute-btn';
                    muteBtn.setAttribute('onclick', 'toggleMute(this)');
                    muteBtn.innerHTML = '<svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>';
                    card.appendChild(muteBtn);
                  }
                  
                  grid.appendChild(card);
                }
              });
            }
          }
        }
      } catch (e) {
        console.error("Error setting dynamic reels:", e);
      }

      // Final Cleanup: Ensure all homepage-specific sections are strictly hidden when a category filter is active
      if (currentCategory !== 'all') {
        const sectionsToForceHide = [
          'tj-hero-banner',
          'tj-goat-deal-outer',
          'tj-top-deal-outer',
          'tj-shop-by-category-outer',
          'tj-bestsellers-section',
          'tj-new-arrivals-section',
          'tj-trending-outer',
          'tj-reels-section',
          'tj-best-quality-outer',
          'tj-quick-categories-section',
          'tj-categories-directory-section',
          'tj-trust-bar',
          'tj-reviews-section'
        ];
        sectionsToForceHide.forEach(id => {
          const el = document.getElementById(id);
          if (el) el.style.display = 'none';
        });

        const classesToForceHide = ['.tj-promises-bar', '.tj-campaign-section'];
        classesToForceHide.forEach(cls => {
          const el = document.querySelector(cls);
          if (el) el.style.display = 'none';
        });
        
        const productsSection = document.getElementById('tj-products-section');
        if (productsSection) productsSection.style.display = 'block';
      }

      // Products have rendered — mark ready. The preloader is dismissed centrally
      // once ALL required data (settings, navbar, categories, products) is ready.
      window._tjProductsReady = true;
    } catch (err) {

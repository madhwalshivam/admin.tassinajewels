    const isWishlisted = localStorage.getItem('tj_wl_' + entryId) === '1';
    const moq = p.moq || 2;
    const outOfStock = p.stock_status === 'out_of_stock' ||
      (p.stock_quantity !== undefined && p.stock_quantity !== null && p.stock_quantity <= 0);


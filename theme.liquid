          <div class="tj-skeleton-shimmer" style="width:100%; aspect-ratio:16/10; background: #e2e8f0; position: relative; overflow: hidden;"></div>
          <div style="padding: 16px 20px; background: #ffffff; display: flex; align-items: center; justify-content: space-between;">
            <div class="tj-skeleton-shimmer" style="height: 14px; width: 60%; background: #e2e8f0; border-radius: 4px; overflow: hidden;"></div>

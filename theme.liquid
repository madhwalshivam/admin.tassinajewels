          </div>

          <!-- Product Main Block (Gallery + Info) -->
          <div class="tj-pdp-main-grid" style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 40px; margin-bottom: 48px; align-items: start;">
            
            <!-- Left Side: Image Gallery -->

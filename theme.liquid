  // Get dynamic category-to-product mapping helper
  function isProductInCategory(p, catSlug) {
    if (!catSlug || catSlug === 'all') return true;
    
    // 1. If we have the new junction mappings (Migrated Schema)
    if (productCategories && productCategories.length > 0 && allCategories && allCategories.length > 0) {
      const targetCat = allCategories.find(c => c.slug === catSlug);
      if (targetCat) {
        return productCategories.some(pc => pc.product_id === p.id && pc.category_id === targetCat.id);
      }
    }
    
    // 2. Fallback to legacy string column checks (Legacy Schema)
    const pCat = (p.category || '').toLowerCase().trim();
    const cSlug = catSlug.toLowerCase().trim();
    
    // Exact match
    if (pCat === cSlug) return true;
    
    // Custom prefix grouping fallback:
    if (cSlug === 'vintage-jewellery' && pCat.startsWith('vintage-')) return true;
    if (cSlug === 'stainless-steel-jewellery' && pCat.startsWith('stainless-steel-')) return true;
    if (cSlug === 'natural-stone-jewellery' && (pCat === 'natural-stones-jewellry' || pCat === 'natural-stone-jewellery')) return true;
    if (cSlug === 'custom-jewellery' && (pCat === 'custom-jewellery' || pCat === 'rings' || pCat === 'necklace' || pCat === 'bracelets' || pCat === 'bracelet')) return true;
    if (cSlug === 'mens' && pCat === 'mens') return true;
    if (cSlug === 'womens' && pCat === 'womens') return true;
    
    // Plural/singular adjustments (remove 's' at the end of either)
    const normPCat = pCat.endsWith('s') ? pCat.slice(0, -1) : pCat;
    const normCSlug = cSlug.endsWith('s') ? cSlug.slice(0, -1) : cSlug;
    if (normPCat === normCSlug) return true;

    // Keyword match: e.g. cSlug: "vintage-rings" contains normPCat: "ring"
    if (cSlug.includes(normPCat) || normPCat.includes(cSlug)) return true;
    
    // Specific match: e.g. "earings" / "earrings" typo
    if ((cSlug.includes('earing') || cSlug.includes('earring')) && (pCat.includes('earing') || pCat.includes('earring'))) return true;
    if ((cSlug.includes('necklace') || cSlug.includes('necklaces')) && (pCat.includes('necklace') || pCat.includes('necklaces'))) return true;
    if ((cSlug.includes('bracelet') || cSlug.includes('bracelets')) && (pCat.includes('bracelet') || pCat.includes('bracelets'))) return true;
    if ((cSlug.includes('jewellry') || cSlug.includes('jewelry')) && (pCat.includes('jewellry') || pCat.includes('jewelry'))) return true;
    
    return false;
  }

  // ─── LOAD PRODUCTS ────────────────────────────────────────
  // Fetch products from the network and refresh the in-memory + persistent caches.
  async function tjFetchProductsFresh() {
    if (!db) return null;
    const { data, error } = await db.from('products')
      .select('*')
      .eq('available', true)
      .order('created_at', { ascending: false })
      .limit(1000);
    if (error) { console.error(error); return null; }
    const list = data || [];
    _cachedProducts = list;
    try { localStorage.setItem(TJ_PRODUCTS_KEY, JSON.stringify({ ts: Date.now(), data: list })); } catch (_e) {}
    return list;
  }

  async function loadProducts() {
    if (!db) return;
    try {
      let fullProducts = _cachedProducts;

      // Fresh page load (in-memory empty): paint instantly from the persistent
      // cache if available, then ALWAYS revalidate from the network so any admin
      // change shows up — live if the tab stays open, and guaranteed on next refresh.
      if (!fullProducts) {
        let cached = null;
        try {
          const l = JSON.parse(localStorage.getItem(TJ_PRODUCTS_KEY) || 'null');
          if (l && Array.isArray(l.data) && (Date.now() - l.ts) < TJ_PRODUCTS_MAX_AGE) cached = l.data;
        } catch (_e) {}

        if (cached) {
          // Instant paint from cache …
          fullProducts = cached;
          _cachedProducts = cached;
          // … then revalidate in the background and re-render only if data changed.
          tjFetchProductsFresh().then(fresh => {
            if (fresh && JSON.stringify(fresh) !== JSON.stringify(cached)) {
              _cachedProducts = fresh;
              loadProducts();
            }
          }).catch(() => {});
        } else {
          // No usable cache — fetch fresh and wait.
          fullProducts = await tjFetchProductsFresh();
          if (!fullProducts) return;
        }
      }

      allProducts = fullProducts;

      // Render sidebar filters dynamically based on active products in this category
      if (typeof renderSidebarFilters === 'function') {
        renderSidebarFilters();
      }

      // Filter locally — instant, no network call
      let filteredProducts = allProducts;
      if (currentCategory !== 'all') {
        filteredProducts = filteredProducts.filter(p => isProductInCategory(p, currentCategory));
      }

      // Filter by active subcategories
      if (activeFilters.subcategories && activeFilters.subcategories.length > 0) {
        filteredProducts = filteredProducts.filter(p => {
          if (productSubcategories && productSubcategories.length > 0) {
            return productSubcategories.some(psc => 
              psc.product_id === p.id && 
              activeFilters.subcategories.includes(psc.subcategory_id)
            );
          } else {
            // Fallback match using product.category / subcategory_id / matching slugs
            const pCat = (p.category || '').toLowerCase().trim();
            return activeFilters.subcategories.some(subSlug => {
              const normSub = subSlug.toLowerCase().trim();
              return pCat === normSub || pCat.includes(normSub) || p.subcategory_id === normSub;
            });
          }
        });
      }

      // Filter by Price range
      if (activeFilters.priceMin !== null) {
        filteredProducts = filteredProducts.filter(p => parseFloat(p.price || 0) >= activeFilters.priceMin);
      }
      if (activeFilters.priceMax !== null) {
        filteredProducts = filteredProducts.filter(p => parseFloat(p.price || 0) <= activeFilters.priceMax);
      }

      // Filter by Availability
      if (activeFilters.availability === 'in-stock') {
        filteredProducts = filteredProducts.filter(p => p.available);
      } else if (activeFilters.availability === 'out-of-stock') {
        filteredProducts = filteredProducts.filter(p => !p.available);
      }

      // Filter by other dynamic filter groups (gender, plating, material, color, stone-type)
      const dynamicFilterKeys = ['gender', 'plating', 'material', 'color', 'stone-type'];
      dynamicFilterKeys.forEach(key => {
        const selectedValues = activeFilters[key];
        if (selectedValues && selectedValues.length > 0) {
          filteredProducts = filteredProducts.filter(p => {
            // If junction tables are populated
            if (allProductFilterValues && allProductFilterValues.length > 0) {
              return allProductFilterValues.some(pfv => {
                if (pfv.product_id !== p.id) return false;
                const fv = allFilterValues.find(v => v.id === pfv.filter_value_id);
                if (!fv) return false;
                const group = allFilterGroups.find(g => g.id === fv.filter_group_id);
                return group && group.slug === key && selectedValues.includes(fv.value);
              });
            } else {
              // Fallback client-side parsing of text
              const text = `${p.title} ${p.description} ${p.material || ''}`.toLowerCase();
              return selectedValues.some(val => {
                const normVal = val.toLowerCase();
                return text.includes(normVal);
              });
            }
          });
        }
      });

      // Sort locally
      if (currentSort === 'price_asc') {
        filteredProducts = [...filteredProducts].sort((a, b) => parseFloat(a.price || 0) - parseFloat(b.price || 0));
      } else if (currentSort === 'price_desc') {
        filteredProducts = [...filteredProducts].sort((a, b) => parseFloat(b.price || 0) - parseFloat(a.price || 0));
      }

      // Update count label
      const countEl = document.getElementById('tj-product-count-label');
      if (countEl) {
        countEl.textContent = `${filteredProducts.length} ${filteredProducts.length === 1 ? 'Product' : 'Products'} Found`;
      }

      // Paginated slice
      const itemsPerPage = 12;
      const totalItems = filteredProducts.length;
      const totalPages = Math.ceil(totalItems / itemsPerPage);
      
      const urlParams = new URLSearchParams(window.location.search);
      let currentPage = parseInt(urlParams.get('p') || '1', 10);
      if (isNaN(currentPage) || currentPage < 1) currentPage = 1;
      if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;

      const startIndex = (currentPage - 1) * itemsPerPage;
      const endIndex = startIndex + itemsPerPage;
      const paginatedProducts = filteredProducts.slice(startIndex, endIndex);

      renderProducts(paginatedProducts);
      renderPagination(currentPage, totalPages);

      // Render New Arrivals (first 4 newest products)
      const newArrivals = allProducts.slice(0, 4);
      renderNewArrivals(newArrivals);

      const sMap = window.tjStorefrontSettings || {};

      // Render Best Seller Section (dynamic based on admin config)
      const bestsellersOuter = document.getElementById('tj-bestsellers-section');
      if (bestsellersOuter) {
        if (currentCategory !== 'all' || sMap.bestsellers_active === 'false') {
          bestsellersOuter.style.display = 'none';
        } else {
          const bestsellersTitleEl = bestsellersOuter.querySelector('.tj-section-title');
          if (bestsellersTitleEl && sMap.bestsellers_title) {
            bestsellersTitleEl.textContent = sMap.bestsellers_title;
          }
          let bestsellersFinal = [];
          if (sMap.bestsellers_products) {
            try {
              const ids = JSON.parse(sMap.bestsellers_products);
              if (Array.isArray(ids) && ids.length > 0) {
                bestsellersFinal = allProducts.filter(p => ids.includes(p.id));
              }
            } catch (e) {
              console.error("Error parsing bestsellers_products:", e);
            }
          }
          if (bestsellersFinal.length === 0) {
            const featuredSellers = allProducts.filter(p => p.featured);

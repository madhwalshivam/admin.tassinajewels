  // ─── RENDER PAGINATION ────────────────────────────────────
  function renderPagination(currentPage, totalPages) {
    const container = document.getElementById('tj-products-pagination');
    if (!container) return;

    if (totalPages <= 1) {
      container.innerHTML = '';
      return;
    }

    let html = '';

    // Previous Button
    const prevDisabled = currentPage === 1;
    html += `
      <button onclick="${prevDisabled ? '' : `changeProductPage(${currentPage - 1})`}" 
              class="tj-pagination-btn"
              ${prevDisabled ? 'disabled' : ''}>
        ‹
      </button>
    `;

    // Page Numbers
    const maxVisiblePages = 5;
    let startPage = Math.max(1, currentPage - 2);
    let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);
    
    if (endPage - startPage < maxVisiblePages - 1) {
      startPage = Math.max(1, endPage - maxVisiblePages + 1);
    }

    if (startPage > 1) {
      html += `
        <button onclick="changeProductPage(1)" class="tj-pagination-btn">
          1
        </button>
      `;
      if (startPage > 2) {
        html += `<span class="tj-pagination-ellipsis">...</span>`;
      }
    }

    for (let i = startPage; i <= endPage; i++) {
      const isActive = i === currentPage;
      html += `
        <button onclick="changeProductPage(${i})" 
                class="tj-pagination-btn ${isActive ? 'active' : ''}">
          ${i}
        </button>
      `;
    }

    if (endPage < totalPages) {
      if (endPage < totalPages - 1) {
        html += `<span class="tj-pagination-ellipsis">...</span>`;
      }
      html += `
        <button onclick="changeProductPage(${totalPages})" class="tj-pagination-btn">
          ${totalPages}
        </button>
      `;
    }

    // Next Button
    const nextDisabled = currentPage === totalPages;
    html += `
      <button onclick="${nextDisabled ? '' : `changeProductPage(${currentPage + 1})`}" 
              class="tj-pagination-btn"
              ${nextDisabled ? 'disabled' : ''}>
        ›
      </button>
    `;

    container.innerHTML = html;
  }


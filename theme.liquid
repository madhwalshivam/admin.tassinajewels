  }
  .tj-quality-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .tj-quality-card-title {
    font-size: 11px;
    font-weight: 500;
    color: var(--green);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 4px;
    font-family: var(--font-sans);
  }
  .tj-quality-card-price {
    font-size: 12px;
    font-weight: 700;
    color: var(--green);
    font-family: var(--font-sans);
  }

  /* Stars select layout */
  .tj-rating-star {
    transition: color 0.2s;
  }
  .tj-rating-star:hover {
    transform: scale(1.15);
  }

  @media (max-width: 768px) {
    .tj-deal-container-gradient { padding: 24px 16px; border-radius: 16px; }

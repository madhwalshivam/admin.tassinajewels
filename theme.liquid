<body class='color-body m-0 bg-body text-body-color template-{{template.name}} font-light' id='hero-2024'>
  <!-- ===== BRAND PRELOADER OVERLAY ===== -->
  <div id="tj-preloader">
    <div class="tj-preloader-logo-wrap">
      <div class="tj-preloader-glow"></div>
      <img src="https://res.cloudinary.com/dxiasatlk/image/upload/v1783413279/29aa78f0974ba0eff61ad18086e37001_mrvtl3.webp" alt="Tassina Jewels" class="tj-preloader-logo">
    </div>
    <div style="margin-top:22px;font-family:'Cinzel',serif;color:#E3BA45;font-size:21px;font-weight:600;letter-spacing:4px;text-transform:uppercase;text-align:center;">Tassina Jewels</div>
    <div style="margin-top:6px;font-family:'Montserrat',sans-serif;color:rgba(255,255,255,0.55);font-size:9.5px;letter-spacing:2.5px;text-transform:uppercase;text-align:center;">Handcrafted Fine Jewelry</div>
    <div class="tj-loader-dots" id="tj-loader-dots" style="margin-top:20px;">
      <div class="tj-loader-dot"></div>
      <div class="tj-loader-dot"></div>
      <div class="tj-loader-dot"></div>
    </div>
    <div id="tj-preloader-slow" style="margin-top:20px;color:rgba(227,186,69,0.9);font-size:12px;letter-spacing:0.4px;font-family:'Montserrat',sans-serif;text-align:center;max-width:280px;padding:0 24px;line-height:1.5;opacity:0;transition:opacity 0.4s ease;">
      Slow connection detected — loading your catalog, please wait…
    </div>
    <div id="tj-preloader-error" style="display:none;margin-top:20px;text-align:center;max-width:300px;padding:0 24px;font-family:'Montserrat',sans-serif;">
      <p style="color:rgba(255,255,255,0.85);font-size:13px;line-height:1.6;margin-bottom:16px;">We're having trouble loading the store. Please check your connection.</p>
      <button onclick="window.location.reload()" style="background:#E3BA45;color:#1B4332;border:none;border-radius:8px;padding:10px 24px;font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;cursor:pointer;">Retry</button>
    </div>
  </div>
  <script>
    window._tjSplashStart = Date.now();
    window._tjPreloaderDone = false;
    // Small floor so instant/cached loads don't flash — NOT a timeout that hides
    // the loader; the loader is dismissed only when the required data is ready.
    var TJ_SPLASH_MIN = 800;

    window.hidePreloader = function() {
      if (window._tjPreloaderDone) return;
      var elapsed = Date.now() - window._tjSplashStart;
      if (elapsed < TJ_SPLASH_MIN) {
        if (!window._tjHideScheduled) {
          window._tjHideScheduled = true;
          setTimeout(function () { window._tjHideScheduled = false; window.hidePreloader(); }, TJ_SPLASH_MIN - elapsed);
        }
        return;
      }
      window._tjPreloaderDone = true;
      var preloader = document.getElementById('tj-preloader');
      if (preloader) {
        preloader.style.opacity = '0';
        preloader.style.visibility = 'hidden';
        setTimeout(function () { preloader.remove(); }, 600);
      }
      if (window._tjSlowTimer) { clearTimeout(window._tjSlowTimer); window._tjSlowTimer = null; }
      if (window._tjSafetyTimer) { clearTimeout(window._tjSafetyTimer); window._tjSafetyTimer = null; }
    };

    // Show an error state (with Retry) instead of hiding with incomplete content.
    window.tjShowLoadError = function() {
      if (window._tjPreloaderDone) return;
      var dots = document.getElementById('tj-loader-dots');
      var slow = document.getElementById('tj-preloader-slow');
      var err = document.getElementById('tj-preloader-error');
      if (dots) dots.style.display = 'none';
      if (slow) slow.style.opacity = '0';
      if (err) err.style.display = 'block';
    };

    // If the connection is slow, show a reassuring message (does NOT hide the loader).
    window._tjSlowTimer = setTimeout(function () {
      var msg = document.getElementById('tj-preloader-slow');
      if (msg) msg.style.opacity = '1';
    }, 7000);
    // Long backstop: if data still hasn't loaded after a long wait, show the error
    // state (retry) rather than leaving the user stuck forever.
    window._tjSafetyTimer = setTimeout(function () {
      if (!window._tjPreloaderDone) window.tjShowLoadError();
    }, 40000);
  </script>

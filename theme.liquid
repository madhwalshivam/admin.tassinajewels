  <!-- Aggressive platform widget/slider killer -->
  <script>
  (function killPlatformWidgets() {
    const KILL_SELECTORS = [
      '[class*="swiper"]:not([class*="tj-"]):not([class*="swiper-"])',
      '[class*="slider-wrap"]:not([class*="tj-"])',
      '[class*="slider"]:not([class*="tj-"]):not([class*="swiper-"])',
      '[class*="carousel"]:not([class*="tj-"])',
      '[class*="toolbar"]', '[class*="float-bar"]', '[class*="aside-bar"]',
      '[class*="right-bar"]', '[class*="plugin-bar"]', '[class*="side-bar"]',
      '[id*="toolbar"]', '[id*="aside-bar"]', '[id*="float-bar"]',
      '.plugin__static-div'
    ];
    
    function killEls() {
      // Hide using selectors
      KILL_SELECTORS.forEach(sel => {
        document.querySelectorAll(sel).forEach(el => {
          el.style.setProperty('display', 'none', 'important');
          el.style.setProperty('width', '0', 'important');
          el.style.setProperty('height', '0', 'important');
          el.style.setProperty('opacity', '0', 'important');
          el.style.setProperty('pointer-events', 'none', 'important');
        });
      });

      // Find and hide any other fixed/absolute widgets on the right side
      document.querySelectorAll('*').forEach(el => {
        // Never touch our own storefront UI (anything with a tj- id/class or inside one)
        if ((el.id && el.id.indexOf('tj-') === 0) ||
            (typeof el.className === 'string' && el.className.indexOf('tj-') !== -1) ||
            (el.closest && el.closest('[id^="tj-"]'))) {
          return;
        }
        if (el.id === 'tj-fab-container' || el.closest('#tj-fab-container') ||
            el.id === 'tj-bottom-nav' || el.closest('#tj-bottom-nav') ||
            el.id === 'tj-modal' || el.closest('#tj-modal') ||
            el.id === 'tj-announcement-bar' || el.closest('#tj-announcement-bar') ||
            el.id === 'tj-custom-header' || el.closest('#tj-custom-header')) {
          return;
        }
        if (['HTML', 'BODY', 'SCRIPT', 'STYLE', 'LINK', 'META', 'HEAD'].includes(el.tagName)) {
          return;
        }
        const style = window.getComputedStyle(el);
        if (style.position === 'fixed' || style.position === 'absolute') {
          const rightVal = parseFloat(style.right);
          const topVal = parseFloat(style.top);
          if (!isNaN(rightVal) && rightVal <= 60 && !isNaN(topVal) && topVal > 100) {
            el.style.setProperty('display', 'none', 'important');
            el.style.setProperty('opacity', '0', 'important');
            el.style.setProperty('pointer-events', 'none', 'important');
          }
        }
      });
    }

    killEls();
    document.addEventListener('DOMContentLoaded', killEls);
    window.addEventListener('load', killEls);

    // Debounce observer callbacks so we don't rescan the whole DOM on every mutation
    let _killScheduled = false;
    const killElsDebounced = () => {
      if (_killScheduled) return;
      _killScheduled = true;
      (window.requestAnimationFrame || window.setTimeout)(() => {
        _killScheduled = false;
        killEls();
      }, 120);
    };
    const obs = new MutationObserver(killElsDebounced);
    obs.observe(document.body, { childList: true, subtree: true });
    
    // Delays for late loading items
    setTimeout(killEls, 500);
    setTimeout(killEls, 1500);
    setTimeout(killEls, 3000);
    setTimeout(killEls, 5000);
  })();

  async function loadReviews() {
    const swiperWrapper = document.querySelector('.tj-swiper-reviews .swiper-wrapper');
    if (!swiperWrapper) return;
    
    // Clear wrapper first to prepare for loading
    swiperWrapper.innerHTML = '';

    let dbReviews = [];
    if (db) {
      try {
        const { data, error } = await db.from('reviews').select('*').eq('approved', true).order('created_at', { ascending: false });
        if (!error && data) {
          dbReviews = data;
        } else if (error) {
          console.error('Error loading reviews:', error.message);
        }
      } catch (e) {
        console.error(e);
      }
    }

    const localReviews = JSON.parse(localStorage.getItem('tj_local_reviews') || '[]');
    const allLoaded = [...localReviews, ...dbReviews];

    if (allLoaded.length > 0) {
      // Sort by date ascending so newest appears last (slider starts from first)
      allLoaded.sort((a, b) => new Date(a.created_at || 0) - new Date(b.created_at || 0));
      allLoaded.forEach(r => appendReviewToSlider(r));
    } else {
      // Fallback to default reviews if none in DB or local storage
      DEFAULT_REVIEWS.forEach(r => appendReviewToSlider(r));
    }

    // Reinitialize swiper after all slides are in DOM
    if (window.reviewsSwiper) {
      window.reviewsSwiper.update();
      window.reviewsSwiper.slideTo(0, 0);
    }
  }


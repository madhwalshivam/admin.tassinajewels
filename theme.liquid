      #tj-filter-modal .tj-fm-body{padding:4px 20px 16px;overflow-y:auto;flex:1;-webkit-overflow-scrolling:touch;}
      #tj-filter-modal .tj-fm-body .tj-sidebar-mobile-header{display:none !important;}
      #tj-filter-modal .tj-fm-foot{display:flex;gap:12px;padding:14px 20px calc(14px + env(safe-area-inset-bottom));border-top:1px solid rgba(27,67,50,.08);background:#fff;flex-shrink:0;}

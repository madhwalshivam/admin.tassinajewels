            <input type="radio" name="availability" value="in-stock" ${activeFilters.availability === 'in-stock' ? 'checked' : ''} onchange="handleAvailabilityChange(this.value)" style="accent-color: var(--green); cursor: pointer;">
            In Stock
          </label>
        </div>
      </div>
    `;

    // 2. Price Range Filter Section
    html += `
      <div class="tj-filter-section">
        <button class="tj-filter-section-header" onclick="toggleFilterSection(event, this)">
          Price Range
          <svg class="tj-caret-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="tj-filter-section-content" style="display: flex; flex-direction: column; gap: 8px;">
          <div style="display: flex; gap: 8px; align-items: center;">
            <input type="number" placeholder="Min" value="${activeFilters.priceMin || ''}" onchange="handlePriceFilterChange('priceMin', this.value)" style="width: 100%; padding: 6px 10px; font-size: 12px; border: 1px solid #eae6e0; border-radius: 6px; outline: none; font-family: var(--font-sans);">
            <span style="font-size: 12px; color: #aaa;">to</span>
            <input type="number" placeholder="Max" value="${activeFilters.priceMax || ''}" onchange="handlePriceFilterChange('priceMax', this.value)" style="width: 100%; padding: 6px 10px; font-size: 12px; border: 1px solid #eae6e0; border-radius: 6px; outline: none; font-family: var(--font-sans);">
          </div>
        </div>
      </div>
    `;

    // 3. Subcategories Filter Section
    const currentCatObj = navigationTree.find(c => c.slug === currentCategory);
    if (currentCatObj && currentCatObj.subcategories && currentCatObj.subcategories.length > 0) {
      html += `
        <div class="tj-filter-section">
          <button class="tj-filter-section-header" onclick="toggleFilterSection(event, this)">
            Subcategory
            <svg class="tj-caret-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="tj-filter-section-content">
            ${currentCatObj.subcategories.map(sub => {
              const isChecked = activeFilters.subcategories.includes(sub.slug) || activeFilters.subcategories.includes(sub.id);
              const val = sub.id || sub.slug;
              return `
                <label style="display: flex; align-items: center; gap: 8px; font-size: 12px; color: #4a5568; cursor: pointer; font-family: var(--font-sans);">
                  <input type="checkbox" value="${val}" ${isChecked ? 'checked' : ''} onchange="handleFilterChange('subcategories', '${val}', this.checked)" style="accent-color: var(--green); cursor: pointer;">
                  ${sub.name}
                </label>
              `;
            }).join('')}
          </div>
        </div>
      `;
    }

    // 4. Dynamic Custom Attributes Filter Groups (Plating, Color, Material, Gender, Stone Type)
    const activeProducts = allProducts.filter(p => isProductInCategory(p, currentCategory));

    const filterKeys = [
      { key: 'gender', name: 'Gender' },
      { key: 'plating', name: 'Plating' },
      { key: 'material', name: 'Material' },
      { key: 'color', name: 'Color' },
      { key: 'stone-type', name: 'Stone Type' }
    ];

    filterKeys.forEach(fKey => {
      let options = new Set();
      
      if (allProductFilterValues && allProductFilterValues.length > 0) {
        activeProducts.forEach(p => {
          allProductFilterValues.forEach(pfv => {
            if (pfv.product_id === p.id) {
              const fv = allFilterValues.find(v => v.id === pfv.filter_value_id);
              if (fv) {
                const group = allFilterGroups.find(g => g.id === fv.filter_group_id);
                if (group && group.slug === fKey.key) {
                  options.add(fv.value);
                }
              }
            }
          });
        });
      }
      
      if (options.size === 0) {
        const fallbackOptionMap = {
          gender: ["Men", "Women", "Unisex"],
          plating: ["18K Gold", "Plated", "Silver Plated", "Rose Gold"],
          material: ["Stainless Steel", "Sterling Silver", "Copper", "Natural Stone", "Brass", "Zircon"],
          color: ["Gold", "Silver", "Rose Gold", "Black", "Green", "Blue", "Red", "White"],
          'stone-type': ["Zircon", "Agate", "Tiger Eye", "Obsidian", "Opal", "Turquoise", "Quartz", "Amethyst", "Lapis Lazuli", "Malachite", "Jade"]
        };
        
        const possibleOptions = fallbackOptionMap[fKey.key] || [];
        possibleOptions.forEach(opt => {
          const normOpt = opt.toLowerCase();
          const matches = activeProducts.some(p => {
            const text = `${p.title} ${p.description} ${p.material || ''}`.toLowerCase();
            return text.includes(normOpt);
          });
          if (matches) {
            options.add(opt);
          }
        });
      }

      if (options.size > 0) {
        html += `
          <div class="tj-filter-section">
            <button class="tj-filter-section-header" onclick="toggleFilterSection(event, this)">
              ${fKey.name}
              <svg class="tj-caret-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="tj-filter-section-content">
              ${Array.from(options).map(opt => {
                const isChecked = (activeFilters[fKey.key] || []).includes(opt);
                return `
                  <label style="display: flex; align-items: center; gap: 8px; font-size: 12px; color: #4a5568; cursor: pointer; font-family: var(--font-sans);">
                    <input type="checkbox" value="${opt}" ${isChecked ? 'checked' : ''} onchange="handleFilterChange('${fKey.key}', '${opt}', this.checked)" style="accent-color: var(--green); cursor: pointer;">
                    ${opt}
                  </label>
                `;
              }).join('')}
            </div>
          </div>
        `;
      }
    });

    sidebar.innerHTML = html;
  };

  window.toggleFilterSection = function(e, btn) {
    btn.classList.toggle('collapsed');
  };

  // Inject filter-modal styles once
  window.tjEnsureFilterModalStyles = function() {
